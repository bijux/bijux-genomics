{
  "stage_id": "bam.complexity",
  "stage_version": 1,
  "tool_id": "preseq",
  "tool_version": "1.0.0",
  "image": {
    "image": "bijux/test:latest",
    "digest": null
  },
  "command": {
    "template": [
      "/bin/sh",
      "-c",
      "preseq lc_extrap -o out/preseq.txt tests/fixtures/plan_inputs/default/sample.bam && python - <<'PY' > out/complexity.json\nimport json\nprint(json.dumps({\"source\": \"preseq\", \"report\": \"out/preseq.txt\"}, indent=2))\nPY && python - <<'PY' > out/complexity.summary.json\nimport json\nprint(json.dumps({\"stage\": \"bam.complexity\", \"preseq\": \"out/preseq.txt\"}, indent=2))\nPY"
    ]
  },
  "resources": {
    "runtime": "docker",
    "mem_gb": 1,
    "tmp_gb": 1,
    "threads": 1
  },
  "io": {
    "inputs": [
      {
        "name": "bam",
        "path": "tests/fixtures/plan_inputs/default/sample.bam",
        "role": "bam",
        "optional": false
      }
    ],
    "outputs": [
      {
        "name": "complexity_report",
        "path": "out/complexity.json",
        "role": "report_json",
        "optional": false
      },
      {
        "name": "preseq",
        "path": "out/preseq.txt",
        "role": "unknown",
        "optional": false
      },
      {
        "name": "summary",
        "path": "out/complexity.summary.json",
        "role": "report_json",
        "optional": false
      },
      {
        "name": "stage_metrics",
        "path": "out/stage.metrics.json",
        "role": "metrics_json",
        "optional": false
      }
    ]
  },
  "out_dir": "out",
  "params": {
    "bam": "tests/fixtures/plan_inputs/default/sample.bam",
    "min_reads": 100000,
    "projection_points": [
      1000000,
      2000000
    ]
  },
  "effective_params": {
    "min_reads": 100000,
    "projection_points": [
      1000000,
      2000000
    ]
  },
