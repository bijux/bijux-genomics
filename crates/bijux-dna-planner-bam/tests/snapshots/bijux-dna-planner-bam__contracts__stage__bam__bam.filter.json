{
  "stage_id": "bam.filter",
  "stage_version": 1,
  "tool_id": "bamtools",
  "tool_version": "1.0.0",
  "image": {
    "image": "bijux/test:latest",
    "digest": null
  },
  "command": {
    "template": [
      "/bin/sh",
      "-c",
      "samtools flagstat tests/fixtures/plan_inputs/default/sample.bam > out/flagstat.before.txt && samtools idxstats tests/fixtures/plan_inputs/default/sample.bam > out/idxstats.before.txt && bamtools stats -in tests/fixtures/plan_inputs/default/sample.bam >/dev/null && samtools view -b tests/fixtures/plan_inputs/default/sample.bam > out/filtered.bam && samtools index out/filtered.bam && samtools flagstat out/filtered.bam > out/flagstat.after.txt && samtools idxstats out/filtered.bam > out/idxstats.after.txt && python - <<'PY' > out/filter.summary.json\nimport json\nprint(json.dumps({\"filter_tool\": \"bamtools\"}, indent=2))\nPY"
    ]
  },
  "resources": {
