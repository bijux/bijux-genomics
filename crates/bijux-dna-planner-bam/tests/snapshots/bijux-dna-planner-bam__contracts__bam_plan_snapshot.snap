---
source: crates/bijux-dna-planner-bam/tests/contracts/plan/plan_snapshots.rs
expression: "bijux_dna_testkit::snapshot_normalize_json(&json)"
---
{
  "contract_version": {
    "major": 1,
    "minor": 0
  },
  "deterministic_scheduler": true,
  "edges": [],
  "pipeline_id": "bam-to-bam__adna_shotgun__v1",
  "planner_version": "bijux-dna-planner-bam.v1",
  "policy": "PreferAccuracy",
  "retry_policy": {
    "max_attempts": 1,
    "retry_on_exit_codes": []
  },
  "schema_version": "bijux.execution_graph.v1",
  "step_timeout_s": null,
  "steps": [
    {
      "aux_images": {},
      "command": {
        "template": [
          "/bin/sh",
          "-c",
          "bwa mem -t 1 -R '@RG\\tID:sample.rg1\\tSM:sample\\tPL:ILLUMINA\\tLB:lib1\\tPU:sample.pu1' tests/fixtures/plan_inputs/default/reference.fasta tests/fixtures/plan_inputs/default/reads_R1.fastq.gz tests/fixtures/plan_inputs/default/reads_R2.fastq.gz | samtools sort -o out/align.bam && samtools index out/align.bam && samtools flagstat out/align.bam > out/flagstat.txt && samtools idxstats out/align.bam > out/idxstats.txt && samtools stats out/align.bam > out/samtools_stats.txt && python - <<'PY' > out/align.metrics.json\nimport json\npayload={\"tool\":\"bwa_mem\",\"preset\":\"default\",\"sensitivity_profile\":\"default\",\"seed_length\":null,\"reference\":\"tests/fixtures/plan_inputs/default/reference.fasta\",\"bam\":\"out/align.bam\",\"read_group\":\"@RG\\tID:sample.rg1\\tSM:sample\\tPL:ILLUMINA\\tLB:lib1\\tPU:sample.pu1\"}\nprint(json.dumps(payload, indent=2))\nPY"
        ]
      },
      "expected_artifact_ids": [
        "align_bam",
        "align_bai",
        "flagstat",
        "idxstats",
        "stats",
        "align_metrics",
        "stage_metrics"
      ],
      "image": {
        "digest": "sha256:bwa",
        "image": "bijux/bwa"
      },
      "io": {
        "inputs": [
          {
            "name": "fastq_r1",
            "optional": false,
            "path": "tests/fixtures/plan_inputs/default/reads_R1.fastq.gz",
            "role": "reads"
          },
          {
            "name": "reference",
            "optional": false,
            "path": "tests/fixtures/plan_inputs/default/reference.fasta",
            "role": "reference"
          },
          {
            "name": "fastq_r2",
            "optional": false,
            "path": "tests/fixtures/plan_inputs/default/reads_R2.fastq.gz",
            "role": "reads"
          }
        ],
        "outputs": [
          {
            "name": "align_bam",
            "optional": false,
            "path": "out/align.bam",
            "role": "bam"
          },
          {
            "name": "align_bai",
            "optional": false,
            "path": "out/align.bam.bai",
            "role": "index"
          },
          {
            "name": "flagstat",
            "optional": false,
            "path": "out/flagstat.txt",
            "role": "report_json"
          },
          {
            "name": "idxstats",
            "optional": false,
            "path": "out/idxstats.txt",
            "role": "unknown"
          },
          {
            "name": "stats",
            "optional": false,
            "path": "out/samtools_stats.txt",
            "role": "unknown"
          },
          {
            "name": "align_metrics",
            "optional": false,
            "path": "out/align.metrics.json",
            "role": "metrics_json"
          },
          {
            "name": "stage_metrics",
            "optional": false,
            "path": "out/stage.metrics.json",
            "role": "metrics_json"
          }
        ]
      },
      "metrics_schema_ids": [
        "bam_metrics_v1"
      ],
      "out_dir": "out",
      "resources": {
        "mem_gb": 2,
        "runtime": "short",
        "threads": 2,
        "tmp_gb": 1
      },
      "stage_id": "bam.align",
      "step_id": "bam.align"
    }
  ]
