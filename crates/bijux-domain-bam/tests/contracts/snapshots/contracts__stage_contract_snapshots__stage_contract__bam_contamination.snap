{
  "audit_artifacts": [
    {
      "filename": "contamination.json",
      "name": "contamination_report"
    },
    {
      "filename": "contamination.summary.json",
      "name": "summary"
    },
    {
      "filename": "stage.metrics.json",
      "name": "stage_metrics"
    }
  ],
  "inputs": [
    "bam"
  ],
  "io": {
    "deterministic": true,
    "duplicate_policy": "no_duplicate_marking",
