---
source: crates/bijux-pipelines/tests/profiles.rs
expression: bam_default_profile()
---
{
  "id": "default",
  "description": "Default BAM pipeline",
  "domains": [
    "Bam"
  ],
  "graph": [
    {
      "stage_id": "bam.validate"
    },
    {
      "stage_id": "bam.qc_pre"
    },
    {
      "stage_id": "bam.filter"
    },
    {
      "stage_id": "bam.markdup"
    },
    {
      "stage_id": "bam.complexity"
    },
    {
      "stage_id": "bam.coverage"
    },
    {
      "stage_id": "bam.damage"
    },
    {
      "stage_id": "bam.authenticity"
    },
    {
      "stage_id": "bam.contamination"
    },
    {
      "stage_id": "bam.sex"
    },
    {
      "stage_id": "bam.bias_mitigation"
    },
    {
      "stage_id": "bam.recalibration"
    }
  ],
  "defaults": {
    "tools": {
      "bam.authenticity": "authenticity",
      "bam.bias_mitigation": "angsd",
      "bam.complexity": "preseq",
      "bam.contamination": "authenticct",
      "bam.coverage": "mosdepth",
      "bam.damage": "pydamage",
      "bam.filter": "samtools",
      "bam.markdup": "gatk",
      "bam.qc_pre": "samtools",
      "bam.recalibration": "gatk",
      "bam.sex": "rxy",
      "bam.validate": "samtools"
    },
    "params": {
      "bam.authenticity": {
        "mode": "aggregate"
      },
      "bam.bias_mitigation": {
        "gc_bias_correction": true,
        "map_bias_correction": false
      },
      "bam.complexity": {
        "min_reads": 100000,
        "projection_points": [
          1000000,
          2000000
        ]
      },
      "bam.contamination": {
        "assumptions": null,
        "prior": null,
        "reference_panels": [],
        "scope": "both",
        "sex_specific": false
      },
      "bam.coverage": {
        "depth_thresholds": [
          1,
          3,
          5
        ],
        "regions": null
      },
      "bam.damage": {
        "pmd_threshold_3p": 0.3,
        "pmd_threshold_5p": 0.3,
        "trim_3p": 2,
        "trim_5p": 2,
        "udg_model": "non_udg"
      },
      "bam.filter": {
        "base_quality_threshold": 20,
        "exclude_flags": [],
        "include_flags": [],
        "mapq_threshold": 30,
        "min_length": 30,
        "remove_duplicates": false
      },
      "bam.markdup": {
        "duplicate_action": "mark",
        "optical_duplicates": "mark_only",
        "umi_policy": "ignore"
      },
      "bam.qc_pre": {
        "regions": null
      },
      "bam.recalibration": {
        "known_sites": [],
        "mode": "standard",
        "skip_criteria": {
          "min_breadth_1x": 0.5,
          "min_mean_coverage": 2.0
        }
      },
      "bam.sex": {
        "expected_sex": null,
        "method": "rxy"
      },
      "bam.validate": {
        "strict": true
      }
    }
  },
  "invariants_preset": null,
  "capabilities": {
    "required_inputs": [
      "bam"
    ],
    "produces_outputs": [
      "bam",
      "bam.metrics"
    ],
    "supports_benchmarking": true
  }
}
