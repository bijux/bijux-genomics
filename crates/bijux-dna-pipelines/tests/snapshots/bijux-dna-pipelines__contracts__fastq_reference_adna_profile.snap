        "read_admission",
        "damage_aware_preprocessing",
        "qc_summary"
      ]
    },
    "failure_policy": [
      {
        "action": "skip_failed_sample",
        "allows_partial_batch": true,
        "downstream_effect": "sample fails quality admission and is skipped with explicit caveats",
        "stage_family": "preflight"
      },
      {
        "action": "skip_failed_sample",
        "allows_partial_batch": true,
        "downstream_effect": "sample preprocessing halts for failed samples while other batch members continue",
        "stage_family": "preprocessing"
      },
      {
        "action": "continue_cohort",
        "allows_partial_batch": true,
        "downstream_effect": "reporting continues and emits incomplete-sample caveats for any skipped sample",
        "stage_family": "reporting"
      }
