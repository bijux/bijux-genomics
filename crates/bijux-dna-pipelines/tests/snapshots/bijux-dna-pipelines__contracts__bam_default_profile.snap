---
source: crates/bijux-dna-pipelines/tests/contracts/profiles/profiles.rs
expression: "bijux_dna_testkit::snapshot_normalize_json(&json)"
---
{
  "capabilities": {
    "batch_semantics": {
      "cohort_stages": [],
      "per_sample_stages": [
        "bam.validate",
        "bam.qc_pre",
        "bam.mapping_summary",
        "bam.filter",
        "bam.duplication_metrics",
        "bam.coverage"
      ],
      "shared_reference_stages": []
    },
    "evidence_summary": {
      "final_caveat_topics": [
        "reference_identity_required",
        "duplicate_handling_limits"
      ],
      "story_order": [
        "bam_admission",
        "alignment_quality",
        "coverage_readiness",
        "qc_summary"
      ]
    },
    "failure_policy": [
      {
        "action": "skip_failed_sample",
        "allows_partial_batch": true,
        "downstream_effect": "samples that fail BAM integrity checks are skipped with explicit refusal evidence",
        "stage_family": "ingestion"
      },
      {
        "action": "skip_failed_sample",
        "allows_partial_batch": true,
        "downstream_effect": "failed preprocessing blocks downstream sample metrics while batch peers continue",
        "stage_family": "preprocessing"
      },
      {
        "action": "continue_cohort",
        "allows_partial_batch": true,
        "downstream_effect": "cohort summaries proceed with missing-sample caveats and retained refusal reasons",
        "stage_family": "reporting"
      }
    ],
    "input_artifacts": [
      "Bam"
    ],
    "input_domains": [
      "Bam"
    ],
    "output_artifacts": [
      "Bam",
      "MetricsBundle"
    ],
    "output_domains": [
      "Bam"
    ],
    "parameter_policy": {
      "configurable_by_stage": {
        "bam.coverage": [
          "depth_thresholds"
        ],
        "bam.filter": [
          "mapq_threshold",
          "min_length"
        ]
      },
      "expert_mode_required_for_locked_overrides": true,
      "locked_by_stage": {
        "bam.validate": [
          "strict"
        ]
      }
    },
    "produces_outputs": [
      "bam",
      "bam.metrics"
    ],
    "report_sections": [
      "bam"
    ],
    "required_artifacts": [
      "report.json",
      "run_manifest.json",
      "stage_summaries.json",
      "invariants_report.json"
    ],
    "required_inputs": [
      "bam"
    ],
    "required_metrics": [
      "bam.metrics"
    ],
    "required_metrics_bundles": [
      "BamCore"
    ],
    "required_report_sections": [
      "Bam",
      "PipelineDefaults"
    ],
    "required_stages": [
      "bam.validate",
      "bam.qc_pre",
      "bam.mapping_summary",
      "bam.filter",
      "bam.coverage",
      "bam.damage"
    ],
    "supports_benchmarks": true,
    "supports_sample_sheet": false,
    "workflow_template_ids": [
      "bam.modern_wgs_qc",
      "bam.low_pass_readiness",
      "bam.aligner_comparison_report",
      "bam.duplicate_method_comparison_report",
      "bam.batch_merge_workflow",
      "bam.coverage_review_report",
      "bam.large_file_performance_profile"
    ]
  },
  "defaults": {
    "params": {
      "bam.coverage": {
        "depth_thresholds": [
          1,
          3,
          5
        ],
        "regime_mode": "advisory_and_enforced",
        "regions": null
      },
      "bam.damage": {
        "damage_tool_profile": "ancient_dna_evidence",
        "evidence_only": true,
        "pmd_threshold_3p": 0.3,
        "pmd_threshold_5p": 0.3,
        "trim_3p": 2,
        "trim_5p": 2,
        "udg_model": "non_udg"
      },
      "bam.filter": {
        "base_quality_threshold": 20,
        "exclude_flags": [],
        "include_flags": [],
        "mapq_threshold": 30,
        "min_length": 30,
        "remove_duplicates": false
      },
      "bam.mapping_summary": {
        "regions": null
      },
      "bam.qc_pre": {
        "regions": null
      },
      "bam.validate": {
        "strict": true
      }
    },
    "rationales": {
      "bam.coverage": "pipeline default",
      "bam.damage": "pipeline default",
      "bam.filter": "pipeline default",
      "bam.mapping_summary": "pipeline default",
      "bam.qc_pre": "pipeline default",
      "bam.validate": "pipeline default"
    },
    "tools": {
      "bam.coverage": "mosdepth",
      "bam.damage": "mapdamage2",
      "bam.filter": "samtools",
      "bam.mapping_summary": "samtools",
      "bam.qc_pre": "samtools",
      "bam.validate": "samtools"
    }
  },
  "defaults_ledger_ref": "defaults_ledger.json",
  "description": "Default BAM pipeline",
  "id": "bam-to-bam__default__v1",
  "input_domains": [
    "Bam"
