        "expected_sex": null,
        "method": "rxy",
        "minimum_y_sites": 100,
        "refuse_without_context": true
      },
      "bam.validate": {
        "strict": true
      }
    },
    "rationales": {
      "bam.authenticity": "pipeline default",
      "bam.contamination": "pipeline default",
      "bam.coverage": "pipeline default",
