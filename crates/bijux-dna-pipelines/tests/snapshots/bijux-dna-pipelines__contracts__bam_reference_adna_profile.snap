---
source: crates/bijux-dna-pipelines/tests/contracts/profiles/profiles.rs
expression: "bijux_dna_testkit::snapshot_normalize_json(&json)"
---
{
  "capabilities": {
    "batch_semantics": {
      "cohort_stages": [],
      "per_sample_stages": [
        "bam.validate",
        "bam.contamination",
        "bam.authenticity",
        "bam.coverage"
      ],
      "shared_reference_stages": []
    },
    "evidence_summary": {
      "final_caveat_topics": [
        "coverage_floor_dependency",
        "panel_compatibility_dependency"
      ],
      "story_order": [
        "bam_admission",
        "contamination_prerequisites",
        "method_disagreement",
        "qc_summary"
      ]
    },
    "failure_policy": [
      {
        "action": "skip_failed_sample",
        "allows_partial_batch": true,
        "downstream_effect": "samples that fail BAM integrity checks are skipped with explicit refusal evidence",
        "stage_family": "ingestion"
      },
      {
        "action": "skip_failed_sample",
        "allows_partial_batch": true,
        "downstream_effect": "failed preprocessing blocks downstream sample metrics while batch peers continue",
        "stage_family": "preprocessing"
      },
      {
        "action": "continue_cohort",
        "allows_partial_batch": true,
        "downstream_effect": "cohort summaries proceed with missing-sample caveats and retained refusal reasons",
        "stage_family": "reporting"
      }
    ],
    "input_artifacts": [
      "Bam"
    ],
    "input_domains": [
      "Bam"
    ],
    "output_artifacts": [
      "Bam",
      "MetricsBundle"
    ],
    "output_domains": [
      "Bam"
    ],
    "parameter_policy": {
      "configurable_by_stage": {
        "bam.contamination": [
          "scope",
          "minimum_mean_coverage"
        ]
      },
      "expert_mode_required_for_locked_overrides": true,
      "locked_by_stage": {
        "bam.authenticity": [
          "disallow_certification"
        ]
      }
    },
    "produces_outputs": [
      "bam",
      "bam.metrics"
    ],
    "report_sections": [
      "bam"
    ],
    "required_artifacts": [
      "report.json",
      "run_manifest.json",
      "stage_summaries.json",
      "invariants_report.json"
    ],
    "required_inputs": [
      "bam"
    ],
    "required_metrics": [
      "bam.metrics"
    ],
    "required_metrics_bundles": [
      "BamAdna"
    ],
    "required_report_sections": [
      "Bam",
      "PipelineDefaults"
    ],
    "required_stages": [
      "bam.validate",
      "bam.mapping_summary",
      "bam.filter",
      "bam.mapq_filter",
      "bam.length_filter",
      "bam.duplication_metrics",
      "bam.coverage",
      "bam.endogenous_content",
      "bam.overlap_correction",
      "bam.damage",
      "bam.authenticity",
      "bam.contamination",
      "bam.sex"
    ],
    "supports_benchmarks": true,
    "supports_sample_sheet": false,
    "workflow_template_ids": [
      "bam.contamination_method_comparison_report"
    ]
  },
  "defaults": {
    "params": {
      "bam.authenticity": {
        "disallow_certification": true,
        "evidence_only": true,
        "mode": "aggregate"
      },
      "bam.contamination": {
        "assumptions": null,
        "chromosome_system": null,
        "emit_confidence_caveats": true,
        "minimum_mean_coverage": 0.5,
        "prior": null,
        "reference_panels": [],
        "required_reference_digest": null,
        "scope": "both",
        "sex_specific": false
      },
      "bam.coverage": {
        "depth_thresholds": [
          1,
          3,
          5
        ],
        "regime_mode": "advisory_and_enforced",
        "regions": null
      },
      "bam.damage": {
        "damage_tool_profile": "ancient_dna_evidence",
        "evidence_only": true,
        "pmd_threshold_3p": 0.3,
        "pmd_threshold_5p": 0.3,
        "trim_3p": 2,
        "trim_5p": 2,
        "udg_model": "non_udg"
      },
      "bam.duplication_metrics": {
        "duplicate_action": "mark",
        "optical_duplicates": "mark_only",
        "umi_policy": "ignore"
      },
      "bam.endogenous_content": {
        "depth_thresholds": [
          1
        ],
        "host_reference_digest": null,
        "host_reference_scope": "host_reference_required",
        "refuse_without_host_reference": true,
        "regions": null
      },
      "bam.filter": {
        "base_quality_threshold": 20,
        "exclude_flags": [],
        "include_flags": [],
        "mapq_threshold": 30,
        "min_length": 30,
        "remove_duplicates": false
      },
      "bam.length_filter": {
        "base_quality_threshold": 20,
        "exclude_flags": [],
        "include_flags": [],
        "mapq_threshold": 0,
