{
  "stage_id": "fastq.profile_overrepresented_sequences",
  "stage_instance_id": "fastq.profile_overrepresented_sequences.tool.fastqc",
  "stage_version": 1,
  "tool_id": "fastqc",
  "tool_version": "domain-manifest",
  "image": {
    "image": "bijuxdna/fastqc",
    "digest": null
  },
  "command": {
    "template": [
      "sh",
      "-lc",
      "mkdir -p 'out/fastqc_overrepresented'\n'fastqc' '--outdir' 'out/fastqc_overrepresented' '--threads' '4' 'reads_R1.fastq.gz' 'reads_R2.fastq.gz'"
    ]
  },
  "resources": {
    "runtime": "local",
    "mem_gb": 8,
    "tmp_gb": 4,
    "threads": 4
  },
  "io": {
    "inputs": [
      {
        "name": "reads_r1",
        "path": "reads_R1.fastq.gz",
        "role": "reads",
        "optional": false
      },
      {
        "name": "reads_r2",
        "path": "reads_R2.fastq.gz",
        "role": "reads",
        "optional": false
      }
    ],
    "outputs": [
      {
        "name": "overrepresented_sequences_tsv",
        "path": "out/overrepresented_sequences.tsv",
        "role": "summary_tsv",
        "optional": false
      },
      {
        "name": "overrepresented_sequences_json",
        "path": "out/overrepresented_sequences.json",
        "role": "metrics_json",
        "optional": false
      },
      {
        "name": "report_json",
        "path": "out/overrepresented_report.json",
        "role": "report_json",
        "optional": false
      }
    ]
  },
  "out_dir": "out",
  "params": {
    "input_r1": "reads_R1.fastq.gz",
    "input_r2": "reads_R2.fastq.gz",
    "output_json": "out/overrepresented_sequences.json",
    "output_tsv": "out/overrepresented_sequences.tsv",
    "report_json": "out/overrepresented_report.json",
    "threads": 4,
    "tool": "fastqc",
    "top_k": 50
  },
  "effective_params": {
    "paired_mode": "paired_end",
    "schema_version": "bijux.fastq.params.overrepresented_profile.v1",
    "threads": 4,
    "top_k": 50
  },
  "operating_mode": "enforced",
  "aux_images": {},
  "canonical_contract": null,
  "provenance": null,
  "reason": {
