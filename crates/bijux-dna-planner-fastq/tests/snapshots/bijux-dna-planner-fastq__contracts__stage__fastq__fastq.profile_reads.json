{
  "stage_id": "fastq.profile_reads",
  "stage_version": 1,
  "tool_id": "seqkit_stats",
  "tool_version": "domain-manifest",
  "image": {
    "image": "bijuxdna/seqkit_stats",
    "digest": null
  },
  "command": {
    "template": [
      "seqkit",
      "stats",
      "-a",
      "-T",
      "reads_R1.fastq.gz"
    ]
  },
  "resources": {
    "runtime": "local",
    "mem_gb": 2,
    "tmp_gb": 2,
    "threads": 2
  },
  "io": {
    "inputs": [
      {
        "name": "reads_r1",
        "path": "reads_R1.fastq.gz",
        "role": "reads",
        "optional": false
      }
    ],
    "outputs": [
      {
        "name": "qc_json",
        "path": "out/qc.json",
        "role": "metrics_json",
        "optional": false
      },
      {
        "name": "qc_tsv",
        "path": "out/qc.tsv",
        "role": "summary_tsv",
        "optional": false
      },
      {
        "name": "qc_plots_dir",
        "path": "out/plots",
        "role": "index",
        "optional": true
      }
    ]
  },
  "out_dir": "out",
  "params": {
    "input_r1": "reads_R1.fastq.gz",
    "input_r2": null,
    "out_dir": "out",
    "tool": "seqkit_stats"
  },
  "effective_params": {
    "paired_mode": "single_end",
    "q_cutoff": null,
    "threads": 2
  },
  "aux_images": {},
  "reason": {
    "kind": "default",
    "summary": "planner default",
    "details": {}
  }
}