  "image": {
    "image": "bijuxdna/fastp",
    "digest": null
  },
  "command": {
    "template": [
      "sh",
      "-lc",
      "set -euo pipefail\n'fastp' '--json' 'out/trim_polyg_tails_report.fastp.json' '--thread' '4' '--in1' 'reads_R1.fastq.gz' '--out1' 'out/R1.polyg.fastp.fastq.gz' '--trim_poly_g' '--poly_g_min_len' '10' '--in2' 'reads_R2.fastq.gz' '--out2' 'out/R2.polyg.fastp.fastq.gz'\nprintf '%s\\n' '{\"input_r1\":\"reads_R1.fastq.gz\",\"input_r2\":\"reads_R2.fastq.gz\",\"min_polyg_run\":10,\"output_r1\":\"out/R1.polyg.fastp.fastq.gz\",\"output_r2\":\"out/R2.polyg.fastp.fastq.gz\",\"raw_report_format\":\"fastp_json\",\"raw_report_path\":\"out/trim_polyg_tails_report.fastp.json\",\"schema_version\":\"bijux.fastq.trim_polyg_tails.report.v1\",\"stage_id\":\"fastq.trim_polyg_tails\",\"tool_id\":\"fastp\",\"trim_polyg\":true}' > 'out/trim_polyg_tails_report.json'\n"
    ]
  },
  "resources": {
    "runtime": "local",
    "mem_gb": 8,
    "tmp_gb": 4,
    "threads": 4
  },
  "io": {
    "inputs": [
      {
        "name": "reads_r1",
        "path": "reads_R1.fastq.gz",
        "role": "reads",
        "optional": false
      },
      {
        "name": "reads_r2",
        "path": "reads_R2.fastq.gz",
        "role": "reads",
        "optional": false
      }
    ],
    "outputs": [
