        "name": "trimmed_reads_r1",
        "path": "out/R1.polyg.fastp.fastq.gz",
        "role": "trimmed_reads",
        "optional": false
      },
      {
        "name": "trimmed_reads_r2",
        "path": "out/R2.polyg.fastp.fastq.gz",
        "role": "trimmed_reads",
        "optional": false
      },
      {
        "name": "report_json",
        "path": "out/trim_polyg_tails_report.json",
        "role": "report_json",
        "optional": false
      }
    ]
  },
  "out_dir": "out",
  "params": {
    "input_r1": "reads_R1.fastq.gz",
    "input_r2": "reads_R2.fastq.gz",
