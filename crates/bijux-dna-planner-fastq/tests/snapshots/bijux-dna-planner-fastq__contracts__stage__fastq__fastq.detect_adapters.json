{
  "stage_id": "fastq.detect_adapters",
  "stage_instance_id": "fastq.detect_adapters.tool.fastqc",
  "stage_version": 1,
  "tool_id": "fastqc",
  "tool_version": "domain-manifest",
  "image": {
    "image": "bijuxdna/fastqc",
    "digest": null
  },
  "command": {
    "template": [
      "sh",
      "-lc",
      "mkdir -p 'out/fastqc'\n'fastqc' '--outdir' 'out/fastqc' '--threads' '4' 'reads_R1.fastq.gz' 'reads_R2.fastq.gz'"
    ]
  },
  "resources": {
    "runtime": "local",
    "mem_gb": 8,
    "tmp_gb": 4,
    "threads": 4
  },
  "io": {
    "inputs": [
      {
        "name": "reads_r1",
        "path": "reads_R1.fastq.gz",
        "role": "reads",
        "optional": false
      },
      {
        "name": "reads_r2",
        "path": "reads_R2.fastq.gz",
        "role": "reads",
        "optional": false
      }
    ],
    "outputs": [
      {
        "name": "report_json",
        "path": "out/adapter_report.json",
        "role": "report_json",
        "optional": false
      },
      {
        "name": "adapter_report",
        "path": "out/adapter_report.json",
        "role": "report_json",
        "optional": false
      },
      {
        "name": "adapter_evidence_dir",
        "path": "out/fastqc",
        "role": "stage_report",
        "optional": true
      }
    ]
  },
  "out_dir": "out",
  "params": {
    "adapter_evidence_dir": "out/fastqc",
    "input_r1": "reads_R1.fastq.gz",
    "input_r2": "reads_R2.fastq.gz",
    "out_dir": "out",
    "report_json": "out/adapter_report.json",
    "sample_reads": null,
    "threads": 4,
    "tool": "fastqc"
  },
  "effective_params": {
    "evidence_artifact_id": "report_json",
    "evidence_engine": "fastqc",
    "evidence_format": "fastqc_summary",
    "evidence_scope": "full_input",
    "inspection_mode": "evidence_only",
    "paired_mode": "paired_end",
    "report_only": true,
    "sample_reads": null,
    "schema_version": "bijux.fastq.params.detect_adapters.v1",
    "threads": 4
  },
  "operating_mode": "enforced",
  "aux_images": {},
  "canonical_contract": null,
  "provenance": null,
