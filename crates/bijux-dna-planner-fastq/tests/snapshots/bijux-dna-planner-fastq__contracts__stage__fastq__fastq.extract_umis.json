{
  "stage_id": "fastq.extract_umis",
  "stage_instance_id": "fastq.extract_umis.tool.umi_tools",
  "stage_version": 1,
  "tool_id": "umi_tools",
  "tool_version": "domain-manifest",
  "image": {
    "image": "bijuxdna/umi_tools",
    "digest": null
  },
  "command": {
    "template": [
      "umi_tools",
      "extract",
      "--stdin",
      "reads_R1.fastq.gz",
      "--stdout",
      "out/umi_tools.r1.fastq.gz",
      "--read2-in",
      "reads_R2.fastq.gz",
      "--read2-out",
      "out/umi_tools.r2.fastq.gz",
      "--bc-pattern",
      "NNNNNNNN",
      "--log",
      "out/umi_tools.extract.log"
    ]
  },
  "resources": {
    "runtime": "local",
    "mem_gb": 4,
    "tmp_gb": 4,
    "threads": 2
  },
  "io": {
    "inputs": [
      {
        "name": "reads_r1",
        "path": "reads_R1.fastq.gz",
        "role": "reads",
        "optional": false
      },
      {
        "name": "reads_r2",
        "path": "reads_R2.fastq.gz",
        "role": "reads",
        "optional": false
      }
    ],
    "outputs": [
      {
        "name": "umi_reads_r1",
        "path": "out/umi_tools.r1.fastq.gz",
        "role": "reads",
        "optional": false
      },
      {
        "name": "umi_reads_r2",
        "path": "out/umi_tools.r2.fastq.gz",
        "role": "reads",
        "optional": false
      },
      {
        "name": "report_json",
        "path": "out/umi_report.json",
        "role": "report_json",
        "optional": false
      }
    ]
  },
  "out_dir": "out",
  "params": {
    "out_dir": "out",
    "output_r1": "out/umi_tools.r1.fastq.gz",
    "output_r2": "out/umi_tools.r2.fastq.gz",
    "r1": "reads_R1.fastq.gz",
    "r2": "reads_R2.fastq.gz",
    "raw_backend_report": "out/umi_tools.extract.log",
    "raw_backend_report_format": "umi_tools_log",
    "report_json": "out/umi_report.json",
    "tool": "umi_tools",
    "umi_pattern": "NNNNNNNN"
  },
  "effective_params": {
    "paired_mode": "paired_end",
    "schema_version": "bijux.fastq.params.umi.v1",
    "threads": 2,
    "umi_pattern": "NNNNNNNN"
  },
  "aux_images": {},
  "reason": {
    "kind": "default",
    "summary": "planner default",
    "details": {}
  }
}