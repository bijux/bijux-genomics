{
  "stage_id": "fastq.deplete_reference_contaminants",
  "stage_version": 1,
  "tool_id": "bowtie2",
  "tool_version": "domain-manifest",
  "image": {
    "image": "bijuxdna/bowtie2",
    "digest": null
  },
  "command": {
    "template": [
      "bowtie2",
      "-x",
      "contaminant_reference_index",
      "--threads",
      "1",
      "-S",
      "/dev/null",
      "-1",
      "reads_R1.fastq.gz",
      "-2",
      "reads_R2.fastq.gz",
      "--un-conc-gz",
      "out/contaminant_screened_R%.fastq.gz",
      "--met-file",
      "out/contaminant_screen_report.json"
    ]
  },
  "resources": {
    "runtime": "local",
    "mem_gb": 1,
    "tmp_gb": 1,
    "threads": 1
  },
  "io": {
    "inputs": [
      {
        "name": "reads_r1",
        "path": "reads_R1.fastq.gz",
        "role": "reads",
        "optional": false
      },
      {
        "name": "reference_index",
        "path": "contaminant_reference_index",
        "role": "index",
        "optional": false
      },
      {
        "name": "reads_r2",
        "path": "reads_R2.fastq.gz",
        "role": "reads",
        "optional": false
      }
    ],
    "outputs": [
      {
        "name": "contaminant_screened_reads_r1",
        "path": "out/contaminant_screened_R1.fastq.gz",
        "role": "reads",
        "optional": false
      },
      {
        "name": "contaminant_screened_reads_r2",
        "path": "out/contaminant_screened_R2.fastq.gz",
        "role": "reads",
        "optional": false
      },
      {
        "name": "contaminant_screen_report_json",
        "path": "out/contaminant_screen_report.json",
        "role": "report_json",
        "optional": false
      }
    ]
  },
  "out_dir": "out",
  "params": {
    "input_r1": "reads_R1.fastq.gz",
    "input_r2": "reads_R2.fastq.gz",
    "output_r1": "out/contaminant_screened_R1.fastq.gz",
    "output_r2": "out/contaminant_screened_R2.fastq.gz",
    "reference_index": "contaminant_reference_index",
    "report_json": "out/contaminant_screen_report.json",
    "tool": "bowtie2"
  },
  "effective_params": {
    "contaminant_reference": "contaminant_reference",
    "index_artifact": "reference_index",
    "paired_mode": "paired_end",
    "retain_unmapped_pairs": true,
    "schema_version": "bijux.fastq.params.deplete_reference_contaminants.v1",
    "threads": 1
  },
  "aux_images": {},
  "reason": {
    "kind": "default",
    "summary": "planner default",
    "details": {}
  }
}