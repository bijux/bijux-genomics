{
  "stage_id": "fastq.deplete_host",
  "stage_instance_id": "fastq.deplete_host.tool.bowtie2",
  "stage_version": 1,
  "tool_id": "bowtie2",
  "tool_version": "domain-manifest",
  "image": {
    "image": "bijuxdna/bowtie2",
    "digest": null
  },
  "command": {
    "template": [
      "bowtie2",
      "-x",
      "host_reference_index",
      "--threads",
      "1",
      "-S",
      "/dev/null",
      "-1",
      "reads_R1.fastq.gz",
      "-2",
      "reads_R2.fastq.gz",
      "--un-conc-gz",
      "out/host_depleted_R%.fastq.gz",
      "--al-conc-gz",
      "out/removed_host_R%.fastq.gz",
      "--met-file",
      "out/bowtie2.host.metrics.txt"
    ]
  },
  "resources": {
    "runtime": "local",
    "mem_gb": 1,
    "tmp_gb": 1,
    "threads": 1
  },
  "io": {
    "inputs": [
      {
        "name": "reads_r1",
        "path": "reads_R1.fastq.gz",
        "role": "reads",
        "optional": false
      },
      {
        "name": "reference_index",
        "path": "host_reference_index",
        "role": "index",
        "optional": false
      },
      {
        "name": "reads_r2",
        "path": "reads_R2.fastq.gz",
        "role": "reads",
        "optional": false
      }
    ],
    "outputs": [
      {
        "name": "host_depleted_reads_r1",
        "path": "out/host_depleted_R1.fastq.gz",
        "role": "reads",
        "optional": false
      },
      {
        "name": "host_depleted_reads_r2",
        "path": "out/host_depleted_R2.fastq.gz",
        "role": "reads",
        "optional": false
      },
      {
        "name": "removed_host_reads_r1",
        "path": "out/removed_host_R1.fastq.gz",
        "role": "reads",
        "optional": false
      },
      {
        "name": "removed_host_reads_r2",
        "path": "out/removed_host_R2.fastq.gz",
        "role": "reads",
        "optional": true
      },
      {
        "name": "host_depletion_report_json",
        "path": "out/host_depletion_report.json",
        "role": "report_json",
        "optional": false
      }
    ]
  },
  "out_dir": "out",
  "params": {
    "host_identity_threshold": 0.95,
    "input_r1": "reads_R1.fastq.gz",
    "input_r2": "reads_R2.fastq.gz",
    "output_r1": "out/host_depleted_R1.fastq.gz",
    "output_r2": "out/host_depleted_R2.fastq.gz",
    "raw_backend_report": "out/bowtie2.host.metrics.txt",
    "raw_backend_report_format": "bowtie2_met_file",
    "reference_index": "host_reference_index",
    "reference_index_backend": "bowtie2_build",
    "removed_host_r1": "out/removed_host_R1.fastq.gz",
    "removed_host_r2": "out/removed_host_R2.fastq.gz",
    "report_json": "out/host_depletion_report.json",
    "retain_unmapped_only": true,
    "threads": 1,
    "tool": "bowtie2"
  },
  "effective_params": {
    "decoy_catalog_id": null,
    "decoy_policy": "none",
    "emit_removed_reads": true,
    "identity_threshold": 0.95,
    "masking_policy": "unmasked",
    "paired_mode": "paired_end",
    "reference_build_id": null,
    "reference_catalog_id": "host_reference",
    "reference_digest": null,
    "reference_index_artifact_id": "reference_index",
    "reference_index_backend": "bowtie2_build",
    "reference_scope": "host",
    "report_format": "bowtie2_metrics_file",
    "retain_unmapped_pairs": true,
    "retained_read_policy": "keep_non_host_reads",
    "schema_version": "bijux.fastq.params.deplete_host.v1",
    "threads": 1
  },
  "operating_mode": "enforced",
  "aux_images": {},
  "canonical_contract": null,
  "provenance": null,
  "reason": {
    "kind": "default",
    "summary": "planner default",
    "details": {}
  }
}