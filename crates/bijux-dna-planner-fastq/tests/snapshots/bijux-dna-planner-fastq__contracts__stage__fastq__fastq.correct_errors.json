{
  "stage_id": "fastq.correct_errors",
  "stage_version": 1,
  "tool_id": "rcorrector",
  "tool_version": "domain-manifest",
  "image": {
    "image": "bijuxdna/rcorrector",
    "digest": null
  },
  "command": {
    "template": [
      "rcorrector",
      "-1",
      "{{reads_r1}}",
      "-2",
      "{{reads_r2}}"
    ]
  },
  "resources": {
    "runtime": "local",
    "mem_gb": 8,
    "tmp_gb": 4,
    "threads": 4
  },
  "io": {
    "inputs": [
      {
        "name": "reads_r1",
        "path": "reads_R1.fastq.gz",
        "role": "reads",
        "optional": false
      },
      {
        "name": "reads_r2",
        "path": "reads_R2.fastq.gz",
        "role": "reads",
        "optional": false
      }
    ],
    "outputs": [
      {
        "name": "corrected_reads_r1",
        "path": "out/reads_r1.fastq.gz",
        "role": "reads",
        "optional": false
      },
      {
        "name": "corrected_reads_r2",
        "path": "out/reads_r2.fastq.gz",
        "role": "reads",
        "optional": false
      }
    ]
  },
  "out_dir": "out",
  "params": {
    "out_dir": "out",
    "output_r1": "out/reads_r1.fastq.gz",
    "output_r2": "out/reads_r2.fastq.gz",
    "r1": "reads_R1.fastq.gz",
    "r2": "reads_R2.fastq.gz",
    "tool": "rcorrector"
  },
  "effective_params": {
    "kmer_size": null,
    "paired_mode": "paired_end",
    "schema_version": "bijux.fastq.params.correct.v1",
    "threads": 4
  },
  "aux_images": {},
  "reason": {
    "kind": "default",
    "summary": "planner default",
    "details": {}
  }
}