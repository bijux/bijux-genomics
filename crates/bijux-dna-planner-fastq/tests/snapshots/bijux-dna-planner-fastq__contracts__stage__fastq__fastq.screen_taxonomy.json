{
  "stage_id": "fastq.screen_taxonomy",
  "stage_instance_id": "fastq.screen_taxonomy.tool.kraken2",
  "stage_version": 1,
  "tool_id": "kraken2",
  "tool_version": "domain-manifest",
  "image": {
    "image": "bijuxdna/kraken2",
    "digest": null
  },
  "command": {
    "template": [
      "kraken2",
      "--report",
      "{{screen_report_tsv}}",
      "{{reads_r1}}"
    ]
  },
  "resources": {
    "runtime": "local",
    "mem_gb": 16,
    "tmp_gb": 8,
    "threads": 4
  },
  "io": {
    "inputs": [
      {
        "name": "reads_r1",
        "path": "reads_R1.fastq.gz",
        "role": "reads",
        "optional": false
      },
      {
        "name": "reads_r2",
        "path": "reads_R2.fastq.gz",
        "role": "reads",
        "optional": false
      }
    ],
    "outputs": [
      {
        "name": "screen_report_tsv",
        "path": "out/kraken2.report.tsv",
        "role": "summary_tsv",
        "optional": false
      },
      {
        "name": "classification_report_json",
        "path": "out/kraken2.classifications.json",
        "role": "metrics_json",
        "optional": false
      }
    ]
  },
  "out_dir": "out",
  "params": {
    "assignments": "out/kraken2.classifications.json",
    "input_r1": "reads_R1.fastq.gz",
    "input_r2": "reads_R2.fastq.gz",
    "out_dir": "out",
    "report": "out/kraken2.report.tsv",
    "tool": "kraken2"
  },
  "effective_params": {
    "assignment_format": "kraken_assignments",
    "classifier": "kraken2",
    "contaminant_db": null,
    "database_artifact_id": "taxonomy_db",
    "database_build_id": null,
    "database_scope": "read_screening",
    "emit_unclassified": true,
    "minimum_confidence": null,
    "paired_mode": "paired_end",
    "report_format": "kraken_report",
    "schema_version": "bijux.fastq.params.screen_taxonomy.v1",
    "threads": 4
  },
  "aux_images": {},
  "reason": {
    "kind": "default",
    "summary": "planner default",
    "details": {}
  }
}