{
  "stage_id": "fastq.validate_reads",
  "stage_version": 1,
  "tool_id": "fastqvalidator",
  "tool_version": "domain-manifest",
  "image": {
    "image": "bijuxdna/fastqvalidator",
    "digest": null
  },
  "command": {
    "template": [
      "fastqvalidator",
      "--file",
      "{{reads}}"
    ]
  },
  "resources": {
    "runtime": "local",
    "mem_gb": 8,
    "tmp_gb": 4,
    "threads": 4
  },
  "io": {
    "inputs": [
      {
        "name": "reads_r1",
        "path": "reads_R1.fastq.gz",
        "role": "reads",
        "optional": false
      }
    ],
    "outputs": [
      {
        "name": "validation_report",
        "path": "out/validation.json",
        "role": "report_json",
        "optional": false
      }
    ]
  },
  "out_dir": "out",
  "params": {
    "input_r1": "reads_R1.fastq.gz",
    "input_r2": null,
    "out_dir": "out",
    "tool": "fastqvalidator"
  },
  "effective_params": {
    "paired_mode": "single_end",
    "q_cutoff": null,
    "threads": 4
  },
  "aux_images": {},
  "reason": {
    "kind": "default",
    "summary": "planner default",
    "details": {}
  }
}