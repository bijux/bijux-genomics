      "reads_R1.fastq.gz",
      "reads_R2.fastq.gz"
    ]
  },
  "resources": {
    "runtime": "local",
    "mem_gb": 2,
    "tmp_gb": 2,
    "threads": 2
  },
  "io": {
    "inputs": [
      {
        "name": "reads_r1",
        "path": "reads_R1.fastq.gz",
        "role": "reads",
