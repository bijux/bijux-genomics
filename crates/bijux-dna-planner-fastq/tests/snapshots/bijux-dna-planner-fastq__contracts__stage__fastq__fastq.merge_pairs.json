{
  "stage_id": "fastq.merge_pairs",
  "stage_version": 1,
  "tool_id": "pear",
  "tool_version": "1.0.0",
  "image": {
    "image": "bijux/test:latest",
    "digest": null
  },
  "command": {
    "template": [
      "pear",
      "-f",
      "reads_R1.fastq.gz",
      "-r",
      "reads_R2.fastq.gz",
      "-o",
      "out/pear"
    ]
  },
  "resources": {
    "runtime": "docker",
    "mem_gb": 1,
    "tmp_gb": 1,
    "threads": 1
  },
  "io": {
    "inputs": [
      {
        "name": "reads_r1",
        "path": "reads_R1.fastq.gz",
        "role": "reads",
        "optional": false
      },
      {
        "name": "reads_r2",
        "path": "reads_R2.fastq.gz",
        "role": "reads",
        "optional": false
      }
    ],
    "outputs": [
      {
        "name": "merged_reads",
        "path": "out/pear.assembled.fastq",
        "role": "reads",
        "optional": false
      },
      {
        "name": "unmerged_reads_r1",
        "path": "out/pear.unassembled.forward.fastq",
        "role": "reads",
        "optional": true
      },
      {
        "name": "unmerged_reads_r2",
        "path": "out/pear.unassembled.reverse.fastq",
        "role": "reads",
        "optional": true
      },
      {
        "name": "report_json",
        "path": "out/merge_report.json",
        "role": "metrics_json",
        "optional": false
      }
    ]
  },
  "out_dir": "out",
  "params": {
    "merged_reads": "out/pear.assembled.fastq",
    "r1": "reads_R1.fastq.gz",
    "r2": "reads_R2.fastq.gz",
    "report_json": "out/merge_report.json",
    "tool": "pear",
    "unmerged_reads_r1": "out/pear.unassembled.forward.fastq",
    "unmerged_reads_r2": "out/pear.unassembled.reverse.fastq"
  },
  "effective_params": {
    "merge_overlap": null,
    "min_len": null,
    "paired_mode": "paired_end",
    "threads": 1
  },
  "aux_images": {},
  "reason": {
    "kind": "default",
    "summary": "planner default",
    "details": {}
  }
}