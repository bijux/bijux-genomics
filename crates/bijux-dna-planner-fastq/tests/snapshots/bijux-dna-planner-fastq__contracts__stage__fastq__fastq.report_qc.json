{
  "stage_id": "fastq.report_qc",
  "stage_instance_id": "fastq.report_qc.tool.multiqc",
  "stage_version": 1,
  "tool_id": "multiqc",
  "tool_version": "domain-manifest",
  "image": {
    "image": "bijuxdna/multiqc",
    "digest": null
  },
  "command": {
    "template": [
      "multiqc",
      "-o",
      "out/multiqc_data",
      "-n",
      "multiqc_report.html",
      "out/detect_adapters/fastqc/adapter_report.json",
      "out/detect_adapters/fastqc/fastqc",
      "out/profile_reads/seqkit_stats/qc.json"
    ]
  },
  "resources": {
    "runtime": "local",
    "mem_gb": 4,
    "tmp_gb": 4,
    "threads": 2
  },
  "io": {
    "inputs": [
      {
        "name": "fastq.detect_adapters.tool.fastqc.adapter_report",
        "path": "out/detect_adapters/fastqc/adapter_report.json",
        "role": "report_json",
        "optional": false
      },
      {
        "name": "fastq.detect_adapters.tool.fastqc.adapter_evidence_dir",
        "path": "out/detect_adapters/fastqc/fastqc",
        "role": "stage_report",
        "optional": true
      },
      {
        "name": "fastq.profile_reads.tool.seqkit_stats.qc_json",
        "path": "out/profile_reads/seqkit_stats/qc.json",
        "role": "metrics_json",
        "optional": false
      }
    ],
    "outputs": [
      {
        "name": "multiqc_report",
        "path": "out/multiqc_report.html",
        "role": "report_html",
        "optional": false
      },
      {
        "name": "multiqc_data",
        "path": "out/multiqc_data",
        "role": "index",
        "optional": false
      }
    ]
  },
  "out_dir": "out",
  "params": {
    "out_dir": "out",
    "qc_input_count": 3,
    "qc_input_paths": [
      "out/detect_adapters/fastqc/adapter_report.json",
      "out/detect_adapters/fastqc/fastqc",
      "out/profile_reads/seqkit_stats/qc.json"
    ],
    "raw_r1": "reads_R1.fastq.gz",
    "raw_r2": "reads_R2.fastq.gz",
    "tool": "multiqc"
  },
  "effective_params": {
    "aggregation_engine": "multiqc",
    "aggregation_scope": "governed_qc_artifacts",
    "paired_mode": "paired_end",
    "schema_version": "bijux.fastq.params.report_qc.v1",
    "threads": 2
  },
  "aux_images": {},
  "reason": {
    "kind": "default",
    "summary": "planner default",
    "details": {}
  }
}