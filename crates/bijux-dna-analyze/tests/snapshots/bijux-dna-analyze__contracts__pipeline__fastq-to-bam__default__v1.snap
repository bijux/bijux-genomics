        "params": {
          "bam.align": {
            "aligner": "bwa",
            "build_indices": false,
            "emit_stats": true,
            "mode": "end_to_end",
            "preset": "default",
            "read_group": {
              "id": "sample.rg1",
              "lane_id": "L001",
              "library": "lib1",
              "platform": "ILLUMINA",
              "platform_unit": "sample.pu1",
              "run_id": null,
              "sample": "sample"
            },
            "reference": "reference.fasta",
            "reference_digest": "unknown",
            "rg_policy": "regenerate",
            "seed_length": null,
            "sensitivity_profile": "default",
            "strategy_id": "bwa_mem_default",
            "threads": 1
          },
          "bam.coverage": {
            "depth_thresholds": [
              1,
              3,
              5
            ],
            "regime_mode": "advisory_and_enforced",
            "regions": null
          },
          "bam.damage": {
            "damage_tool_profile": "ancient_dna_evidence",
            "evidence_only": true,
            "pmd_threshold_3p": 0.3,
            "pmd_threshold_5p": 0.3,
            "trim_3p": 2,
            "trim_5p": 2,
            "udg_model": "non_udg"
          },
          "bam.filter": {
            "base_quality_threshold": 20,
            "exclude_flags": [],
            "include_flags": [],
            "mapq_threshold": 30,
            "min_length": 30,
            "remove_duplicates": false
          },
          "bam.mapping_summary": {
            "regions": null
          },
          "bam.qc_pre": {
            "regions": null
          },
          "bam.validate": {
            "strict": true
          },
          "core.prepare_reference": {},
          "fastq.cluster_otus": {
            "identity_threshold": 0.97,
            "output_table_kind": "otu_table",
            "raw_backend_report_artifact": "cluster_otus_report.json",
            "raw_backend_report_format": "vsearch_json",
            "report_artifact": "report_json",
            "schema_version": "v1",
            "threads": 1
          },
          "fastq.correct_errors": {
            "conservative_mode": false,
            "correction_engine": "rcorrector",
            "genome_size": null,
            "kmer_size": null,
            "max_memory_gb": null,
            "musket_kmer_budget": null,
            "paired_mode": "single_end",
            "quality_encoding": "phred33",
            "schema_version": "bijux.fastq.params.correct.v1",
            "threads": 1,
            "trusted_kmer_artifact": null
          },
          "fastq.deplete_host": {
            "decoy_catalog_id": null,
            "decoy_policy": "none",
            "emit_removed_reads": false,
            "identity_threshold": 0.95,
            "masking_policy": "unmasked",
            "paired_mode": "single_end",
            "reference_build_id": null,
            "reference_catalog_id": "host_reference",
            "reference_digest": null,
            "reference_index_artifact_id": "host_reference_index",
            "reference_index_backend": "bowtie2",
            "reference_scope": "host",
            "report_format": "bowtie2_metrics_file",
            "retain_unmapped_pairs": true,
            "retained_read_policy": "keep_non_host_reads",
            "schema_version": "bijux.fastq.params.deplete_host.v1",
            "threads": 1
          },
          "fastq.deplete_reference_contaminants": {
            "contaminant_reference": "contaminants.fasta",
            "index_artifact": "contaminants_index",
            "paired_mode": "single_end",
            "reference_build_id": null,
            "reference_catalog_id": "reference_contaminants",
            "reference_digest": null,
            "reference_index_backend": "bowtie2",
            "retain_unmapped_pairs": true,
            "schema_version": "bijux.fastq.params.deplete_reference_contaminants.v1",
            "threads": 1
          },
          "fastq.deplete_rrna": {
            "contaminant_db": "rrna_reference",
            "database_artifact_id": "rrna_db",
            "database_build_id": null,
            "emit_removed_reads": false,
            "paired_mode": "single_end",
            "report_format": "summary_tsv_and_json",
            "schema_version": "bijux.fastq.params.deplete_rrna.v1",
            "screening_engine": "sortmerna",
            "threads": 1
          },
          "fastq.detect_adapters": {
            "evidence_artifact_id": "report_json",
            "evidence_engine": "fastqc",
            "evidence_format": "fastqc_summary",
            "evidence_scope": "full_input",
            "inspection_mode": "evidence_only",
            "paired_mode": "single_end",
            "report_only": true,
            "sample_reads": null,
            "schema_version": "bijux.fastq.params.detect_adapters.v1",
            "threads": 1
          },
          "fastq.extract_umis": {
            "downstream_dedup_policy": "sequence_identity_recommended",
            "downstream_propagation": "header_and_report",
            "extraction_location": "read1_prefix",
            "failed_extraction_policy": "refuse_stage",
            "grouping_policy": "pair_aware",
            "paired_mode": "single_end",
            "read_name_transform": "append_to_header",
            "schema_version": "bijux.fastq.params.umi.v1",
            "threads": 1,
            "umi_pattern": null
          },
          "fastq.filter_reads": {
            "contaminant_db": null,
            "entropy_threshold": null,
            "low_complexity_threshold": null,
            "max_n": null,
            "max_n_count": null,
            "max_n_fraction": null,
            "n_policy": null,
            "paired_mode": "single_end",
            "polyx_policy": null,
            "threads": 1
          },
          "fastq.infer_asvs": {
            "chimera_policy": "report_only",
            "denoising_method": "dada2",
            "output_table_kind": "feature_table",
            "paired_mode": "single_end",
            "pooling_mode": "independent",
            "raw_backend_report_artifact": "infer_asvs_report.json",
            "raw_backend_report_format": "dada2_json",
            "report_artifact": "report_json",
            "requires_r_runtime": true,
            "schema_version": "v1",
            "threads": 1
          },
          "fastq.merge_pairs": {
            "merge_engine": "pear",
            "merge_overlap": null,
            "min_len": null,
            "paired_mode": "single_end",
            "schema_version": "bijux.fastq.params.merge_pairs.v1",
            "threads": 6,
            "unmerged_read_policy": "emit_unmerged_pairs"
          },
          "fastq.normalize_abundance": {
            "compositional_rule": "sum_to_one",
            "expected_columns": [
              "feature_id",
              "count"
            ],
            "input_value_column": "count",
            "method": "relative_abundance",
            "normalized_value_column": "relative_abundance",
            "report_artifact": "report_json",
            "scale_factor": 1.0,
            "schema_version": "v1"
          },
          "fastq.normalize_primers": {
            "allow_iupac_codes": true,
            "marker_id": null,
            "max_mismatch_rate": 0.1,
            "min_overlap_bp": 18,
            "orientation_policy": "forward_reverse",
            "paired_mode": "single_end",
            "primer_fasta": "assets/reference/primers/COI.fasta",
            "primer_set_id": "metabarcoding_default",
            "schema_version": "v1",
            "strict_5p_anchor": true,
            "threads": 1
          },
          "fastq.profile_overrepresented_sequences": {
            "paired_mode": "single_end",
            "schema_version": "bijux.fastq.params.overrepresented_profile.v1",
            "threads": 2,
            "top_k": 50
          },
          "fastq.profile_read_lengths": {
            "histogram_bins": 100,
            "paired_mode": "single_end",
            "schema_version": "bijux.fastq.params.read_length_profile.v1",
            "threads": 2
          },
          "fastq.profile_reads": {
            "paired_mode": "single_end",
            "schema_version": "bijux.fastq.params.stats.v1",
            "threads": 2
          },
