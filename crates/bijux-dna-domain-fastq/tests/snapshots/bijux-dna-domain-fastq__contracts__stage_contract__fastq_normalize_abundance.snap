---
source: crates/bijux-dna-domain-fastq/tests/contracts/stage_contract_snapshots.rs
expression: "bijux_dna_testkit::snapshot_normalize_json(&json)"
---
{
  "inputs": {
    "accepted_kinds": [
      "AmpliconTable"
    ],
    "kind": "SingleEnd"
  },
  "metrics": {
    "classes": [
      "Composition"
    ],
    "invariants": [
      "table_rows >= 0",
      "sample_count >= 0",
      "zero_fraction in [0, 1]"
    ],
    "notes": "Abundance normalization operates on a feature table and emits a normalized compositional table."
  },
  "outputs": {
    "emits_fastq": false,
    "kind": "AmpliconTable",
    "possible_kinds": [
      "AmpliconTable"
    ]
  },
  "retention": {
    "definition": "non-empty table rows and stable sample identifiers",
    "may_drop": [],
    "may_drop_reads": false,
    "must_preserve_pairing": false,
    "preserves": [
      "sample_ids",
      "abundance_units"
    ],
    "units": "rows,samples"
  },
  "schema_version": "bijux.stage_contract.v1",
  "stage_id": "fastq.normalize_abundance",
  "tool_ids": [
    "seqfu",
    "seqkit"
  ]
}
