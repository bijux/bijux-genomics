---
source: crates/bijux-dna-domain-fastq/tests/contracts/stage_contract_snapshots.rs
expression: "bijux_dna_testkit::snapshot_normalize_json(&json)"
---
{
  "amplicon_semantics": {
    "orientation_policy": "normalize_to_primer_forward_orientation",
    "primer_assumptions": [
      "primer_set_declared",
      "primer_match_confidence>=0.9"
    ]
  },
  "inputs": {
    "accepted_kinds": [
      "SingleEnd",
      "PairedEnd"
    ],
    "kind": "SingleEnd"
  },
  "metrics": {
    "classes": [
      "Integrity",
      "Retention"
    ],
    "invariants": [
      "reads_out <= reads_in",
      "primer_trimmed_fraction in [0, 1]",
      "orientation_forward_fraction in [0, 1]"
    ],
    "notes": "Primer normalization re-orients amplicon reads and may trim primer bases while preserving deterministic ordering."
  },
  "outputs": {
    "emits_fastq": true,
    "kind": "SingleEnd",
    "possible_kinds": [
      "SingleEnd",
      "PairedEnd"
    ]
  },
  "retention": {
    "definition": "reads_out / reads_in; bases_out / bases_in",
    "may_drop": [
      "reads",
      "bases"
    ],
    "may_drop_reads": true,
    "must_preserve_pairing": true,
    "preserves": [
      "read_order",
      "pairing_metadata"
    ],
    "units": "reads,bases"
  },
  "schema_version": "bijux.stage_contract.v1",
  "stage_id": "fastq.normalize_primers",
  "tool_ids": [
    "cutadapt",
    "seqkit"
  ]
}
