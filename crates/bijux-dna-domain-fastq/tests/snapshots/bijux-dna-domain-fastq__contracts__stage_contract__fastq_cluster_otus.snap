---
source: crates/bijux-dna-domain-fastq/tests/contracts/stage_contract_snapshots.rs
expression: "bijux_dna_testkit::snapshot_normalize_json(&json)"
---
{
  "amplicon_semantics": {
    "decision_semantics": "legal in amplicon mode when ASV path disabled; outputs clustered centroids and a canonical governed clustering report"
  },
  "inputs": {
    "accepted_kinds": [
      "SingleEnd",
      "PairedEnd",
      "Merged"
    ],
    "kind": "SingleEnd"
  },
  "metrics": {
    "classes": [
      "Integrity",
      "Composition"
    ],
    "invariants": [
      "reads_in >= 0",
      "otu_count >= 0",
      "representative_count >= 0"
    ],
    "notes": "OTU clustering emits deterministic centroid and abundance artifacts for amplicon workflows."
  },
  "outputs": {
    "emits_fastq": false,
    "kind": "AmpliconTable",
    "possible_kinds": [
      "AmpliconTable",
      "RepresentativeFasta"
    ]
  },
  "retention": {
    "definition": "non-empty table rows and stable sample identifiers",
    "may_drop": [],
    "may_drop_reads": false,
    "must_preserve_pairing": false,
    "preserves": [
      "sample_ids",
      "abundance_units"
    ],
    "units": "rows,samples"
  },
  "schema_version": "bijux.stage_contract.v1",
  "stage_id": "fastq.cluster_otus",
  "tool_ids": [
    "vsearch"
  ]
}
