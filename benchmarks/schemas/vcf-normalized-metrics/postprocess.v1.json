{
  "$id": "bijux.schemas.bench.vcf-normalized-metrics.postprocess.v1",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "allOf": [
    {
      "$ref": "../vcf-normalized-metrics.v1.json#/$defs/base"
    },
    {
      "additionalProperties": true,
      "properties": {
        "contigs_consistent_with_species_context": {
          "type": "boolean"
        },
        "filter_standardized_to_pass": {
          "minimum": 0,
          "type": "integer"
        },
        "indels_normalized": {
          "minimum": 0,
          "type": "integer"
        },
        "invalid_records_removed": {
          "minimum": 0,
          "type": "integer"
        },
        "left_align_applied": {
          "type": "boolean"
        },
        "multiallelic_records_split": {
          "minimum": 0,
          "type": "integer"
        },
        "readable_vcf": {
          "type": "boolean"
        },
        "schema_version": {
          "const": "bijux.vcf.postprocess.v1"
        },
        "stage_id": {
          "const": "vcf.postprocess"
        },
        "tabix_present": {
          "type": "boolean"
        },
        "tool_id": {
          "type": "string"
        },
        "variant_ids_normalized": {
          "minimum": 0,
          "type": "integer"
        }
      },
      "required": [
        "schema_version",
        "stage_id",
        "tool_id",
        "readable_vcf",
        "tabix_present",
        "contigs_consistent_with_species_context",
        "left_align_applied",
        "multiallelic_records_split",
        "indels_normalized",
        "variant_ids_normalized",
        "invalid_records_removed",
        "filter_standardized_to_pass"
      ],
      "type": "object",
      "x-bijux-extension-id": "vcf_postprocess_normalized_v1"
    }
  ],
  "description": "Governed normalized parser output for `vcf.postprocess`.",
  "title": "VCF normalized benchmark metrics: vcf.postprocess"
}