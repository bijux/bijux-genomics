#!/usr/bin/env sh
set -eu

required_vars="ISO_TAG ISO_RUN_ID ISO_ROOT CARGO_TARGET_DIR CARGO_HOME TMPDIR TMP TEMP"

print_explain() {
  TAG="$(date -u +%Y%m%dT%H%M%SZ)-explain-$$"
  cat <<'EOF'
isolate-required:
- This command must run inside an isolate to keep build/test outputs deterministic.
- Required env vars: ISO_TAG ISO_RUN_ID ISO_ROOT CARGO_TARGET_DIR CARGO_HOME TMPDIR TMP TEMP.
- Expected contract: all writable paths are inside ISO_ROOT.
- No silent fallback: non-isolated execution must fail and be re-invoked via bin/isolate.
EOF
  cat <<EOF

Invoke with:
  ./bin/isolate --tag $TAG --require-clean <command> [args...]

Inspect resolved isolate values before running:
  ./bin/isolate --tag $TAG --print-tag
  ./bin/isolate --tag $TAG --print-root
  ./bin/isolate --tag $TAG --print-env

For target directory hygiene:
  ./bin/isolate --tag $TAG --require-empty-target-dir <command> [args...]
  # add --reuse only when intentional reuse is required

EOF
}

if [ "${1:-}" = "--explain" ]; then
  print_explain
  exit 0
fi

fail() {
  echo "isolate-required: $1" >&2
  echo "isolate-required: missing/invalid isolation contract; run './bin/require-isolate --explain' for exact invocation." >&2
  exit 1
}

missing=""
for var in $required_vars; do
  eval "value=\${$var:-}"
  if [ -z "$value" ]; then
    missing="${missing}${var} "
  fi
done
if [ -n "$missing" ]; then
  fail "missing env var(s): $missing"
fi

case "$ISO_ROOT" in
  */artifacts/isolates/*) ;;
  *) fail "ISO_ROOT must be under artifacts/isolates: $ISO_ROOT" ;;
esac

home_dir="${HOME:-}"
if [ -n "$home_dir" ] && [ "${PWD:-}" = "$home_dir" ]; then
  fail "PWD must not be the home directory; run from a repository workspace"
fi
case "${PWD:-}" in
  /tmp|/private/tmp) fail "PWD must not be /tmp; run from a repository workspace" ;;
esac

for path in "$CARGO_TARGET_DIR" "$CARGO_HOME" "$TMPDIR" "$TMP" "$TEMP"; do
  case "$path" in
    "$ISO_ROOT"/*) ;;
    *) fail "path is not inside ISO_ROOT: $path" ;;
  esac
done

[ -w "$ISO_ROOT" ] || fail "ISO_ROOT is not writable: $ISO_ROOT"
[ -w "$(dirname "$ISO_ROOT")" ] || fail "ISO_ROOT parent is not writable: $(dirname "$ISO_ROOT")"

echo "isolate-required: OK"
