{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "bijux.adapter_trimming_report.v1",
  "title": "AdapterTrimmingReportV1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "reads_with_adapter",
    "total_reads",
    "bases_trimmed_total",
    "per_adapter_counts",
    "tool"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "bijux.adapter_trimming_report.v1"
    },
    "reads_with_adapter": {
      "description": "Count of reads with at least one adapter match.",
      "type": "integer",
      "minimum": 0
    },
    "total_reads": {
      "description": "Total reads evaluated for adapter trimming.",
      "type": "integer",
      "minimum": 0
    },
    "bases_trimmed_total": {
      "description": "Total bases trimmed across all adapters.",
      "type": "integer",
      "minimum": 0
    },
    "per_adapter_counts": {
      "type": "object",
      "description": "Counts per adapter id.",
      "additionalProperties": {
        "type": "integer",
        "minimum": 0
      }
    },
    "top_k_adapters": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "count"],
        "properties": {
          "id": { "type": "string" },
          "count": { "type": "integer", "minimum": 0 }
        }
      }
    },
    "tool": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "params"],
      "properties": {
        "id": { "type": "string" },
        "stage": { "type": "string" },
        "version": { "type": "string" },
        "params": { "type": "object" }
      }
    }
  }
}
