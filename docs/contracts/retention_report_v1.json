{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "bijux.retention_report.v1",
  "title": "RetentionReportV1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "definition",
    "numerator",
    "denominator",
    "scope",
    "stage_boundary",
    "tool"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "bijux.retention_report.v1"
    },
    "definition": {
      "type": "string",
      "description": "Human-readable definition of what is being retained."
    },
    "numerator": {
      "description": "Numerator for the retention ratio.",
      "oneOf": [
        { "type": "number" },
        { "type": "string" }
      ]
    },
    "denominator": {
      "description": "Denominator for the retention ratio.",
      "oneOf": [
        { "type": "number" },
        { "type": "string" }
      ]
    },
    "scope": {
      "type": "string",
      "description": "Scope of the measurement (reads, bases, lanes, etc.)."
    },
    "stage_boundary": {
      "type": "string",
      "description": "Stage boundary describing before/after measurement points."
    },
    "tool": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "params"],
      "properties": {
        "id": { "type": "string" },
        "stage": { "type": "string" },
        "version": { "type": "string" },
        "params": { "type": "object" }
      }
    }
  }
}
