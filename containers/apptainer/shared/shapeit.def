# VERSION_SOURCE: containers/versions/versions.toml
Bootstrap: docker
From: ubuntu:24.04@sha256:cd1dba651b3080c3686ecf4e3c4220f026b521fb76978881737d24f200828b2b

%labels
# Tool ID: shapeit
# Version policy: pinned_or_registry_locked
# Upstream source: see org.opencontainers.image.source label
# Build date policy: org.opencontainers.image.created set by release pipeline
# Network source policy: NETWORK_SOURCE_VERIFIED_BY_LOCK
# Runtime UID policy: RUNTIME_UID_SAFE

    org.opencontainers.image.source https://odelaneau.github.io/shapeit4/
    org.opencontainers.image.revision planned-4.2.2
    org.opencontainers.image.created 2026-02-13T00:00:00Z
    org.opencontainers.image.licenses MIT
    org.opencontainers.image.version 4.2.2-planned
    org.opencontainers.image.tool shapeit
    org.opencontainers.image.title shapeit

%environment
    export PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
    export LC_ALL=C
    export TZ=UTC
    DEBIAN_FRONTEND=noninteractive

%post
    set -eux
    umask 022
    export DEBIAN_FRONTEND=noninteractive
    apt-get update -qq
    apt-get install -y --no-install-recommends ca-certificates
    cat >/usr/local/bin/shapeit <<'SH'
#!/usr/bin/env bash
set -euo pipefail
if [[ "${1:-}" == "--version" ]]; then
  echo "shapeit 4.2.2-planned"
  exit 0
fi
if [[ "${1:-}" == "--help" || $# -eq 0 ]]; then
  echo "shapeit planned wrapper image. Upstream: https://odelaneau.github.io/shapeit4/"
  exit 0
fi
echo "error: shapeit runtime payload is not bundled in this planned wrapper image" >&2
exit 2
SH
    chmod 0755 /usr/local/bin/shapeit
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%runscript
    exec shapeit "$@"

%help
    Bijux Apptainer wrapper for planned SHAPEIT admission.
