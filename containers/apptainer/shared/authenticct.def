# BIJUX_TEMPLATE: v1

# Tool ID: authenticct
# Version policy: pinned_or_registry_locked
# Upstream source: see org.opencontainers.image.source label
# Build date policy: org.opencontainers.image.created set by release pipeline
# Network source policy: NETWORK_SOURCE_VERIFIED_BY_LOCK
# Runtime UID policy: RUNTIME_UID_SAFE

# VERSION_SOURCE: containers/versions/versions.toml
Bootstrap: docker
From: ubuntu:24.04@sha256:cd1dba651b3080c3686ecf4e3c4220f026b521fb76978881737d24f200828b2b

%labels
    VERSION unknown
    org.opencontainers.image.source https://github.com/bijux/bijux-dna
    org.opencontainers.image.revision unknown
    org.opencontainers.image.created unknown
    org.opencontainers.image.licenses GPL-3.0
    org.opencontainers.image.version 1.0.0
    org.opencontainers.image.tool authenticct
    org.opencontainers.image.title authenticct

%environment
    export PATH=/opt/authenticct-venv/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
    export LC_ALL=C
    export TZ=UTC
    DEBIAN_FRONTEND=noninteractive

%post
    set -eux
    umask 022
    export DEBIAN_FRONTEND=noninteractive
    apt-get update -qq && apt-get install -y --no-install-recommends \
        python3 python3-dev python3-pip python3-venv git build-essential ca-certificates && \
        rm -rf /var/lib/apt/lists/*

    git clone https://github.com/StephanePeyregne/AuthentiCT.git /opt/authenticct
    cd /opt/authenticct
    git checkout f58b25c448c8d9afebcdddd351cbae84fd5f6bab
    python3 -m venv /opt/authenticct-venv
    /opt/authenticct-venv/bin/pip install --no-cache-dir --upgrade pip setuptools wheel
    /opt/authenticct-venv/bin/pip install --no-cache-dir .

    cat > /usr/local/bin/authenticct <<'EOS'
#!/usr/bin/env sh
set -eu
run_authenticct() {
  exec /opt/authenticct-venv/bin/python -m AuthentiCT.cli "$@"
}
case "${1:-}" in
  --version)
    # Deterministic wrapper output independent of runtime script location.
    echo "authenticct 1.0.0"
    exit 0
    ;;
  --help|-h|"")
    run_authenticct --help
    ;;
  --__bijux_invalid_flag__*)
    echo "error: authenticct does not support ${1}" >&2
    exit 2
    ;;
esac
run_authenticct "$@"
EOS
    chmod +x /usr/local/bin/authenticct
%runscript
    exec /usr/local/bin/authenticct "$@"

%help
    Apptainer image for authenticct.
    Default runscript forwards arguments to the tool entrypoint.
