# BIJUX_TEMPLATE: v1

# Tool ID: fastq_scan
# Version policy: pinned_or_registry_locked
# Upstream source: see org.opencontainers.image.source label
# Build date policy: org.opencontainers.image.created set by release pipeline
# Network source policy: NETWORK_SOURCE_VERIFIED_BY_LOCK
# Runtime UID policy: RUNTIME_UID_SAFE

# VERSION_SOURCE: containers/versions/versions.toml
Bootstrap: docker
From: ubuntu:24.04@sha256:cd1dba651b3080c3686ecf4e3c4220f026b521fb76978881737d24f200828b2b

%labels
    org.opencontainers.image.source https://github.com/bijux/bijux-genomics
    org.opencontainers.image.title fastq_scan
    org.opencontainers.image.revision unknown
    org.opencontainers.image.created unknown
    org.opencontainers.image.licenses GPL-3.0
    org.opencontainers.image.version 0.0.1
    org.opencontainers.image.tool fastq_scan
%environment
    export PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
    export LC_ALL=C
    export TZ=UTC
    export VERSION_FASTQ_SCAN=0.0.1
%post
    set -eux
    umask 022
    export DEBIAN_FRONTEND=noninteractive
    apt-get update
    apt-get install -y --no-install-recommends seqkit
    cat > /usr/local/bin/fastq_scan <<'EOS'
#!/usr/bin/env sh
set -eu
case "${1:-}" in
  --version) echo "${VERSION_FASTQ_SCAN}"; exit 0 ;;
  --help|-h|"") echo "fastq_scan compatibility wrapper"; echo "usage: fastq_scan <fastq[.gz]>"; exit 0 ;;
esac
exec seqkit stats "$@"
EOS
    chmod 0755 /usr/local/bin/fastq_scan
    rm -rf /var/lib/apt/lists/*
%runscript
    if [ $# -eq 0 ]; then
        exec fastq_scan --help
    else
        exec fastq_scan "$@"
    fi
%help
    fastq_scan compatibility image.
