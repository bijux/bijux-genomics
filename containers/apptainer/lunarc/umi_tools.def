# BIJUX_TEMPLATE: v1

# Tool ID: umi_tools
# Version policy: pinned_or_registry_locked
# Upstream source: see org.opencontainers.image.source label
# Build date policy: org.opencontainers.image.created set by release pipeline
# Network source policy: NETWORK_SOURCE_VERIFIED_BY_LOCK
# Runtime UID policy: RUNTIME_UID_SAFE

# VERSION_SOURCE: containers/versions/versions.toml
Bootstrap: docker
From: python:3.9-slim@sha256:dad5b29e3506c35e0fd222736f4d4ef25d21b219acdd73f7bb41d59996ca8e0d

%labels
    MAINTAINER Bijan Mousavi <mousavi.bijan@gmail.com>
    VERSION umi_tools-1.1.6
    org.opencontainers.image.source https://github.com/CGATOxford/UMI-tools
    org.opencontainers.image.title UMI-tools
    org.opencontainers.image.licenses Apache-2.0

    org.opencontainers.image.source https://github.com/bijux/bijux-dna
    org.opencontainers.image.revision unknown
    org.opencontainers.image.created unknown
    org.opencontainers.image.licenses GPL-3.0
    org.opencontainers.image.version 1.1.6
    org.opencontainers.image.tool umi_tools
%environment
    export LC_ALL=C
    DEBIAN_FRONTEND=noninteractive
    TZ=UTC
    export VERSION_UMI_TOOLS=1.1.6
    PATH=/opt/umi-tools-venv/bin:/usr/local/bin:/usr/bin:/bin

%post
    set -eux
    umask 022
    export DEBIAN_FRONTEND=noninteractive

    apt-get update -qq
    apt-get install -y --no-install-recommends \
        ca-certificates \
        build-essential \
        git \
        python3 \
        python3-pip \
        python3-venv \
        liblzma-dev

    python3 -m venv /opt/umi-tools-venv
    /opt/umi-tools-venv/bin/pip install --no-cache-dir --upgrade pip setuptools wheel
    /opt/umi-tools-venv/bin/pip install --no-cache-dir \
        "git+https://github.com/CGATOxford/UMI-tools.git@v${VERSION_UMI_TOOLS}"
    install -m 0755 /opt/umi-tools-venv/bin/umi_tools /usr/local/bin/umi_tools-bin

    # Create a wrapper for stable --version and --help behavior.
    cat > /usr/local/bin/umi_tools <<'EOF'
#!/usr/bin/env sh
set -eu

case "${1:-}" in
  --version)
    echo "${VERSION_UMI_TOOLS}"
    exit 0
    ;;
  --help|-h|"")
    echo "UMI-tools ${VERSION_UMI_TOOLS}"
    echo "wrapper help: invoke umi_tools subcommands for full functionality"
    exit 0
    ;;
esac

exec /usr/local/bin/umi_tools-bin "$@"
EOF
    chmod 0755 /usr/local/bin/umi_tools

    rm -rf /var/lib/apt/lists/*
%runscript
    if [ $# -eq 0 ]; then
        exec umi_tools --help
    else
        exec umi_tools "$@"
    fi

%help
    UMI-tools v1.1.6 installed into /opt/umi-tools-venv (Python 3.9).
    This image installs from the upstream Git tag rather than the legacy sdist path so Apptainer builds avoid the ez_setup/setuptools bootstrap failure.
    Wrapper: umi_tools
    Real binary: umi_tools-bin
