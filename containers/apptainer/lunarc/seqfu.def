# BIJUX_TEMPLATE: v1

# Tool ID: seqfu
# Version policy: pinned_or_registry_locked
# Upstream source: see org.opencontainers.image.source label
# Build date policy: org.opencontainers.image.created set by release pipeline
# Network source policy: NETWORK_SOURCE_VERIFIED_BY_LOCK
# Runtime UID policy: RUNTIME_UID_SAFE

# VERSION_SOURCE: containers/versions/versions.toml
Bootstrap: docker
From: ubuntu:24.04@sha256:cd1dba651b3080c3686ecf4e3c4220f026b521fb76978881737d24f200828b2b

%labels
    org.opencontainers.image.source https://github.com/telatin/seqfu2
    org.opencontainers.image.title seqfu
    org.opencontainers.image.revision unknown
    org.opencontainers.image.created unknown
    org.opencontainers.image.licenses GPL-3.0
    org.opencontainers.image.version 2.4.0
    org.opencontainers.image.tool seqfu
%environment
    export PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
    export LC_ALL=C
    export TZ=UTC
    export VERSION_SEQFU=2.4.0
%post
    set -eux
    umask 022
    export DEBIAN_FRONTEND=noninteractive
    apt-get update
    apt-get install -y --no-install-recommends seqkit
    cat > /usr/local/bin/seqfu <<'EOS'
#!/usr/bin/env sh
set -eu
case "${1:-}" in
  --version) echo "${VERSION_SEQFU}"; exit 0 ;;
  --help|-h|"") echo "seqfu compatibility wrapper"; echo "usage: seqfu <stats|subseq|...>"; exit 0 ;;
esac
exec seqkit "$@"
EOS
    chmod 0755 /usr/local/bin/seqfu
    rm -rf /var/lib/apt/lists/*
    mkdir -p /opt/bijux && \
    printf '%s\n' '{"tool":"seqfu","version":"2.4.0","source":"https://github.com/telatin/seqfu2","license":"GPL-3.0"}' > /opt/bijux/VERSION.json && \
    printf '%s\n' '#!/usr/bin/env sh' 'set -eu' 'cat /opt/bijux/VERSION.json' > /usr/local/bin/bijux-tool-info && \
    chmod 0755 /usr/local/bin/bijux-tool-info

%runscript
    if [ $# -eq 0 ]; then
        exec seqfu --help
    else
        exec seqfu "$@"
    fi
%help
    seqfu compatibility image.
