# BIJUX_TEMPLATE: v1

# Tool ID: bayeshammer
# Version policy: pinned_or_registry_locked
# Upstream source: see org.opencontainers.image.source label
# Build date policy: org.opencontainers.image.created set by release pipeline
# Network source policy: NETWORK_SOURCE_VERIFIED_BY_LOCK
# Runtime UID policy: RUNTIME_UID_SAFE

# VERSION_SOURCE: containers/versions/versions.toml
Bootstrap: docker
From: ubuntu:24.04@sha256:cd1dba651b3080c3686ecf4e3c4220f026b521fb76978881737d24f200828b2b

%labels
    MAINTAINER Bijan Mousavi <mousavi.bijan@gmail.com>
    VERSION SPAdes-v4.2.0-BayesHammer

    org.opencontainers.image.source https://github.com/bijux/bijux-dna
    org.opencontainers.image.revision unknown
    org.opencontainers.image.created unknown
    org.opencontainers.image.licenses GPL-3.0
    org.opencontainers.image.version 0.0.0
    org.opencontainers.image.tool bayeshammer
    org.opencontainers.image.title bayeshammer
%environment
    export PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
    export LC_ALL=C
    TZ=UTC
    DEBIAN_FRONTEND=noninteractive

%post
    set -eux
    umask 022
    export TZ=UTC
    export DEBIAN_FRONTEND=noninteractive

    BUILD_DEPS="wget xz-utils" && \
    RUNTIME_DEPS="libgomp1 python3 python3-yaml" && \

    apt-get update && \
    apt-get install -y --no-install-recommends \
        ${BUILD_DEPS} \
        ${RUNTIME_DEPS} && \

    wget -qO /tmp/spades.tar.gz \
        "https://github.com/ablab/spades/releases/download/v4.2.0/SPAdes-4.2.0-Linux.tar.gz" && \
    tar -xzf /tmp/spades.tar.gz -C /opt && \
    cp -r /opt/SPAdes-4.2.0-Linux/bin/* /usr/local/bin/ && \
    cp -r /opt/SPAdes-4.2.0-Linux/share/spades /usr/local/share/ && \
    chmod +x /usr/local/share/spades/spades.py && \
    ln -sf /usr/local/share/spades/spades.py /usr/local/bin/spades.py && \

    cd / && \
    rm -rf /opt/SPAdes-4.2.0-Linux /tmp/spades.tar.gz && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

    # Create a wrapper script for bayeshammer.
    printf '%s\n' \
      '#!/usr/bin/env bash' \
      'set -e' \
      'spades_entry=/usr/local/bin/spades.py' \
      'if [ ! -x "$spades_entry" ]; then' \
      '  echo "error: spades.py not installed at $spades_entry" >&2' \
      '  exit 127' \
      'fi' \
      'case "$1" in' \
      '  --version) echo "4.2.0"; exit 0 ;;' \
      '  --help|-h|"") exec "$spades_entry" --only-error-correction --help ;;' \
      '  --__bijux_invalid_flag__*) echo "error: bayeshammer does not support $1" >&2; exit 2 ;;' \
      'esac' \
      'exec "$spades_entry" --only-error-correction "$@"' \
      > /usr/local/bin/bayeshammer && \
    chmod +x /usr/local/bin/bayeshammer
    mkdir -p /opt/bijux && \
    printf '%s\n' '{"tool":"bayeshammer","version":"4.2.0","source":"https://github.com/ablab/spades","license":"GPL-3.0"}' > /opt/bijux/VERSION.json && \
    printf '%s\n' '#!/usr/bin/env sh' 'set -eu' 'cat /opt/bijux/VERSION.json' > /usr/local/bin/bijux-tool-info && \
    chmod +x /usr/local/bin/bijux-tool-info

%runscript
    if [ $# -eq 0 ]; then
        exec /usr/local/bin/bayeshammer --help
    else
        exec /usr/local/bin/bayeshammer "$@"
    fi

%help
    This Apptainer image provides BayesHammer (via SPAdes v4.2.0 error correction module).
    The default command is 'bayeshammer', which runs 'spades.py --only-error-correction'.
    Run without arguments to display help, or provide arguments to execute error correction.
