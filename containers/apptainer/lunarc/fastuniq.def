# BIJUX_TEMPLATE: v1

# Tool ID: fastuniq
# Version policy: pinned_or_registry_locked
# Upstream source: see org.opencontainers.image.source label
# Build date policy: org.opencontainers.image.created set by release pipeline
# Network source policy: NETWORK_SOURCE_VERIFIED_BY_LOCK
# Runtime UID policy: RUNTIME_UID_SAFE

# VERSION_SOURCE: containers/versions/versions.toml
Bootstrap: docker
From: ubuntu:24.04@sha256:cd1dba651b3080c3686ecf4e3c4220f026b521fb76978881737d24f200828b2b

%labels
    org.opencontainers.image.source https://sourceforge.net/projects/fastuniq/
    org.opencontainers.image.title fastuniq
    org.opencontainers.image.revision unknown
    org.opencontainers.image.created unknown
    org.opencontainers.image.licenses GPL-3.0
    org.opencontainers.image.version 1.1
    org.opencontainers.image.tool fastuniq
%environment
    export PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
    export LC_ALL=C
    export TZ=UTC
    export VERSION_FASTUNIQ=1.1
%post
    set -eux
    umask 022
    VERSION_FASTUNIQ=1.1
    export VERSION_FASTUNIQ
    export DEBIAN_FRONTEND=noninteractive
    apt-get update
    apt-get install -y --no-install-recommends build-essential ca-certificates curl
    curl -fsSL "https://sourceforge.net/projects/fastuniq/files/FastUniq-${VERSION_FASTUNIQ}.tar.gz/download" -o /tmp/FastUniq.tar.gz
    tar -xzf /tmp/FastUniq.tar.gz -C /tmp
    make -C /tmp/FastUniq/source
    install -d /usr/local/libexec
    install -m 0755 /tmp/FastUniq/source/fastuniq /usr/local/libexec/fastuniq.real
    cat > /usr/local/bin/fastuniq <<'EOS'
#!/usr/bin/env sh
set -eu
case "${1:-}" in
  --version) echo "${VERSION_FASTUNIQ}"; exit 0 ;;
  --help|-h|"")
    cat <<'EOH'
FastUniq 1.1
Usage: fastuniq -i <input_list.txt> -t <q|f|p> -o <out1> [-p <out2>] [-c <0|1>]
EOH
    exit 0
    ;;
esac
exec /usr/local/libexec/fastuniq.real "$@"
EOS
    chmod 0755 /usr/local/bin/fastuniq
    rm -rf /tmp/FastUniq /tmp/FastUniq.tar.gz
    rm -rf /var/lib/apt/lists/*
%runscript
    if [ $# -eq 0 ]; then
        exec fastuniq -h
    else
        exec fastuniq "$@"
    fi
%help
    FastUniq image built from upstream source.
