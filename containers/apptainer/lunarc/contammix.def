# BIJUX_TEMPLATE: v1

# Tool ID: contammix
# Version policy: pinned_or_registry_locked
# Upstream source: see org.opencontainers.image.source label
# Build date policy: org.opencontainers.image.created set by release pipeline
# Network source policy: NETWORK_SOURCE_VERIFIED_BY_LOCK
# Runtime UID policy: RUNTIME_UID_SAFE

# VERSION_SOURCE: containers/versions/versions.toml
Bootstrap: docker
From: ubuntu:24.04@sha256:cd1dba651b3080c3686ecf4e3c4220f026b521fb76978881737d24f200828b2b

%labels
    VERSION unknown
    org.opencontainers.image.source https://github.com/bijux/bijux-dna
    org.opencontainers.image.revision unknown
    org.opencontainers.image.created unknown
    org.opencontainers.image.licenses GPL-3.0
    org.opencontainers.image.version 1.0.11
    org.opencontainers.image.tool contammix
    org.opencontainers.image.title contammix
%environment
    export PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
    export LC_ALL=C
    export TZ=UTC
    DEBIAN_FRONTEND=noninteractive

%post
    set -eux
    umask 022
    export DEBIAN_FRONTEND=noninteractive
    apt-get update -qq && apt-get install -y --no-install-recommends r-base ca-certificates && rm -rf /var/lib/apt/lists/*
    R -q -e 'install.packages("BiocManager", repos="https://cran.r-project.org"); BiocManager::install("contamMix", ask=FALSE, update=FALSE)'
    cat > /usr/local/bin/contammix <<'SH'
#!/bin/sh
set -eu
if [ "${1:-}" = "--version" ]; then
  echo "1.0.11"
  exit 0
fi
if [ "${1:-}" = "--help" ] || [ $# -eq 0 ]; then
  R -q -e 'cat("contamMix installed. Use R scripts for workflow integration.\n")'
  exit 0
fi
exec R "$@"
SH
    chmod +x /usr/local/bin/contammix

%runscript
    exec /usr/local/bin/contammix "$@"

%help
    Apptainer image for contamMix.
