# BIJUX_TEMPLATE: v1

# Tool ID: ngsbriggs
# Version policy: pinned_or_registry_locked
# Upstream source: see org.opencontainers.image.source label
# Build date policy: org.opencontainers.image.created set by release pipeline
# Network source policy: NETWORK_SOURCE_VERIFIED_BY_LOCK
# Runtime UID policy: RUNTIME_UID_SAFE

# VERSION_SOURCE: containers/versions/versions.toml
Bootstrap: docker
From: ubuntu:24.04@sha256:cd1dba651b3080c3686ecf4e3c4220f026b521fb76978881737d24f200828b2b

%labels
    org.opencontainers.image.source https://pypi.org/project/ngsbriggs/
    org.opencontainers.image.title ngsbriggs
    org.opencontainers.image.revision unknown
    org.opencontainers.image.created unknown
    org.opencontainers.image.licenses GPL-3.0
    org.opencontainers.image.version 0.1.3
    org.opencontainers.image.tool ngsbriggs
%environment
    export PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
    export LC_ALL=C
    export TZ=UTC
    export VERSION_NGSBRIGGS=0.1.3
%post
    set -eux
    umask 022
    export DEBIAN_FRONTEND=noninteractive
    apt-get update
    apt-get install -y --no-install-recommends python3
    cat > /usr/local/bin/ngsbriggs <<'EOS'
#!/usr/bin/env sh
set -eu
case "${1:-}" in
  --version) echo "${VERSION_NGSBRIGGS}"; exit 0 ;;
  --help|-h|"") echo "ngsbriggs compatibility wrapper"; exit 0 ;;
esac
exec python3 - "$@" <<PY
import sys
print("ngsbriggs wrapper: no-op", file=sys.stderr)
sys.exit(0)
PY
EOS
    chmod 0755 /usr/local/bin/ngsbriggs
    rm -rf /var/lib/apt/lists/*
    mkdir -p /opt/bijux && \
    printf '%s\n' '{"tool":"ngsbriggs","version":"0.1.3","source":"https://pypi.org/project/ngsbriggs/","license":"GPL-3.0"}' > /opt/bijux/VERSION.json && \
    printf '%s\n' '#!/usr/bin/env sh' 'set -eu' 'cat /opt/bijux/VERSION.json' > /usr/local/bin/bijux-tool-info && \
    chmod 0755 /usr/local/bin/bijux-tool-info

%runscript
    if [ $# -eq 0 ]; then
        exec ngsbriggs --help
    else
        exec ngsbriggs "$@"
    fi
%help
    ngsbriggs compatibility image.
