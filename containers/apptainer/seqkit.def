Bootstrap: docker
From: ubuntu:24.04

%labels
    MAINTAINER Bijan Mousavi <mousavi.bijan@gmail.com>
    VERSION seqkit-2.8.2
    org.opencontainers.image.source https://github.com/shenwei356/seqkit
    org.opencontainers.image.title seqkit
    org.opencontainers.image.licenses Apache-2.0

    org.opencontainers.image.source https://github.com/bijux/bijux-dna
    org.opencontainers.image.revision unknown
    org.opencontainers.image.created unknown
    org.opencontainers.image.licenses GPL-3.0-or-later
    org.opencontainers.image.version unknown
%environment
    DEBIAN_FRONTEND=noninteractive
    TZ=UTC
    VERSION_SEQKIT=2.8.2

%post
    set -eux
    export DEBIAN_FRONTEND=noninteractive

    apt-get update
    apt-get install -y --no-install-recommends \
        wget \
        ca-certificates \
        gzip \
        tar

    # Download ARM64 release tarball and install
    cd /tmp
    wget -q -O seqkit.tar.gz \
      "https://github.com/shenwei356/seqkit/releases/download/v2.8.2/seqkit_linux_arm64.tar.gz"

    tar -xzf seqkit.tar.gz -C /usr/local/bin
    mv /usr/local/bin/seqkit /usr/local/bin/seqkit-bin
    chmod 0755 /usr/local/bin/seqkit-bin

    # Wrapper script: unified execution + stable --version / --help behavior
    cat > /usr/local/bin/seqkit <<'EOF'
#!/usr/bin/env sh
set -eu

case "${1:-}" in
  --version)
    echo "${VERSION_SEQKIT}"
    exit 0
    ;;
  --help|-h|"")
    exec /usr/local/bin/seqkit-bin --help
    ;;
esac

exec /usr/local/bin/seqkit-bin "$@"
EOF
    chmod 0755 /usr/local/bin/seqkit

    # Clean up.
    rm -f /tmp/seqkit.tar.gz
    rm -rf /var/lib/apt/lists/*

    # Note: do not purge ca-certificates; it is not worth breaking TLS later.
    apt-get purge -y --auto-remove wget || true

%runscript
    if [ $# -eq 0 ]; then
        exec seqkit --help
    else
        exec seqkit "$@"
    fi

%help
    This Apptainer image provides SeqKit v2.8.2 (ARM64 release binary).
    Wrapper: 'seqkit' (stable --version and --help behavior)
    Underlying binary: 'seqkit-bin'
