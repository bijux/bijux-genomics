Bootstrap: docker
From: ubuntu:24.04

%labels
    MAINTAINER Bijan Mousavi <mousavi.bijan@gmail.com>
    VERSION PEAR-v0.9.6
    org.opencontainers.image.source https://sco.h-its.org/exelixis/web/software/pear/

%environment
    DEBIAN_FRONTEND=noninteractive

%post
    export DEBIAN_FRONTEND=noninteractive

    apt-get update -qq && \
    apt-get install -y --no-install-recommends \
        wget \
        ca-certificates \
        build-essential \
        zlib1g-dev \
        libbz2-dev \
        liblzma-dev \
        autoconf \
        automake \
        libtool \
        m4 \
        pkg-config && \

    wget -q https://depot.galaxyproject.org/software/pear/pear_0.9.6_src_all.tar.gz -O /tmp/pear.tar.gz && \
    tar -xzf /tmp/pear.tar.gz -C /opt && \
    cd /opt/pear-0.9.6-src && \
    autoreconf -i && \
    ./configure --prefix=/usr/local && \
    make -j$(nproc) && \
    make install && \
    mv /usr/local/bin/pear /usr/local/bin/pear-bin && \

    # Create a wrapper script with version override and help handling.
    cat > /usr/local/bin/pear <<'EOF'
#!/bin/sh
if [ "$1" = "--version" ]; then
    echo "0.9.6"
    exit 0
elif [ "$1" = "--help" ]; then
    /usr/local/bin/pear-bin --help
    exit 0
else
    /usr/local/bin/pear-bin "$@"
fi
EOF
    chmod +x /usr/local/bin/pear && \

    cd / && \
    rm -rf /opt/pear-0.9.6-src /tmp/pear.tar.gz && \
    apt-get purge -y wget ca-certificates build-essential autoconf automake libtool m4 pkg-config && \
    apt-get autoremove -y && \
    rm -rf /var/lib/apt/lists/*

%runscript
    if [ $# -eq 0 ]; then
        exec /usr/local/bin/pear --help
    else
        exec /usr/local/bin/pear "$@"
    fi

%help
    This Apptainer image provides PEAR version 0.9.6, compiled from source.
    The default command is 'pear' (with wrapper for consistent --version output).
    Run without arguments to display help.