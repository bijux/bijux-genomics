Bootstrap: docker
From: ubuntu:24.04@sha256:cd1dba651b3080c3686ecf4e3c4220f026b521fb76978881737d24f200828b2b

%labels
    org.opencontainers.image.source https://github.com/bijux/bijux-dna
    org.opencontainers.image.revision unknown
    org.opencontainers.image.created unknown
    org.opencontainers.image.licenses GPL-3.0
    org.opencontainers.image.version 0.0.14
    org.opencontainers.image.tool fastx_clipper
%environment
    DEBIAN_FRONTEND=noninteractive

%post
    export DEBIAN_FRONTEND=noninteractive
    apt-get update -qq && apt-get install -y --no-install-recommends git build-essential automake autoconf libtool zlib1g-dev ca-certificates && rm -rf /var/lib/apt/lists/*
    git clone --depth 1 https://github.com/agordon/fastx_toolkit.git /opt/fastx
    cd /opt/fastx
    git checkout ea0ca83ba24dce80c20ca589b838a281fe5deb0c
    ./reconf
    ./configure
    make -j"$(nproc)"
    cp /opt/fastx/src/fastx_clipper /usr/local/bin/fastx_clipper

%runscript
    exec /usr/local/bin/fastx_clipper "$@"

%help
    Apptainer image for fastx_clipper.
