Bootstrap: docker
From: ubuntu:24.04

%labels
    MAINTAINER Bijan Mousavi <mousavi.bijan@gmail.com>
    VERSION Kaiju-v1.10.0
    org.opencontainers.image.source https://github.com/bioinformatics-centre/kaiju

%environment
    DEBIAN_FRONTEND=noninteractive

%post
    export DEBIAN_FRONTEND=noninteractive

    apt-get update && \
    apt-get install -y --no-install-recommends \
        wget \
        ca-certificates \
        build-essential \
        zlib1g-dev && \

    wget -q https://github.com/bioinformatics-centre/kaiju/archive/v1.10.0.tar.gz -O /tmp/kaiju.tar.gz && \
    tar -xzf /tmp/kaiju.tar.gz -C /opt && \
    cd /opt/kaiju-1.10.0/src && \
    make && \
    mv ../bin/kaiju /usr/local/bin/kaiju-bin && \
    mv ../bin/* /usr/local/bin/ && \

    # Create a wrapper script with version override and help handling.
    cat > /usr/local/bin/kaiju <<'EOF'
#!/bin/sh
if [ "$1" = "--version" ]; then
    echo "1.10.0"
    exit 0
elif [ "$1" = "--help" ]; then
    /usr/local/bin/kaiju-bin --help
    exit 0
else
    /usr/local/bin/kaiju-bin "$@"
fi
EOF
    chmod +x /usr/local/bin/kaiju && \

    cd / && \
    rm -rf /tmp/kaiju.tar.gz /opt/kaiju-1.10.0 && \
    apt-get purge -y wget build-essential zlib1g-dev && \
    apt-get autoremove -y && \
    rm -rf /var/lib/apt/lists/*

%runscript
    if [ $# -eq 0 ]; then
        exec /usr/local/bin/kaiju --help
    else
        exec /usr/local/bin/kaiju "$@"
    fi

%help
    This Apptainer image provides Kaiju version 1.10.0, compiled from source.
    All Kaiju tools (kaiju, kaiju2table, etc.) are available.
    The default command is 'kaiju' (with wrapper for consistent --version output).
    Run without arguments to display help.