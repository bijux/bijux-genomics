Bootstrap: docker
From: ubuntu:24.04

%labels
    MAINTAINER Bijan Mousavi <mousavi.bijan@gmail.com>
    VERSION trim_galore-0.6.10
    org.opencontainers.image.source https://github.com/FelixKrueger/TrimGalore
    org.opencontainers.image.title Trim Galore!
    org.opencontainers.image.licenses Apache-2.0

    org.opencontainers.image.source https://github.com/bijux/bijux-dna
    org.opencontainers.image.revision unknown
    org.opencontainers.image.created unknown
    org.opencontainers.image.licenses GPL-3.0
    org.opencontainers.image.version unknown
%environment
    DEBIAN_FRONTEND=noninteractive
    TZ=UTC
    VERSION_TRIM_GALORE=0.6.10

%post
    set -eux
    export DEBIAN_FRONTEND=noninteractive

    # Base deps + runtime deps
    apt-get update
    apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        python3-dev \
        build-essential \
        fastqc \
        wget \
        ca-certificates \
        gzip \
        tar

    # Fetch Trim Galore! source
    cd /tmp
    wget -q -O trimgalore.tar.gz \
      "https://github.com/FelixKrueger/TrimGalore/archive/0.6.10.tar.gz"

    mkdir -p /opt
    tar -xzf trimgalore.tar.gz -C /opt

    # Install entrypoint script
    ln -sf "/opt/TrimGalore-0.6.10/trim_galore" /usr/local/bin/trim_galore
    chmod 0755 /usr/local/bin/trim_galore

    rm -f /tmp/trimgalore.tar.gz

    # Install cutadapt (Trim Galore relies on it for adapter trimming)
    python3 -m pip install --no-cache-dir --break-system-packages cutadapt

    # Clean up apt lists.
    rm -rf /var/lib/apt/lists/*

    # Purge build-only deps (keep python3 + pip since cutadapt is python runtime)
        build-essential \
        python3-dev \
        wget || true

%runscript
    if [ $# -eq 0 ]; then
        exec trim_galore --help
    else
        exec trim_galore "$@"
    fi

%help
    This Apptainer image provides Trim Galore! v0.6.10 on Ubuntu 24.04.
    Includes: cutadapt (pip), fastqc (apt).
    Executable: trim_galore
