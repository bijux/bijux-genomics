Bootstrap: docker
From: ubuntu:24.04

%labels
    MAINTAINER Bijan Mousavi <mousavi.bijan@gmail.com>
    VERSION Lighter-v1.1.2
    org.opencontainers.image.source https://github.com/mourisl/Lighter

    org.opencontainers.image.source https://github.com/bijux/bijux-dna
    org.opencontainers.image.revision unknown
    org.opencontainers.image.created unknown
    org.opencontainers.image.licenses GPL-3.0-or-later
    org.opencontainers.image.version unknown
%environment
    DEBIAN_FRONTEND=noninteractive
    TZ=UTC

%post
    export DEBIAN_FRONTEND=noninteractive
    export TZ=UTC

    BUILD_DEPS="build-essential curl" && \
    RUNTIME_DEPS="zlib1g-dev ca-certificates" && \

    apt-get update && \
    apt-get install -y --no-install-recommends \
        ${BUILD_DEPS} \
        ${RUNTIME_DEPS} && \

    curl -L --retry 5 --retry-delay 3 --connect-timeout 20 --max-time 300 \
        -o /tmp/lighter.tar.gz \
        "https://github.com/mourisl/Lighter/archive/refs/tags/v1.1.2.tar.gz" && \
    tar -xzf /tmp/lighter.tar.gz -C /opt && \
    cd /opt/Lighter-1.1.2 && \

    # Apply GCC compatibility fixes
    sed -i '1i#include <string.h>' main.cpp && \
    sed -r -i '/char[[:space:]]+code\[128\]/,/};/d' main.cpp && \
    sed -i '/code\[65\]/i static char code[128]; memset(code,(signed char)-1,sizeof(code));' main.cpp && \

    make -j$(nproc) CXXFLAGS="-Wall -O3 -std=c++03 -Wno-narrowing" && \
    install -m 0755 lighter /usr/local/bin/lighter-bin && \

    # Create a wrapper script.
    cat > /usr/local/bin/lighter <<'EOF'
#!/usr/bin/env bash
set -e
case "$1" in
  --version) echo "1.1.2"; exit 0 ;;
  --help|-h) exec /usr/local/bin/lighter-bin --help ;;
esac
exec /usr/local/bin/lighter-bin "$@"
EOF
    chmod +x /usr/local/bin/lighter && \

    cd / && \
    rm -rf /opt/Lighter-1.1.2 /tmp/lighter.tar.gz && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

%runscript
    if [ $# -eq 0 ]; then
        exec /usr/local/bin/lighter --help
    else
        exec /usr/local/bin/lighter "$@"
    fi

%help
    This Apptainer image provides Lighter version 1.1.2, compiled from source with GCC compatibility patches.
    The default command is 'lighter' (with wrapper for consistent --version output).
    Run without arguments to display help.
