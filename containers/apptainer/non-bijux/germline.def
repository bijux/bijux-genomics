# VERSION_SOURCE: containers/versions/versions.toml
Bootstrap: docker
From: ubuntu:24.04@sha256:cd1dba651b3080c3686ecf4e3c4220f026b521fb76978881737d24f200828b2b

%labels
# Tool ID: germline
# Version policy: pinned_or_registry_locked
# Upstream source: see org.opencontainers.image.source label
# Build date policy: org.opencontainers.image.created set by release pipeline
# Network source policy: NETWORK_SOURCE_VERIFIED_BY_LOCK
# Runtime UID policy: RUNTIME_UID_SAFE

    org.opencontainers.image.source https://www.cs.columbia.edu/~gusev/germline/
    org.opencontainers.image.revision v1.5.3
    org.opencontainers.image.created 2026-02-13T00:00:00Z
    org.opencontainers.image.licenses GPL-3.0
    org.opencontainers.image.version 1.5.3
    org.opencontainers.image.tool germline
    org.opencontainers.image.title germline

%environment
    export PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
    export LC_ALL=C
    export TZ=UTC
    DEBIAN_FRONTEND=noninteractive

%post
    set -eux
    umask 022
    export DEBIAN_FRONTEND=noninteractive
    apt-get update -qq
    apt-get install -y --no-install-recommends ca-certificates curl g++ make zlib1g-dev
    curl -fsSL -o /tmp/germline.tar.gz https://github.com/gusevlab/germline/archive/refs/tags/v1.5.3.tar.gz
    echo "2712053ab9d4dea7b2346e7f5a70ec84f6f003720f5e1ab5fbe1c709c7c8f6d2  /tmp/germline.tar.gz" | sha256sum -c -
    tar -xzf /tmp/germline.tar.gz -C /tmp
    make -C /tmp/germline-1.5.3
    install -m 0755 /tmp/germline-1.5.3/germline /usr/local/bin/germline
    mkdir -p /opt/bijux
    printf '%s\n' '{"tool":"germline","version":"1.5.3","source":"https://www.cs.columbia.edu/~gusev/germline/","license":"GPL-3.0"}' > /opt/bijux/VERSION.json
    cat >/usr/local/bin/bijux-tool-info <<'SH'
#!/usr/bin/env bash
set -euo pipefail
cat /opt/bijux/VERSION.json
SH
    chmod 0755 /usr/local/bin/bijux-tool-info
    rm -rf /tmp/germline.tar.gz /tmp/germline-1.5.3
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%runscript
    exec germline "$@"

%help
    Non-bijux Apptainer recipe for germline with pinned source checksum.
