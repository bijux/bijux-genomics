# VERSION_SOURCE: containers/versions/versions.toml
Bootstrap: docker
From: ubuntu:24.04@sha256:cd1dba651b3080c3686ecf4e3c4220f026b521fb76978881737d24f200828b2b

%labels
# Tool ID: glimpse
# Version policy: pinned_or_registry_locked
# Upstream source: see org.opencontainers.image.source label
# Build date policy: org.opencontainers.image.created set by release pipeline
# Network source policy: NETWORK_SOURCE_VERIFIED_BY_LOCK
# Runtime UID policy: RUNTIME_UID_SAFE

    org.opencontainers.image.source https://odelaneau.github.io/GLIMPSE/
    org.opencontainers.image.revision planned-2026-02-13
    org.opencontainers.image.created 2026-02-13T00:00:00Z
    org.opencontainers.image.licenses MIT
    org.opencontainers.image.version planned
    org.opencontainers.image.tool glimpse
    org.opencontainers.image.title glimpse

%environment
    export PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
    export LC_ALL=C
    export TZ=UTC
    DEBIAN_FRONTEND=noninteractive

%post
    set -eux
    umask 022
    cat >/usr/local/bin/glimpse <<'SH'
#!/usr/bin/env bash
set -euo pipefail
if [[ "${1:-}" == "--version" ]]; then
  echo "glimpse planned"
  exit 0
fi
if [[ "${1:-}" == "--help" || $# -eq 0 ]]; then
  echo "GLIMPSE wrapper image. Upstream: https://odelaneau.github.io/GLIMPSE/"
  exit 0
fi
echo "GLIMPSE binary not bundled in this planned wrapper image." >&2
exit 2
SH
    chmod 0755 /usr/local/bin/glimpse
    mkdir -p /opt/bijux
    printf '%s\n' '{"tool":"glimpse","version":"planned","source":"https://odelaneau.github.io/GLIMPSE/","license":"MIT"}' > /opt/bijux/VERSION.json
    cat >/usr/local/bin/bijux-tool-info <<'SH'
#!/usr/bin/env bash
set -euo pipefail
cat /opt/bijux/VERSION.json
SH
    chmod 0755 /usr/local/bin/bijux-tool-info

%runscript
    exec glimpse "$@"

%help
    Non-bijux Apptainer wrapper for GLIMPSE.
