Bootstrap: docker
From: ubuntu:24.04@sha256:cd1dba651b3080c3686ecf4e3c4220f026b521fb76978881737d24f200828b2b

%labels
    org.opencontainers.image.source https://faculty.washington.edu/browning/beagle/beagle.html
    org.opencontainers.image.revision pinned-2026-02-13
    org.opencontainers.image.created 2026-02-13T00:00:00Z
    org.opencontainers.image.licenses GPL-3.0
    org.opencontainers.image.version 5.4
    org.opencontainers.image.tool beagle
    org.opencontainers.image.title beagle

%environment
    DEBIAN_FRONTEND=noninteractive

%post
    export DEBIAN_FRONTEND=noninteractive
    apt-get update -qq
    apt-get install -y --no-install-recommends ca-certificates curl openjdk-21-jre-headless
    curl -fsSL -o /opt/beagle.jar https://faculty.washington.edu/browning/beagle/beagle.29Oct24.c8e.jar
    echo "220b8f1687f32f6f04cb4e85b0d6ab4ecd2e98f6f5147064c4c2420ddfdd5b3f  /opt/beagle.jar" | sha256sum -c -
    cat >/usr/local/bin/beagle <<'SH'
#!/usr/bin/env bash
set -euo pipefail
if [[ "${1:-}" == "--version" ]]; then
  echo "beagle 5.4"
  exit 0
fi
exec java -jar /opt/beagle.jar "$@"
SH
    chmod 0755 /usr/local/bin/beagle
    mkdir -p /opt/bijux
    printf '%s\n' '{"tool":"beagle","version":"5.4","source":"https://faculty.washington.edu/browning/beagle/beagle.html","license":"GPL-3.0"}' > /opt/bijux/VERSION.json
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%runscript
    exec beagle "$@"

%help
    Non-bijux Apptainer recipe for Beagle with pinned jar checksum.
