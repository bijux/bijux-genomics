# Tool ID: bcftools
# Version policy: pinned_or_registry_locked
# Upstream source: see org.opencontainers.image.source label
# Build date policy: org.opencontainers.image.created set by release pipeline
# Network source policy: NETWORK_SOURCE_VERIFIED_BY_LOCK
# Runtime UID policy: RUNTIME_UID_SAFE

Bootstrap: docker
From: quay.io/biocontainers/bcftools:1.20--h8b25389_0@sha256:67f54df47f501f6ddef08e3b9ad89cf693952f9a89de0d74df6e39fce15f1ff6

%labels
    VERSION unknown
    org.opencontainers.image.source https://github.com/bijux/bijux-dna
    org.opencontainers.image.revision unknown
    org.opencontainers.image.created unknown
    org.opencontainers.image.licenses MIT
    org.opencontainers.image.version 1.20
    org.opencontainers.image.tool bcftools
    org.opencontainers.image.title bcftools

%environment
    export PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
    export TZ=UTC
    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8

%post
    set -eux
    set -eu
    bcftools --version >/dev/null 2>&1 || true

%runscript
    exec bcftools "$@"

%help
    Apptainer image for bcftools.
    Default runscript forwards arguments to the tool entrypoint.
