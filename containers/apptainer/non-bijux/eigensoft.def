# VERSION_SOURCE: containers/versions/versions.toml
Bootstrap: docker
From: ubuntu:24.04@sha256:cd1dba651b3080c3686ecf4e3c4220f026b521fb76978881737d24f200828b2b

%labels
# Tool ID: eigensoft
# Version policy: pinned_or_registry_locked
# Upstream source: see org.opencontainers.image.source label
# Build date policy: org.opencontainers.image.created set by release pipeline
# Network source policy: NETWORK_SOURCE_VERIFIED_BY_LOCK
# Runtime UID policy: RUNTIME_UID_SAFE

    org.opencontainers.image.source https://github.com/DReichLab/EIG
    org.opencontainers.image.revision v8.0.0
    org.opencontainers.image.created 2026-02-13T00:00:00Z
    org.opencontainers.image.licenses GPL-2.0
    org.opencontainers.image.version 8.0.0
    org.opencontainers.image.tool eigensoft
    org.opencontainers.image.title eigensoft

%environment
    export PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
    export LC_ALL=C
    export TZ=UTC
    DEBIAN_FRONTEND=noninteractive

%post
    set -eux
    umask 022
    export DEBIAN_FRONTEND=noninteractive
    apt-get update -qq
    apt-get install -y --no-install-recommends ca-certificates
    cat >/usr/local/bin/smartpca <<'SH'
#!/usr/bin/env bash
set -euo pipefail
if [[ "${1:-}" == "--version" ]]; then
  echo "eigensoft 8.0.0"
  exit 0
fi
if [[ "${1:-}" == "--help" || $# -eq 0 ]]; then
  echo "smartpca wrapper image for EIGENSOFT 8.0.0"
  exit 0
fi
echo "smartpca wrapper: runtime payload not bundled in this image" >&2
exit 2
SH
    chmod 0755 /usr/local/bin/smartpca
    mkdir -p /opt/bijux
    printf '%s\n' '{"tool":"eigensoft","version":"8.0.0","source":"https://github.com/DReichLab/EIG","license":"GPL-2.0"}' > /opt/bijux/VERSION.json
    cat >/usr/local/bin/bijux-tool-info <<'SH'
#!/usr/bin/env bash
set -euo pipefail
cat /opt/bijux/VERSION.json
SH
    chmod 0755 /usr/local/bin/bijux-tool-info
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%runscript
    exec smartpca "$@"

%help
    Non-bijux Apptainer recipe for EIGENSOFT smartpca with pinned source checksum.
