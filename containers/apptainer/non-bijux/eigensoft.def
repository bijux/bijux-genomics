Bootstrap: docker
From: ubuntu:24.04@sha256:cd1dba651b3080c3686ecf4e3c4220f026b521fb76978881737d24f200828b2b

%labels
    org.opencontainers.image.source https://github.com/DReichLab/EIG
    org.opencontainers.image.revision v8.0.0
    org.opencontainers.image.created 2026-02-13T00:00:00Z
    org.opencontainers.image.licenses GPL-2.0
    org.opencontainers.image.version 8.0.0
    org.opencontainers.image.tool eigensoft
    org.opencontainers.image.title eigensoft

%environment
    DEBIAN_FRONTEND=noninteractive

%post
    export DEBIAN_FRONTEND=noninteractive
    apt-get update -qq
    apt-get install -y --no-install-recommends ca-certificates curl make g++ zlib1g-dev
    curl -fsSL -o /tmp/eigensoft.tar.gz https://github.com/DReichLab/EIG/archive/refs/tags/v8.0.0.tar.gz
    echo "fbe67c1ff5eb3487bb0fb74b24166b618b7f92c72f0c6f369f7bc0f8ceeb4ed9  /tmp/eigensoft.tar.gz" | sha256sum -c -
    tar -xzf /tmp/eigensoft.tar.gz -C /tmp
    make -C /tmp/EIG-8.0.0/src
    install -m 0755 /tmp/EIG-8.0.0/bin/smartpca /usr/local/bin/smartpca
    mkdir -p /opt/bijux
    printf '%s\n' '{"tool":"eigensoft","version":"8.0.0","source":"https://github.com/DReichLab/EIG","license":"GPL-2.0"}' > /opt/bijux/VERSION.json
    rm -rf /tmp/eigensoft.tar.gz /tmp/EIG-8.0.0
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%runscript
    exec smartpca "$@"

%help
    Non-bijux Apptainer recipe for EIGENSOFT smartpca with pinned source checksum.
