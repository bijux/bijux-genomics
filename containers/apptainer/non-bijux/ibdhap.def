# VERSION_SOURCE: containers/versions/versions.toml
Bootstrap: docker
From: ubuntu:24.04@sha256:cd1dba651b3080c3686ecf4e3c4220f026b521fb76978881737d24f200828b2b

%labels
# Tool ID: ibdhap
# Version policy: pinned_or_registry_locked
# Upstream source: see org.opencontainers.image.source label
# Build date policy: org.opencontainers.image.created set by release pipeline
# Network source policy: NETWORK_SOURCE_VERIFIED_BY_LOCK
# Runtime UID policy: RUNTIME_UID_SAFE

    org.opencontainers.image.source https://example.invalid/ibdhap
    org.opencontainers.image.revision planned-0.1.0
    org.opencontainers.image.created 2026-02-13T00:00:00Z
    org.opencontainers.image.licenses unknown
    org.opencontainers.image.version 0.1.0-planned
    org.opencontainers.image.tool ibdhap
    org.opencontainers.image.title ibdhap

%environment
    export PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
    export LC_ALL=C
    export TZ=UTC
    DEBIAN_FRONTEND=noninteractive

%post
    set -eux
    umask 022
    export DEBIAN_FRONTEND=noninteractive
    apt-get update -qq
    apt-get install -y --no-install-recommends ca-certificates
    cat >/usr/local/bin/ibdhap <<'SH'
#!/usr/bin/env bash
set -euo pipefail
if [[ "${1:-}" == "--version" ]]; then
  echo "ibdhap 0.1.0-planned"
  exit 0
fi
if [[ "${1:-}" == "--help" ]]; then
  echo "ibdhap planned wrapper; upstream integration pending."
  exit 0
fi
echo "ibdhap: planned wrapper (no upstream binary integrated yet)" >&2
exit 2
SH
    chmod 0755 /usr/local/bin/ibdhap
    mkdir -p /opt/bijux
    printf '%s\n' '{"tool":"ibdhap","version":"0.1.0-planned","source":"https://example.invalid/ibdhap","license":"unknown"}' > /opt/bijux/VERSION.json
    cat >/usr/local/bin/bijux-tool-info <<'SH'
#!/usr/bin/env bash
set -euo pipefail
cat /opt/bijux/VERSION.json
SH
    chmod 0755 /usr/local/bin/bijux-tool-info
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%runscript
    exec ibdhap "$@"

%help
    Non-bijux placeholder recipe for planned ibdhap integration.
