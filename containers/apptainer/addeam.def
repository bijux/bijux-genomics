Bootstrap: docker
From: ubuntu:24.04@sha256:cd1dba651b3080c3686ecf4e3c4220f026b521fb76978881737d24f200828b2b

%labels
    org.opencontainers.image.source https://github.com/bijux/bijux-dna
    org.opencontainers.image.revision unknown
    org.opencontainers.image.created unknown
    org.opencontainers.image.licenses GPL-3.0
    org.opencontainers.image.version latest-pinned

%post
    export DEBIAN_FRONTEND=noninteractive
    apt-get update -qq && apt-get install -y --no-install-recommends \
        git python3 python3-pip ca-certificates && \
        rm -rf /var/lib/apt/lists/*

    git clone --depth 1 https://github.com/LouisPwr/AdDeam.git /opt/AdDeam
    cd /opt/AdDeam
    git checkout f1dd2a5e530975cab1df48e47a1d51ea76bf183a
    pip3 install --no-cache-dir .

    cat > /usr/local/bin/addeam <<'SH'
#!/bin/sh
set -eu
if [ "${1:-}" = "--version" ]; then
  python3 -c 'import importlib.metadata as m; print(m.version("addeam"))' || echo "unknown"
  exit 0
fi
exec python3 -m addeam "$@"
SH
    chmod +x /usr/local/bin/addeam

%runscript
    exec /usr/local/bin/addeam "$@"

%help
    Apptainer image for AdDeam.
    Default runscript forwards arguments to addeam.
