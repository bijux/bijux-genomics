# BIJUX_TEMPLATE: v1

# Tool ID: adapterremoval
# Version policy: pinned_or_registry_locked
# Upstream source: see org.opencontainers.image.source label
# Build date policy: org.opencontainers.image.created set by release pipeline
# Network source policy: NETWORK_SOURCE_VERIFIED_BY_LOCK
# Runtime UID policy: RUNTIME_UID_SAFE

# VERSION_SOURCE: containers/versions/versions.toml
Bootstrap: docker
From: ubuntu:24.04@sha256:cd1dba651b3080c3686ecf4e3c4220f026b521fb76978881737d24f200828b2b

%labels
    MAINTAINER Bijan Mousavi <mousavi.bijan@gmail.com>
    VERSION AdapterRemoval-v2.3.3

    org.opencontainers.image.source https://github.com/bijux/bijux-dna
    org.opencontainers.image.revision unknown
    org.opencontainers.image.created unknown
    org.opencontainers.image.licenses GPL-3.0
    org.opencontainers.image.version 0.0.0
    org.opencontainers.image.tool adapterremoval
    org.opencontainers.image.title adapterremoval
%environment
    export PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
    export LC_ALL=C
    export TZ=UTC
    DEBIAN_FRONTEND=noninteractive

%post
    set -eux
    umask 022
    export DEBIAN_FRONTEND=noninteractive

    apt-get update && \
    apt-get install -y --no-install-recommends \
        ca-certificates git build-essential zlib1g-dev libbz2-dev && \

    ADAPTERREMOVAL_VERSION=2.3.3 && \

    for i in 1 2 3; do \
        git clone https://github.com/MikkelSchubert/adapterremoval.git /opt/adapterremoval && break || \
        echo "Git clone attempt $i failed, retrying..." && sleep 5; \
    done || { echo "Failed to clone AdapterRemoval repository after 3 attempts"; exit 1; } && \

    cd /opt/adapterremoval && \
    git checkout 54bc0d6ffbbbc81ce60dc227e8ddd8e56ddf1501 && \
    make && \
    mv build/AdapterRemoval /usr/local/bin/adapterremoval-bin && \
    rm -rf /opt/adapterremoval && \

    # Create a wrapper script.
    printf '#!/bin/sh\nexec /usr/local/bin/adapterremoval-bin "$@"\n' > /usr/local/bin/adapterremoval && \
    chmod +x /usr/local/bin/adapterremoval && \

    rm -rf /var/lib/apt/lists/*

%runscript
    if [ $# -eq 0 ]; then
        exec /usr/local/bin/adapterremoval --help
    else
        exec /usr/local/bin/adapterremoval "$@"
    fi

%help
    This Apptainer image provides AdapterRemoval version 2.3.3.
    Run with arguments to execute the tool, or without arguments to display help.
