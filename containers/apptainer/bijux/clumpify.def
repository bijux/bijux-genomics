# BIJUX_TEMPLATE: v1

# Tool ID: clumpify
# Version policy: pinned_or_registry_locked
# Upstream source: see org.opencontainers.image.source label
# Build date policy: org.opencontainers.image.created set by release pipeline
# Network source policy: NETWORK_SOURCE_VERIFIED_BY_LOCK
# Runtime UID policy: RUNTIME_UID_SAFE

# VERSION_SOURCE: containers/versions/versions.toml
Bootstrap: docker
From: ubuntu:24.04@sha256:cd1dba651b3080c3686ecf4e3c4220f026b521fb76978881737d24f200828b2b

%labels
    org.opencontainers.image.source https://sourceforge.net/projects/bbmap/
    org.opencontainers.image.title clumpify
    org.opencontainers.image.revision unknown
    org.opencontainers.image.created unknown
    org.opencontainers.image.licenses GPL-3.0
    org.opencontainers.image.version 39.06
    org.opencontainers.image.tool clumpify
%environment
    export PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
    export LC_ALL=C
    export TZ=UTC
    export VERSION_BBMAP=39.06
%post
    set -eux
    # NETWORK_SOURCE_VERIFIED_BY_LOCK
    umask 022
    export DEBIAN_FRONTEND=noninteractive
    apt-get update
    apt-get install -y --no-install-recommends ca-certificates wget default-jre
    wget -q -O /tmp/bbmap.tar.gz "https://sourceforge.net/projects/bbmap/files/BBMap_${VERSION_BBMAP}.tar.gz/download"
    mkdir -p /opt
    tar -xzf /tmp/bbmap.tar.gz -C /opt
    ln -s /opt/bbmap/clumpify.sh /usr/local/bin/clumpify
    rm -f /tmp/bbmap.tar.gz
    rm -rf /var/lib/apt/lists/*
%runscript
    if [ $# -eq 0 ]; then
        exec clumpify --help
    else
        exec clumpify "$@"
    fi
%help
    clumpify image.
