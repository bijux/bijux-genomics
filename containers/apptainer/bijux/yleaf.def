# BIJUX_TEMPLATE: v1

# Tool ID: yleaf
# Version policy: pinned_or_registry_locked
# Upstream source: see org.opencontainers.image.source label
# Build date policy: org.opencontainers.image.created set by release pipeline
# Network source policy: NETWORK_SOURCE_VERIFIED_BY_LOCK
# Runtime UID policy: RUNTIME_UID_SAFE

# VERSION_SOURCE: containers/versions/versions.toml
Bootstrap: docker
From: ubuntu:24.04@sha256:cd1dba651b3080c3686ecf4e3c4220f026b521fb76978881737d24f200828b2b

%labels
    VERSION unknown
    org.opencontainers.image.source https://github.com/bijux/bijux-dna
    org.opencontainers.image.revision unknown
    org.opencontainers.image.created unknown
    org.opencontainers.image.licenses GPL-3.0
    org.opencontainers.image.version 3.0.3
    org.opencontainers.image.tool yleaf
    org.opencontainers.image.title yleaf

%environment
    export PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
    export LC_ALL=C
    export TZ=UTC
    DEBIAN_FRONTEND=noninteractive

%post
    set -eux
    umask 022
    export DEBIAN_FRONTEND=noninteractive
    apt-get update -qq && apt-get install -y --no-install-recommends         python3 python3-pip python3-venv git ca-certificates &&         rm -rf /var/lib/apt/lists/*

    git clone --depth 1 https://github.com/genid/Yleaf.git /opt/yleaf
    cd /opt/yleaf
    git checkout f3aae50653cb685a7c3d6e4c08aa170c47a85263
    python3 -m pip install --break-system-packages --no-cache-dir .

    cat > /usr/local/bin/yleaf <<'EOS'
#!/usr/bin/env sh
case "${1:-}" in
  --version) yleaf --version; exit 0 ;;
  --help|-h|"") yleaf --help; exit 0 ;;
esac
exec yleaf "$@"
EOS
    chmod +x /usr/local/bin/yleaf

%runscript
    exec /usr/local/bin/yleaf "$@"

%help
    Apptainer image for yleaf.
    Default runscript forwards arguments to the tool entrypoint.
