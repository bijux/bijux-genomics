# The bijux-dna software source code is licensed under Apache-2.0.
# Copyright (C) 2026 Bijan Mousavi
# BIJUX_TEMPLATE: v1

# Tool ID: alientrimmer
# Version policy: pinned_or_registry_locked
# Upstream source: see org.opencontainers.image.source label
# Build date policy: org.opencontainers.image.created set by release pipeline
# Network source policy: NETWORK_SOURCE_VERIFIED_BY_LOCK
# Runtime UID policy: RUNTIME_UID_SAFE

# VERSION_SOURCE: containers/versions/versions.toml
Bootstrap: docker
From: ubuntu:24.04@sha256:cd1dba651b3080c3686ecf4e3c4220f026b521fb76978881737d24f200828b2b

%labels
    VERSION unknown
    org.opencontainers.image.source https://github.com/bijux/bijux-dna
    org.opencontainers.image.revision unknown
    org.opencontainers.image.created unknown
    org.opencontainers.image.licenses GPL-3.0
    org.opencontainers.image.version 0.4.0
    org.opencontainers.image.tool alientrimmer
    org.opencontainers.image.title alientrimmer
%environment
    export PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
    export LC_ALL=C
    export TZ=UTC
    DEBIAN_FRONTEND=noninteractive

%post
    set -eux
    umask 022
    cat > /usr/local/bin/alientrimmer <<'SH'
#!/bin/sh
set -eu
if [ "${1:-}" = "--version" ]; then
  echo "AlienTrimmer 0.4.0"
  exit 0
fi
if [ "${1:-}" = "--help" ] || [ $# -eq 0 ]; then
  echo "AlienTrimmer wrapper. Upstream source: https://gite.lirmm.fr/clegrand/AlienTrimmer"
  exit 0
fi
echo "AlienTrimmer binary not bundled; use help/version in this pre-HPC registry peer image." >&2
exit 2
SH
    chmod +x /usr/local/bin/alientrimmer

%runscript
    exec /usr/local/bin/alientrimmer "$@"

%help
    Apptainer image for AlienTrimmer wrapper.
