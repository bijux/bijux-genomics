# BIJUX_TEMPLATE: v1

# Tool ID: bbmerge
# Version policy: pinned_or_registry_locked
# Upstream source: see org.opencontainers.image.source label
# Build date policy: org.opencontainers.image.created set by release pipeline
# Network source policy: NETWORK_SOURCE_VERIFIED_BY_LOCK
# Runtime UID policy: RUNTIME_UID_SAFE

# VERSION_SOURCE: containers/versions/versions.toml
Bootstrap: docker
From: ubuntu:24.04@sha256:cd1dba651b3080c3686ecf4e3c4220f026b521fb76978881737d24f200828b2b

%labels
    MAINTAINER Bijan Mousavi <mousavi.bijan@gmail.com>
    VERSION BBMerge-v39.06

    org.opencontainers.image.source https://github.com/bijux/bijux-dna
    org.opencontainers.image.revision unknown
    org.opencontainers.image.created unknown
    org.opencontainers.image.licenses GPL-3.0
    org.opencontainers.image.version 0.0.0
    org.opencontainers.image.tool bbmerge
    org.opencontainers.image.title bbmerge
%environment
    export PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
    export LC_ALL=C
    export TZ=UTC
    DEBIAN_FRONTEND=noninteractive

%post
    set -eux
    umask 022
    export DEBIAN_FRONTEND=noninteractive

    apt-get update && \
    apt-get install -y --no-install-recommends \
        curl ca-certificates openjdk-17-jre-headless && \

    curl -fsSL "https://downloads.sourceforge.net/project/bbmap/BBMap_39.06.tar.gz?download" -o /tmp/bbmap.tar.gz && \
    tar -xzf /tmp/bbmap.tar.gz -C /opt && \
    rm -f /tmp/bbmap.tar.gz

    # Create a wrapper script with special handling for --version.
    cat > /usr/local/bin/bbmerge <<'EOF'
#!/bin/sh
if [ "$1" = "--version" ]; then
    echo "39.06"
else
    /opt/bbmap/bbmerge.sh "$@"
fi
EOF
    chmod +x /usr/local/bin/bbmerge
    rm -rf /var/lib/apt/lists/*

%runscript
    if [ $# -eq 0 ]; then
        exec /usr/local/bin/bbmerge --help
    else
        exec /usr/local/bin/bbmerge "$@"
    fi

%help
    This Apptainer image provides BBMerge (part of BBMap version 39.06).
    Run with arguments to execute bbmerge.sh, or without arguments to display help.
    The wrapper handles --version by redirecting output for consistency.
