# BIJUX_TEMPLATE: v1

# Tool ID: spades
# Version policy: pinned_or_registry_locked
# Upstream source: see org.opencontainers.image.source label
# Build date policy: org.opencontainers.image.created set by release pipeline
# Network source policy: NETWORK_SOURCE_VERIFIED_BY_LOCK
# Runtime UID policy: RUNTIME_UID_SAFE

# VERSION_SOURCE: containers/versions/versions.toml
Bootstrap: docker
From: ubuntu:24.04@sha256:cd1dba651b3080c3686ecf4e3c4220f026b521fb76978881737d24f200828b2b

%labels
    MAINTAINER Bijan Mousavi <mousavi.bijan@gmail.com>
    VERSION spades-4.2.0
    org.opencontainers.image.source https://github.com/ablab/spades
    org.opencontainers.image.title SPAdes
    org.opencontainers.image.licenses Apache-2.0

    org.opencontainers.image.source https://github.com/bijux/bijux-dna
    org.opencontainers.image.revision unknown
    org.opencontainers.image.created unknown
    org.opencontainers.image.licenses GPL-3.0
    org.opencontainers.image.version 0.0.0
    org.opencontainers.image.tool spades
%environment
    export PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
    export LC_ALL=C
    DEBIAN_FRONTEND=noninteractive
    TZ=UTC
    export VERSION_SPADES=4.2.0

%post
    set -eux
    umask 022
    export DEBIAN_FRONTEND=noninteractive

    # Section 1: Install runtime dependencies.
    apt-get update
    apt-get install -y --no-install-recommends \
        wget \
        python3 \
        ca-certificates \
        grep

    # Section 2: Fetch prebuilt SPAdes release.
    cd /tmp
    wget -q -O spades.tar.gz \
      "https://github.com/ablab/spades/releases/download/v4.2.0/SPAdes-4.2.0-Linux.tar.gz"

    mkdir -p /opt
    tar -xzf spades.tar.gz -C /opt

    # Section 3: Install binaries and shared assets.
    cp -r /opt/SPAdes-4.2.0-Linux/bin/* /usr/local/bin/
    ln -sf spades.py /usr/local/bin/spades
    mkdir -p /usr/local/share
    cp -r /opt/SPAdes-4.2.0-Linux/share/spades /usr/local/share/

    # Section 4: Run sanity checks and fail on version mismatch.
    /usr/local/bin/spades --version | grep -q "4.2.0"

    # Section 5: Create a BayesHammer wrapper with a uniform CLI.
    cat > /usr/local/bin/bayeshammer <<'EOF'
#!/usr/bin/env bash
set -euo pipefail

case "${1:-}" in
  --version)
    exec spades --version
    ;;
  --help|-h|"")
    exec spades --only-error-correction --help
    ;;
esac

exec spades --only-error-correction "$@"
EOF
    chmod 0755 /usr/local/bin/bayeshammer

    # Section 6: Clean up build tree.
    cd /
    rm -rf /opt/SPAdes-4.2.0-Linux /tmp/spades.tar.gz

    rm -rf /var/lib/apt/lists/*

%runscript
    if [ $# -eq 0 ]; then
        exec spades.py --help
    else
        exec spades.py "$@"
    fi

%help
    This Apptainer image provides SPAdes v4.2.0 built from source on Ubuntu 24.04.

    Main entry:
      - spades.py  (also symlinked as 'spades')

    Extra wrapper:
      - bayeshammer  (runs: spades --only-error-correction)

    Installs SPAdes helpers from bin/ and data assets under /usr/local/share/spades.
