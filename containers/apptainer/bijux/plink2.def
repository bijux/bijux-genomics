Bootstrap: docker
From: ubuntu:24.04@sha256:cd1dba651b3080c3686ecf4e3c4220f026b521fb76978881737d24f200828b2b

%labels
    VERSION unknown
    org.opencontainers.image.source https://github.com/bijux/bijux-dna
    org.opencontainers.image.revision unknown
    org.opencontainers.image.created unknown
    org.opencontainers.image.licenses GPL-3.0
    org.opencontainers.image.version 2.00a5
    org.opencontainers.image.tool plink2
    org.opencontainers.image.title plink2

%environment
    DEBIAN_FRONTEND=noninteractive

%post
    export DEBIAN_FRONTEND=noninteractive
    apt-get update -qq
    apt-get install -y --no-install-recommends ca-certificates curl unzip
    curl -fsSL -o /tmp/plink2.zip https://s3.amazonaws.com/plink2-assets/alpha6/plink2_linux_x86_64_20240105.zip
    echo "e73d87c395f6eb0f0b2f513f67d55bdb37f8f948d26554f9e4537806e96ca2ec  /tmp/plink2.zip" | sha256sum -c -
    unzip -q /tmp/plink2.zip -d /opt/plink2
    install -m 0755 /opt/plink2/plink2 /usr/local/bin/plink2
    rm -rf /tmp/plink2.zip /opt/plink2
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%runscript
    exec plink2 "$@"

%help
    Apptainer image for plink2 with pinned archive checksum verification.
