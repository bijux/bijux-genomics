# BIJUX_TEMPLATE: v1

# Tool ID: mapdamage2
# Version policy: pinned_or_registry_locked
# Upstream source: see org.opencontainers.image.source label
# Build date policy: org.opencontainers.image.created set by release pipeline
# Network source policy: NETWORK_SOURCE_VERIFIED_BY_LOCK
# Runtime UID policy: RUNTIME_UID_SAFE

Bootstrap: docker
From: ubuntu:24.04@sha256:cd1dba651b3080c3686ecf4e3c4220f026b521fb76978881737d24f200828b2b

%labels
    VERSION unknown
    org.opencontainers.image.source https://github.com/bijux/bijux-dna
    org.opencontainers.image.revision unknown
    org.opencontainers.image.created unknown
    org.opencontainers.image.licenses GPL-3.0
    org.opencontainers.image.version 2.2.2
    org.opencontainers.image.tool mapdamage2
    org.opencontainers.image.title mapdamage2

%environment
    export PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
    export LC_ALL=C
    export TZ=UTC
    DEBIAN_FRONTEND=noninteractive

%post
    set -eux
    umask 022
    export DEBIAN_FRONTEND=noninteractive
    apt-get update -qq && apt-get install -y --no-install-recommends \
        python3 python3-dev python3-pip python3-venv git build-essential ca-certificates && \
        rm -rf /var/lib/apt/lists/*

    git clone --depth 1 https://github.com/ginolhac/mapDamage.git /opt/mapdamage2
    cd /opt/mapdamage2
    git checkout 484bb3094de69422c2308385aa2bfaf0ef12fa27
    python3 -m pip install --break-system-packages --no-cache-dir .

    cat > /usr/local/bin/mapdamage2 <<'EOS'
#!/usr/bin/env sh
case "${1:-}" in
  --version) mapDamage --version; exit 0 ;;
  --help|-h|"") mapDamage --help; exit 0 ;;
esac
exec mapDamage "$@"
EOS
    chmod +x /usr/local/bin/mapdamage2

%runscript
    exec /usr/local/bin/mapdamage2 "$@"

%help
    Apptainer image for mapdamage2.
    Default runscript forwards arguments to the tool entrypoint.
