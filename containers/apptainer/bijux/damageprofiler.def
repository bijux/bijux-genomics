Bootstrap: docker
From: ubuntu:24.04@sha256:cd1dba651b3080c3686ecf4e3c4220f026b521fb76978881737d24f200828b2b

%labels
    VERSION unknown
    org.opencontainers.image.source https://github.com/bijux/bijux-dna
    org.opencontainers.image.revision unknown
    org.opencontainers.image.created unknown
    org.opencontainers.image.licenses GPL-3.0
    org.opencontainers.image.version latest-pinned
    org.opencontainers.image.tool damageprofiler
    org.opencontainers.image.title damageprofiler
%environment
    DEBIAN_FRONTEND=noninteractive

%post
    export DEBIAN_FRONTEND=noninteractive
    apt-get update -qq && apt-get install -y --no-install-recommends \
        wget openjdk-17-jre-headless ca-certificates && \
        rm -rf /var/lib/apt/lists/*
    wget -q -O /opt/damageprofiler.jar \
      "https://github.com/Integrative-Transcriptomics/DamageProfiler/releases/download/v1.1/DamageProfiler-1.1-java11.jar"
    cat > /usr/local/bin/damageprofiler <<'SH'
#!/bin/sh
set -eu
exec java -jar /opt/damageprofiler.jar "$@"
SH
    chmod +x /usr/local/bin/damageprofiler

%runscript
    exec /usr/local/bin/damageprofiler "$@"

%help
    Apptainer image for DamageProfiler.
