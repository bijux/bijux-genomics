# BIJUX_TEMPLATE: v1

# Tool ID: fastq_screen
# Version policy: pinned_or_registry_locked
# Upstream source: see org.opencontainers.image.source label
# Build date policy: org.opencontainers.image.created set by release pipeline
# Network source policy: NETWORK_SOURCE_VERIFIED_BY_LOCK
# Runtime UID policy: RUNTIME_UID_SAFE

Bootstrap: docker
From: ubuntu:24.04@sha256:cd1dba651b3080c3686ecf4e3c4220f026b521fb76978881737d24f200828b2b

%labels
    MAINTAINER Bijan Mousavi <mousavi.bijan@gmail.com>
    VERSION FastQ-Screen-v0.15.3
    org.opencontainers.image.source https://www.bioinformatics.babraham.ac.uk/projects/fastq_screen/

    org.opencontainers.image.source https://github.com/bijux/bijux-dna
    org.opencontainers.image.revision unknown
    org.opencontainers.image.created unknown
    org.opencontainers.image.licenses GPL-3.0
    org.opencontainers.image.version 0.15.3
    org.opencontainers.image.tool fastq_screen
    org.opencontainers.image.title fastq_screen
%environment
    export PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
    export LC_ALL=C
    export TZ=UTC
    DEBIAN_FRONTEND=noninteractive

%post
    set -eux
    export DEBIAN_FRONTEND=noninteractive

    apt-get update -qq && \
    apt-get install -y --no-install-recommends \
        perl \
        curl \
        ca-certificates \
        bzip2 \
        gzip && \

    mkdir -p /opt && \
    cd /opt && \
    curl -fsSL -o fastq_screen.tar.gz \
        "https://github.com/StevenWingett/FastQ-Screen/archive/refs/tags/v0.15.3.tar.gz" && \
    tar -xzf fastq_screen.tar.gz && \
    mv FastQ-Screen-0.15.3 fastq_screen && \
    ln -s /opt/fastq_screen/fastq_screen /usr/local/bin/fastq_screen && \

    rm fastq_screen.tar.gz && \
    rm -rf /var/lib/apt/lists/*

%runscript
    if [ $# -eq 0 ]; then
        exec /usr/local/bin/fastq_screen --help
    else
        exec /usr/local/bin/fastq_screen "$@"
    fi

%help
    This Apptainer image provides FastQ Screen version 0.15.3.
    Run with arguments to execute fastq_screen, or without arguments to display help.
    Note: External aligners (Bowtie2, BWA, or similar) are required for screening and must be available in the runtime environment.
