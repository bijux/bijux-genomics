# BIJUX_TEMPLATE: v1

# Tool ID: rxy
# Version policy: pinned_or_registry_locked
# Upstream source: see org.opencontainers.image.source label
# Build date policy: org.opencontainers.image.created set by release pipeline
# Network source policy: NETWORK_SOURCE_VERIFIED_BY_LOCK
# Runtime UID policy: RUNTIME_UID_SAFE

Bootstrap: docker
From: ubuntu:24.04@sha256:cd1dba651b3080c3686ecf4e3c4220f026b521fb76978881737d24f200828b2b

%labels
    VERSION unknown
    org.opencontainers.image.source https://github.com/bijux/bijux-dna
    org.opencontainers.image.revision unknown
    org.opencontainers.image.created unknown
    org.opencontainers.image.licenses GPL-3.0
    org.opencontainers.image.version 1.0.0
    org.opencontainers.image.tool rxy
    org.opencontainers.image.title rxy

%environment
    export PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
    export LC_ALL=C
    export TZ=UTC
    DEBIAN_FRONTEND=noninteractive

%post
    set -eux
    umask 022
    export DEBIAN_FRONTEND=noninteractive
    apt-get update -qq && apt-get install -y --no-install-recommends samtools awk ca-certificates && rm -rf /var/lib/apt/lists/*
    cat > /usr/local/bin/rxy <<'EOS'
#!/usr/bin/env sh
set -eu
if [ "${1:-}" = "--version" ]; then
  echo "1.0.0"
  exit 0
fi
if [ "${1:-}" = "--help" ] || [ $# -eq 0 ]; then
  echo "usage: rxy <alignment.bam>"
  echo "computes simple RX/RY ratio from samtools idxstats"
  exit 0
fi
bam="$1"
idx="$(samtools idxstats "$bam")"
rx=$(printf '%s\n' "$idx" | awk '$1=="chrX" || $1=="X" {s+=$3} END{print s+0}')
ry=$(printf '%s\n' "$idx" | awk '$1=="chrY" || $1=="Y" {s+=$3} END{print s+0}')
printf 'RX=%s\nRY=%s\nRXY=%s\n' "$rx" "$ry" "$(awk -v x="$rx" -v y="$ry" 'BEGIN{if(y==0){print "inf"} else {printf "%.6f", x/y}}')"
EOS
    chmod +x /usr/local/bin/rxy

%runscript
    exec /usr/local/bin/rxy "$@"

%help
    Apptainer image for rxy.
    Default runscript forwards arguments to the tool entrypoint.
