# BIJUX_TEMPLATE: v1

# Tool ID: vsearch
# Version policy: pinned_or_registry_locked
# Upstream source: see org.opencontainers.image.source label
# Build date policy: org.opencontainers.image.created set by release pipeline
# Network source policy: NETWORK_SOURCE_VERIFIED_BY_LOCK
# Runtime UID policy: RUNTIME_UID_SAFE

# VERSION_SOURCE: containers/versions/versions.toml
Bootstrap: docker
From: ubuntu:24.04@sha256:cd1dba651b3080c3686ecf4e3c4220f026b521fb76978881737d24f200828b2b

%labels
    MAINTAINER Bijan Mousavi <mousavi.bijan@gmail.com>
    VERSION vsearch-2.28.1
    org.opencontainers.image.source https://github.com/torognes/vsearch
    org.opencontainers.image.title vsearch
    org.opencontainers.image.licenses Apache-2.0

    org.opencontainers.image.source https://github.com/bijux/bijux-dna
    org.opencontainers.image.revision unknown
    org.opencontainers.image.created unknown
    org.opencontainers.image.licenses GPL-3.0
    org.opencontainers.image.version 0.0.0
    org.opencontainers.image.tool vsearch
%environment
    export PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
    export LC_ALL=C
    DEBIAN_FRONTEND=noninteractive
    TZ=UTC
    VERSION_VSEARCH=2.28.1

%post
    set -eux
    umask 022
    export DEBIAN_FRONTEND=noninteractive

    apt-get update
    apt-get install -y --no-install-recommends \
        wget \
        ca-certificates \
        build-essential \
        git \
        autoconf \
        automake \
        libtool \
        pkg-config \
        zlib1g-dev \
        libbz2-dev \
        liblzma-dev

    # Fetch source at the requested tag (with retries)
    for i in 1 2 3; do \
        git clone --depth 1 --branch "v2.28.1" https://github.com/torognes/vsearch.git /tmp/vsearch-src && cd /tmp/vsearch-src && git checkout d98284e5015d5afce61427c4b6420653c7700650 && cd - >/dev/null && break || \
        echo "Git clone attempt $i failed, retrying..." && sleep 5; \
    done || { echo "Failed to clone vsearch after 3 attempts"; exit 1; }

    cd /tmp/vsearch-src
    ./autogen.sh
    ./configure --quiet CFLAGS="-O3"
    make -j"$(nproc)"

    # Install binary
    install -m 0755 ./bin/vsearch /usr/local/bin/vsearch-bin
    strip /usr/local/bin/vsearch-bin || true

    # Wrapper: unified execution + stable --version / --help behavior
    cat > /usr/local/bin/vsearch <<'EOF'
#!/usr/bin/env sh
set -eu

case "${1:-}" in
  --version)
    echo "${VERSION_VSEARCH}"
    exit 0
    ;;
  --help|-h|"")
    exec /usr/local/bin/vsearch-bin --help
    ;;
esac

exec /usr/local/bin/vsearch-bin "$@"
EOF
    chmod 0755 /usr/local/bin/vsearch

    # Clean up the build tree. (avoid Docker-style aggressive purges that break Apptainer)
    cd /
    rm -rf /tmp/vsearch-src
    rm -rf /var/lib/apt/lists/*

%runscript
    if [ $# -eq 0 ]; then
        exec vsearch --help
    else
        exec vsearch "$@"
    fi

%help
    This Apptainer image provides VSEARCH v2.28.1 built from source on Ubuntu 24.04.
    Wrapper: 'vsearch' (stable --version and --help behavior)
    Underlying binary: 'vsearch-bin'
