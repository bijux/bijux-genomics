# BIJUX_TEMPLATE: v1

# Tool ID: flash2
# Version policy: pinned_or_registry_locked
# Upstream source: see org.opencontainers.image.source label
# Build date policy: org.opencontainers.image.created set by release pipeline
# Network source policy: NETWORK_SOURCE_VERIFIED_BY_LOCK
# Runtime UID policy: RUNTIME_UID_SAFE

Bootstrap: docker
From: ubuntu:24.04@sha256:cd1dba651b3080c3686ecf4e3c4220f026b521fb76978881737d24f200828b2b

%labels
    MAINTAINER Bijan Mousavi <mousavi.bijan@gmail.com>
    VERSION FLASH2-v2.2.00
    org.opencontainers.image.source https://github.com/dstreett/FLASH2

    org.opencontainers.image.source https://github.com/bijux/bijux-dna
    org.opencontainers.image.revision unknown
    org.opencontainers.image.created unknown
    org.opencontainers.image.licenses GPL-3.0
    org.opencontainers.image.version 2.2.00
    org.opencontainers.image.tool flash2
    org.opencontainers.image.title flash2
%environment
    export PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
    export LC_ALL=C
    export TZ=UTC
    DEBIAN_FRONTEND=noninteractive

%post
    set -eux
    umask 022
    export DEBIAN_FRONTEND=noninteractive

    apt-get update && \
    apt-get install -y --no-install-recommends \
        build-essential zlib1g-dev git ca-certificates && \

    git clone https://github.com/dstreett/FLASH2.git /opt/FLASH2 && \
    cd /opt/FLASH2 && \
    git checkout 64826f4574b11b3c0ae7460826f30be16f49c3ea && \
    make -j$(nproc) && \
    cp flash2 /usr/local/bin/flash2 && \

    cd / && \
    rm -rf /opt/FLASH2 && \
    rm -rf /var/lib/apt/lists/*

%runscript
    if [ $# -eq 0 ]; then
        exec /usr/local/bin/flash2 --help
    else
        exec /usr/local/bin/flash2 "$@"
    fi

%help
    This Apptainer image provides FLASH2 version 2.2.00, compiled from source.
    Run with arguments to execute flash2, or without arguments to display detailed help.
