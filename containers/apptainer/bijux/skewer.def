Bootstrap: docker
From: ubuntu:24.04@sha256:cd1dba651b3080c3686ecf4e3c4220f026b521fb76978881737d24f200828b2b

%labels
    VERSION unknown
    org.opencontainers.image.source https://github.com/bijux/bijux-dna
    org.opencontainers.image.revision unknown
    org.opencontainers.image.created unknown
    org.opencontainers.image.licenses GPL-3.0
    org.opencontainers.image.version latest-pinned
    org.opencontainers.image.tool skewer
    org.opencontainers.image.title skewer
%environment
    DEBIAN_FRONTEND=noninteractive

%post
    export DEBIAN_FRONTEND=noninteractive
    apt-get update -qq && apt-get install -y --no-install-recommends \
        git build-essential g++-10 zlib1g-dev ca-certificates && \
        rm -rf /var/lib/apt/lists/*
    git clone https://github.com/relipmoc/skewer.git /opt/skewer
    cd /opt/skewer
    git checkout 978e8e46cba44595ece623e5387749284a86b74b
    make CXX=g++-10 -j"$(nproc)"
    cp /opt/skewer/skewer /usr/local/bin/skewer

%runscript
    exec /usr/local/bin/skewer "$@"

%help
    Apptainer image for skewer.
