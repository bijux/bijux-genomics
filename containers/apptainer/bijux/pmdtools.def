# BIJUX_TEMPLATE: v1

# Tool ID: pmdtools
# Version policy: pinned_or_registry_locked
# Upstream source: see org.opencontainers.image.source label
# Build date policy: org.opencontainers.image.created set by release pipeline
# Network source policy: NETWORK_SOURCE_VERIFIED_BY_LOCK
# Runtime UID policy: RUNTIME_UID_SAFE

Bootstrap: docker
From: ubuntu:24.04@sha256:cd1dba651b3080c3686ecf4e3c4220f026b521fb76978881737d24f200828b2b

%labels
    VERSION unknown
    org.opencontainers.image.source https://github.com/bijux/bijux-dna
    org.opencontainers.image.revision unknown
    org.opencontainers.image.created unknown
    org.opencontainers.image.licenses GPL-3.0
    org.opencontainers.image.version 0.60
    org.opencontainers.image.tool pmdtools
    org.opencontainers.image.title pmdtools

%environment
    export PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
    export LC_ALL=C
    export TZ=UTC
    DEBIAN_FRONTEND=noninteractive

%post
    set -eux
    export DEBIAN_FRONTEND=noninteractive
    apt-get update -qq && apt-get install -y --no-install-recommends \
        git python3 ca-certificates && \
        rm -rf /var/lib/apt/lists/*

    git clone --depth 1 https://github.com/pontussk/PMDtools.git /opt/pmdtools
    cd /opt/pmdtools
    git checkout cc91fb8d870eadc4566d0bb3fbbc92fa96cd1363

    cat > /usr/local/bin/pmdtools <<'SH'
#!/bin/sh
set -eu
if [ "${1:-}" = "--version" ]; then
  echo "0.60"
  exit 0
fi
if [ "${1:-}" = "--help" ] || [ $# -eq 0 ]; then
  exec python3 /opt/pmdtools/pmdtools.0.60.py --help
fi
exec python3 /opt/pmdtools/pmdtools.0.60.py "$@"
SH
    chmod +x /usr/local/bin/pmdtools

%runscript
    exec /usr/local/bin/pmdtools "$@"

%help
    Apptainer image for PMDtools.
    Default runscript forwards arguments to pmdtools.
