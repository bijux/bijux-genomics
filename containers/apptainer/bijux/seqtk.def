# BIJUX_TEMPLATE: v1

# Tool ID: seqtk
# Version policy: pinned_or_registry_locked
# Upstream source: see org.opencontainers.image.source label
# Build date policy: org.opencontainers.image.created set by release pipeline
# Network source policy: NETWORK_SOURCE_VERIFIED_BY_LOCK
# Runtime UID policy: RUNTIME_UID_SAFE

Bootstrap: docker
From: ubuntu:24.04@sha256:cd1dba651b3080c3686ecf4e3c4220f026b521fb76978881737d24f200828b2b

%labels
    MAINTAINER Bijan Mousavi <mousavi.bijan@gmail.com>
    VERSION seqtk-1.5-r133
    org.opencontainers.image.source https://github.com/lh3/seqtk
    org.opencontainers.image.title seqtk
    org.opencontainers.image.licenses Apache-2.0

    org.opencontainers.image.source https://github.com/bijux/bijux-dna
    org.opencontainers.image.revision unknown
    org.opencontainers.image.created unknown
    org.opencontainers.image.licenses GPL-3.0
    org.opencontainers.image.version 0.0.0
    org.opencontainers.image.tool seqtk
%environment
    export PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
    export LC_ALL=C
    DEBIAN_FRONTEND=noninteractive
    TZ=UTC
    VERSION_SEQTK=1.5-r133

%post
    set -eux
    umask 022
    export DEBIAN_FRONTEND=noninteractive

    apt-get update
    apt-get install -y --no-install-recommends \
        git \
        ca-certificates \
        build-essential \
        zlib1g-dev

    # Fetch + build
    mkdir -p /opt
    for i in 1 2 3; do \
        git clone https://github.com/lh3/seqtk.git /opt/seqtk && break || \
        echo "Git clone attempt $i failed, retrying..." && sleep 5; \
    done || { echo "Failed to clone seqtk after 3 attempts"; exit 1; }

    cd /opt/seqtk
    git checkout 94e707082d39b0a038f234df676e32d9802c0dc7
    make -j"$(nproc)"

    install -m 0755 ./seqtk /usr/local/bin/seqtk-bin

    # Wrapper: unified execution + stable --version / --help behavior
    cat > /usr/local/bin/seqtk <<'EOF'
#!/usr/bin/env sh
set -eu

case "${1:-}" in
  --version)
    echo "${VERSION_SEQTK}"
    exit 0
    ;;
  --help|-h|"")
    exec /usr/local/bin/seqtk-bin --help
    ;;
esac

exec /usr/local/bin/seqtk-bin "$@"
EOF
    chmod 0755 /usr/local/bin/seqtk

    # Clean up the build tree.
    cd /
    rm -rf /opt/seqtk

    rm -rf /var/lib/apt/lists/*

%runscript
    if [ $# -eq 0 ]; then
        exec seqtk --help
    else
        exec seqtk "$@"
    fi

%help
    This Apptainer image provides Seqtk built from source on Ubuntu 24.04.
    Wrapper: 'seqtk' (stable --version and --help behavior)
    Underlying binary: 'seqtk-bin'
    Upstream: https://github.com/lh3/seqtk
