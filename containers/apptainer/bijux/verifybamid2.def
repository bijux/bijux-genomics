# BIJUX_TEMPLATE: v1

# Tool ID: verifybamid2
# Version policy: pinned_or_registry_locked
# Upstream source: see org.opencontainers.image.source label
# Build date policy: org.opencontainers.image.created set by release pipeline
# Network source policy: NETWORK_SOURCE_VERIFIED_BY_LOCK
# Runtime UID policy: RUNTIME_UID_SAFE

Bootstrap: docker
From: ubuntu:24.04@sha256:cd1dba651b3080c3686ecf4e3c4220f026b521fb76978881737d24f200828b2b

%labels
    VERSION unknown
    org.opencontainers.image.source https://github.com/bijux/bijux-dna
    org.opencontainers.image.revision unknown
    org.opencontainers.image.created unknown
    org.opencontainers.image.licenses GPL-3.0
    org.opencontainers.image.version 2.0.1
    org.opencontainers.image.tool verifybamid2
    org.opencontainers.image.title verifybamid2

%environment
    export PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
    export LC_ALL=C
    export TZ=UTC
    DEBIAN_FRONTEND=noninteractive

%post
    set -eux
    umask 022
    export DEBIAN_FRONTEND=noninteractive
    apt-get update -qq && apt-get install -y --no-install-recommends \
        git build-essential cmake zlib1g-dev libbz2-dev liblzma-dev libcurl4-gnutls-dev libhts-dev \
        ca-certificates && rm -rf /var/lib/apt/lists/*

    git clone --depth 1 https://github.com/Griffan/VerifyBamID.git /opt/VerifyBamID
    cd /opt/VerifyBamID
    git checkout 4b362f5191b8385d038350acc03800890dd66524
    cmake -S . -B build -DCMAKE_BUILD_TYPE=Release
    cmake --build build -j"$(nproc)"
    bin_path="$(find /opt/VerifyBamID -maxdepth 3 -type f -perm -111 -name 'VerifyBamID*' | head -n 1)"
    test -n "$bin_path"
    cp "$bin_path" /usr/local/bin/verifybamid2

%runscript
    exec /usr/local/bin/verifybamid2 "$@"

%help
    Apptainer image for verifybamid2.
    Default runscript forwards arguments to verifybamid2.
