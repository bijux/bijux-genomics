Bootstrap: docker
From: ubuntu:24.04@sha256:cd1dba651b3080c3686ecf4e3c4220f026b521fb76978881737d24f200828b2b

%labels
    org.opencontainers.image.source https://github.com/bijux/bijux-dna
    org.opencontainers.image.revision unknown
    org.opencontainers.image.created unknown
    org.opencontainers.image.licenses GPL-3.0
    org.opencontainers.image.version 2.9
    org.opencontainers.image.tool bracken
    org.opencontainers.image.title bracken

%environment
    DEBIAN_FRONTEND=noninteractive

%post
    export DEBIAN_FRONTEND=noninteractive
    apt-get update -qq && apt-get install -y --no-install-recommends \
        git build-essential python3 ca-certificates && \
        rm -rf /var/lib/apt/lists/*

    git clone https://github.com/jenniferlu717/Bracken.git /opt/bracken
    cd /opt/bracken
    git checkout c5bfec1929fe30feef21afbde67b16bda44de448
    ./install_bracken.sh
    ln -sf /opt/bracken/bracken /usr/local/bin/bracken

%runscript
    exec /usr/local/bin/bracken "$@"

%help
    Apptainer image for Bracken.
    Default runscript forwards arguments to bracken.
