Bootstrap: docker
From: ubuntu:24.04@sha256:cd1dba651b3080c3686ecf4e3c4220f026b521fb76978881737d24f200828b2b

%labels
    VERSION unknown
    org.opencontainers.image.source https://github.com/bijux/bijux-dna
    org.opencontainers.image.revision unknown
    org.opencontainers.image.created unknown
    org.opencontainers.image.licenses GPL-3.0
    org.opencontainers.image.version 0.940
    org.opencontainers.image.tool angsd
    org.opencontainers.image.title angsd

%environment
    DEBIAN_FRONTEND=noninteractive

%post
    export DEBIAN_FRONTEND=noninteractive
    apt-get update -qq && apt-get install -y --no-install-recommends \
        git build-essential zlib1g-dev libbz2-dev liblzma-dev libcurl4-openssl-dev \
        ca-certificates make autoconf automake libtool pkg-config && \
        rm -rf /var/lib/apt/lists/*

    git clone --depth 1 https://github.com/ANGSD/angsd.git /opt/angsd
    cd /opt/angsd
    git checkout 6b5d90641cc6924a0fab06584297f9a1cd1f46ac
    make -j1
    cp /opt/angsd/angsd /usr/local/bin/angsd

    apt-get update -qq && apt-get install -y --no-install-recommends \
        libbz2-1.0 liblzma5 libcurl4 zlib1g ca-certificates && \
        rm -rf /var/lib/apt/lists/*

%runscript
    exec /usr/local/bin/angsd "$@"

%help
    Apptainer image for angsd.
    Default runscript forwards arguments to the tool entrypoint.
