# BIJUX_TEMPLATE: v1

# Tool ID: bowtie2
# Version policy: pinned_or_registry_locked
# Upstream source: see org.opencontainers.image.source label
# Build date policy: org.opencontainers.image.created set by release pipeline
# Network source policy: NETWORK_SOURCE_VERIFIED_BY_LOCK
# Runtime UID policy: RUNTIME_UID_SAFE

# VERSION_SOURCE: containers/versions/versions.toml
Bootstrap: docker
From: ubuntu:24.04@sha256:cd1dba651b3080c3686ecf4e3c4220f026b521fb76978881737d24f200828b2b

%labels
    MAINTAINER Bijan Mousavi <mousavi.bijan@gmail.com>
    VERSION Bowtie2-v2.5.4

    org.opencontainers.image.source https://github.com/bijux/bijux-dna
    org.opencontainers.image.revision unknown
    org.opencontainers.image.created unknown
    org.opencontainers.image.licenses GPL-3.0
    org.opencontainers.image.version 2.5.4
    org.opencontainers.image.tool bowtie2
    org.opencontainers.image.title bowtie2
%environment
    export PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
    export LC_ALL=C
    export TZ=UTC
    DEBIAN_FRONTEND=noninteractive

%post
    set -eux
    umask 022
    export DEBIAN_FRONTEND=noninteractive

    apt-get update && \
    apt-get install -y --no-install-recommends \
        perl \
        curl \
        wget \
        unzip \
        ca-certificates \
        make \
        gcc && \

    curl -L https://cpanmin.us | perl - --self-upgrade && \
    cpanm Sys::Hostname && \

    VERSION=2.5.4 && \
    ARCH=$(uname -m) && \
    if [ "$ARCH" = "x86_64" ]; then \
        SUFFIX=linux-x86_64; \
    elif [ "$ARCH" = "aarch64" ]; then \
        SUFFIX=linux-aarch64; \
    else \
        echo "Unsupported architecture: $ARCH" >&2; \
        exit 1; \
    fi && \
    wget -q https://github.com/BenLangmead/bowtie2/releases/download/v${VERSION}/bowtie2-${VERSION}-${SUFFIX}.zip -O /tmp/bowtie2.zip && \
    unzip -q /tmp/bowtie2.zip -d /opt && \
    cp /opt/bowtie2-${VERSION}-${SUFFIX}/bowtie2* /usr/local/bin/ && \
    rm -rf /tmp/bowtie2.zip /opt/bowtie2-${VERSION}-${SUFFIX} && \

    rm -rf /var/lib/apt/lists/*

%runscript
    if [ $# -eq 0 ]; then
        exec /usr/local/bin/bowtie2 --help
    else
        exec /usr/local/bin/bowtie2 "$@"
    fi

%help
    This Apptainer image provides Bowtie2 version 2.5.4 with precompiled binaries matching the build host architecture (x86_64 or aarch64).
    Run with arguments to execute bowtie2, or without arguments to display detailed help.
