# BIJUX_TEMPLATE: v1

# Tool ID: kraken2
# Version policy: pinned_or_registry_locked
# Upstream source: see org.opencontainers.image.source label
# Build date policy: org.opencontainers.image.created set by release pipeline
# Network source policy: NETWORK_SOURCE_VERIFIED_BY_LOCK
# Runtime UID policy: RUNTIME_UID_SAFE

Bootstrap: docker
From: ubuntu:24.04@sha256:cd1dba651b3080c3686ecf4e3c4220f026b521fb76978881737d24f200828b2b

%labels
    MAINTAINER Bijan Mousavi <mousavi.bijan@gmail.com>
    VERSION Kraken2-v2.1.3
    org.opencontainers.image.source https://github.com/DerrickWood/kraken2

    org.opencontainers.image.source https://github.com/bijux/bijux-dna
    org.opencontainers.image.revision unknown
    org.opencontainers.image.created unknown
    org.opencontainers.image.licenses GPL-3.0
    org.opencontainers.image.version 2.1.3
    org.opencontainers.image.tool kraken2
    org.opencontainers.image.title kraken2
%environment
    export PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
    export LC_ALL=C
    export TZ=UTC
    DEBIAN_FRONTEND=noninteractive

%post
    set -eux
    export DEBIAN_FRONTEND=noninteractive

    apt-get update && \
    apt-get install -y --no-install-recommends \
        wget ca-certificates build-essential zlib1g-dev && \

    wget -q https://github.com/DerrickWood/kraken2/archive/v2.1.3.tar.gz -O /tmp/kraken2.tar.gz && \
    tar -xzf /tmp/kraken2.tar.gz -C /opt && \
    cd /opt/kraken2-2.1.3 && \
    ./install_kraken2.sh /usr/local/bin && \

    cd / && \
    rm -rf /tmp/kraken2.tar.gz /opt/kraken2-2.1.3 && \
    rm -rf /var/lib/apt/lists/*

%runscript
    if [ $# -eq 0 ]; then
        exec /usr/local/bin/kraken2 --help
    else
        exec /usr/local/bin/kraken2 "$@"
    fi

%help
    This Apptainer image provides Kraken2 version 2.1.3, installed via the official script.
    All Kraken2 tools and scripts are available in /usr/local/bin.
    Run with arguments to execute kraken2, or without arguments to display detailed help.
