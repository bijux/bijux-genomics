# BIJUX_TEMPLATE: v1

# Tool ID: krakenuniq
# Version policy: pinned_or_registry_locked
# Upstream source: see org.opencontainers.image.source label
# Build date policy: org.opencontainers.image.created set by release pipeline
# Network source policy: NETWORK_SOURCE_VERIFIED_BY_LOCK
# Runtime UID policy: RUNTIME_UID_SAFE

# VERSION_SOURCE: containers/versions/versions.toml
Bootstrap: docker
From: ubuntu:24.04@sha256:cd1dba651b3080c3686ecf4e3c4220f026b521fb76978881737d24f200828b2b

%labels
    VERSION unknown
    org.opencontainers.image.source https://github.com/bijux/bijux-dna
    org.opencontainers.image.revision unknown
    org.opencontainers.image.created unknown
    org.opencontainers.image.licenses GPL-3.0
    org.opencontainers.image.version 1.0.4
    org.opencontainers.image.tool krakenuniq
    org.opencontainers.image.title krakenuniq

%environment
    export PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
    export LC_ALL=C
    export TZ=UTC
    DEBIAN_FRONTEND=noninteractive

%post
    set -eux
    umask 022
    export DEBIAN_FRONTEND=noninteractive
    apt-get update -qq && apt-get install -y --no-install-recommends \
        git build-essential wget perl python3 ca-certificates zlib1g-dev libbz2-dev && \
        rm -rf /var/lib/apt/lists/*

    git clone --depth 1 https://github.com/fbreitwieser/krakenuniq.git /opt/krakenuniq
    cd /opt/krakenuniq
    git checkout f4e3796580c5c576b15e929c741e6e725b7e29b6
    sed -i '1i #include <cstdint>' src/uid_mapping.hpp
    sed -i '1i #include <cstdint>' src/report-cols.hpp
    ./install_krakenuniq.sh /opt/krakenuniq/install

    ln -sf /opt/krakenuniq/install/krakenuniq /usr/local/bin/krakenuniq

%runscript
    exec /usr/local/bin/krakenuniq "$@"

%help
    Apptainer image for KrakenUniq.
    Default runscript forwards arguments to krakenuniq.
