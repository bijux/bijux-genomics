# BIJUX_TEMPLATE: v1

# Tool ID: metaphlan
# Version policy: pinned_or_registry_locked
# Upstream source: see org.opencontainers.image.source label
# Build date policy: org.opencontainers.image.created set by release pipeline
# Network source policy: NETWORK_SOURCE_VERIFIED_BY_LOCK
# Runtime UID policy: RUNTIME_UID_SAFE

# VERSION_SOURCE: containers/versions/versions.toml
Bootstrap: docker
From: ubuntu:24.04@sha256:cd1dba651b3080c3686ecf4e3c4220f026b521fb76978881737d24f200828b2b

%labels
    MAINTAINER Bijan Mousavi <mousavi.bijan@gmail.com>
    VERSION MetaPhlAn-v4.1.1
    org.opencontainers.image.source https://github.com/biobakery/MetaPhlAn

    org.opencontainers.image.source https://github.com/bijux/bijux-dna
    org.opencontainers.image.revision unknown
    org.opencontainers.image.created unknown
    org.opencontainers.image.licenses GPL-3.0
    org.opencontainers.image.version 4.1.1
    org.opencontainers.image.tool metaphlan
    org.opencontainers.image.title metaphlan
%environment
    export PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
    export LC_ALL=C
    export TZ=UTC
    DEBIAN_FRONTEND=noninteractive

%post
    set -eux
    umask 022
    export DEBIAN_FRONTEND=noninteractive

    apt-get update && \
    apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        python3-dev \
        build-essential \
        pkg-config \
        libbz2-dev \
        liblzma-dev \
        libcurl4-gnutls-dev \
        libssl-dev \
        zlib1g-dev \
        libhdf5-dev && \

    pip3 install --no-cache-dir --break-system-packages \
        metaphlan==4.1.1 && \

    mv /usr/local/bin/metaphlan /usr/local/bin/metaphlan-bin && \

    # Create a wrapper script with version override.
    cat > /usr/local/bin/metaphlan <<'EOF'
#!/bin/sh
case "$1" in
  --version) echo "4.1.1"; exit 0;;
  --help)    exec /usr/local/bin/metaphlan-bin --help;;
  *)         exec /usr/local/bin/metaphlan-bin "$@";;
esac
EOF
    chmod +x /usr/local/bin/metaphlan && \
    rm -rf /var/lib/apt/lists/*

%runscript
    if [ $# -eq 0 ]; then
        exec /usr/local/bin/metaphlan --help
    else
        exec /usr/local/bin/metaphlan "$@"
    fi

%help
    This Apptainer image provides MetaPhlAn version 4.1.1, installed via pip.
    The default command is 'metaphlan' (with wrapper for consistent --version output).
    Run without arguments to display help.
