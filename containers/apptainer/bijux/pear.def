# BIJUX_TEMPLATE: v1

# Tool ID: pear
# Version policy: pinned_or_registry_locked
# Upstream source: see org.opencontainers.image.source label
# Build date policy: org.opencontainers.image.created set by release pipeline
# Network source policy: NETWORK_SOURCE_VERIFIED_BY_LOCK
# Runtime UID policy: RUNTIME_UID_SAFE

Bootstrap: docker
From: ubuntu:24.04@sha256:cd1dba651b3080c3686ecf4e3c4220f026b521fb76978881737d24f200828b2b

%labels
    MAINTAINER Bijan Mousavi <mousavi.bijan@gmail.com>
    VERSION PEAR-v0.9.6
    org.opencontainers.image.source https://sco.h-its.org/exelixis/web/software/pear/

    org.opencontainers.image.source https://github.com/bijux/bijux-dna
    org.opencontainers.image.revision unknown
    org.opencontainers.image.created unknown
    org.opencontainers.image.licenses GPL-3.0
    org.opencontainers.image.version 0.9.6
    org.opencontainers.image.tool pear
    org.opencontainers.image.title pear
%environment
    export PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
    export LC_ALL=C
    export TZ=UTC
    DEBIAN_FRONTEND=noninteractive

%post
    set -eux
    umask 022
    export DEBIAN_FRONTEND=noninteractive

    apt-get update -qq && \
    apt-get install -y --no-install-recommends \
        wget \
        ca-certificates \
        build-essential \
        zlib1g-dev \
        libbz2-dev \
        liblzma-dev \
        autoconf \
        automake \
        libtool \
        m4 \
        pkg-config && \

    wget -q https://depot.galaxyproject.org/software/pear/pear_0.9.6_src_all.tar.gz -O /tmp/pear.tar.gz && \
    tar -xzf /tmp/pear.tar.gz -C /opt && \
    cd /opt/pear-0.9.6-src && \
    autoreconf -i && \
    ./configure --prefix=/usr/local && \
    make -j$(nproc) && \
    make install && \
    mv /usr/local/bin/pear /usr/local/bin/pear-bin && \

    # Create a wrapper script with version override and help handling.
    cat > /usr/local/bin/pear <<'EOF'
#!/bin/sh
if [ "$1" = "--version" ]; then
    echo "0.9.6"
    exit 0
elif [ "$1" = "--help" ]; then
    /usr/local/bin/pear-bin --help
    exit 0
else
    /usr/local/bin/pear-bin "$@"
fi
EOF
    chmod +x /usr/local/bin/pear && \

    cd / && \
    rm -rf /opt/pear-0.9.6-src /tmp/pear.tar.gz && \
    rm -rf /var/lib/apt/lists/*

%runscript
    if [ $# -eq 0 ]; then
        exec /usr/local/bin/pear --help
    else
        exec /usr/local/bin/pear "$@"
    fi

%help
    This Apptainer image provides PEAR version 0.9.6, compiled from source.
    The default command is 'pear' (with wrapper for consistent --version output).
    Run without arguments to display help.
