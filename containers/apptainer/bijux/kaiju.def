# BIJUX_TEMPLATE: v1

# Tool ID: kaiju
# Version policy: pinned_or_registry_locked
# Upstream source: see org.opencontainers.image.source label
# Build date policy: org.opencontainers.image.created set by release pipeline
# Network source policy: NETWORK_SOURCE_VERIFIED_BY_LOCK
# Runtime UID policy: RUNTIME_UID_SAFE

# VERSION_SOURCE: containers/versions/versions.toml
Bootstrap: docker
From: ubuntu:24.04@sha256:cd1dba651b3080c3686ecf4e3c4220f026b521fb76978881737d24f200828b2b

%labels
    MAINTAINER Bijan Mousavi <mousavi.bijan@gmail.com>
    VERSION Kaiju-v1.10.0
    org.opencontainers.image.source https://github.com/bioinformatics-centre/kaiju

    org.opencontainers.image.source https://github.com/bijux/bijux-dna
    org.opencontainers.image.revision unknown
    org.opencontainers.image.created unknown
    org.opencontainers.image.licenses GPL-3.0
    org.opencontainers.image.version 1.10.0
    org.opencontainers.image.tool kaiju
    org.opencontainers.image.title kaiju
%environment
    export PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
    export LC_ALL=C
    export TZ=UTC
    DEBIAN_FRONTEND=noninteractive

%post
    set -eux
    umask 022
    export DEBIAN_FRONTEND=noninteractive

    apt-get update && \
    apt-get install -y --no-install-recommends \
        wget \
        ca-certificates \
        build-essential \
        zlib1g-dev && \

    wget -q https://github.com/bioinformatics-centre/kaiju/archive/v1.10.0.tar.gz -O /tmp/kaiju.tar.gz && \
    tar -xzf /tmp/kaiju.tar.gz -C /opt && \
    cd /opt/kaiju-1.10.0/src && \
    make && \
    mv ../bin/kaiju /usr/local/bin/kaiju-bin && \
    mv ../bin/* /usr/local/bin/ && \

    # Create a wrapper script with version override and help handling.
    cat > /usr/local/bin/kaiju <<'EOF'
#!/bin/sh
if [ "$1" = "--version" ]; then
    echo "1.10.0"
    exit 0
elif [ "$1" = "--help" ]; then
    /usr/local/bin/kaiju-bin --help
    exit 0
else
    /usr/local/bin/kaiju-bin "$@"
fi
EOF
    chmod +x /usr/local/bin/kaiju && \

    cd / && \
    rm -rf /tmp/kaiju.tar.gz /opt/kaiju-1.10.0 && \
    rm -rf /var/lib/apt/lists/*

%runscript
    if [ $# -eq 0 ]; then
        exec /usr/local/bin/kaiju --help
    else
        exec /usr/local/bin/kaiju "$@"
    fi

%help
    This Apptainer image provides Kaiju version 1.10.0, compiled from source.
    All Kaiju tools (kaiju, kaiju2table, etc.) are available.
    The default command is 'kaiju' (with wrapper for consistent --version output).
    Run without arguments to display help.
