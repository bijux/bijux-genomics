Bootstrap: docker
From: ubuntu:24.04@sha256:cd1dba651b3080c3686ecf4e3c4220f026b521fb76978881737d24f200828b2b

%labels
    VERSION unknown
    org.opencontainers.image.source https://github.com/bijux/bijux-dna
    org.opencontainers.image.revision unknown
    org.opencontainers.image.created unknown
    org.opencontainers.image.licenses GPL-3.0
    org.opencontainers.image.version 0.80
    org.opencontainers.image.tool pydamage
    org.opencontainers.image.title pydamage

%environment
    DEBIAN_FRONTEND=noninteractive

%post
    export DEBIAN_FRONTEND=noninteractive
    apt-get update -qq && apt-get install -y --no-install-recommends         python3 python3-pip python3-venv git ca-certificates &&         rm -rf /var/lib/apt/lists/*

    git clone --depth 1 https://github.com/maxibor/pydamage.git /opt/pydamage
    cd /opt/pydamage
    git checkout 08f1d0f2d1981d350decbf10964f989e9567ddbf
    python3 -m pip install --break-system-packages --no-cache-dir .

    cat > /usr/local/bin/pydamage <<'EOS'
#!/usr/bin/env sh
case "${1:-}" in
  --version) pydamage --version; exit 0 ;;
  --help|-h|"") pydamage --help; exit 0 ;;
esac
exec pydamage "$@"
EOS
    chmod +x /usr/local/bin/pydamage

%runscript
    exec /usr/local/bin/pydamage "$@"

%help
    Apptainer image for pydamage.
    Default runscript forwards arguments to the tool entrypoint.
