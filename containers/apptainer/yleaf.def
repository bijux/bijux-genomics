Bootstrap: docker
From: ubuntu:24.04@sha256:cd1dba651b3080c3686ecf4e3c4220f026b521fb76978881737d24f200828b2b

%labels
    org.opencontainers.image.source https://github.com/bijux/bijux-dna
    org.opencontainers.image.revision unknown
    org.opencontainers.image.created unknown
    org.opencontainers.image.licenses GPL-3.0
    org.opencontainers.image.version unknown

%post
    export DEBIAN_FRONTEND=noninteractive
    apt-get update && apt-get install -y --no-install-recommends ca-certificates && rm -rf /var/lib/apt/lists/*
    cat > /usr/local/bin/yleaf <<'EOS'
#!/usr/bin/env sh
if [ "${1:-}" = "--version" ]; then echo "unknown"; exit 0; fi
if [ "${1:-}" = "--help" ] || [ $# -eq 0 ]; then echo "yleaf container scaffold"; exit 0; fi
echo "yleaf executable not yet wired" >&2
exit 2
EOS
    chmod +x /usr/local/bin/yleaf

%runscript
    exec /usr/local/bin/yleaf "$@"

%help
    Scaffold Apptainer definition for yleaf with standardized labels and runscript.
