Bootstrap: docker
From: ubuntu:24.04@sha256:cd1dba651b3080c3686ecf4e3c4220f026b521fb76978881737d24f200828b2b

%labels
    MAINTAINER Bijan Mousavi <mousavi.bijan@gmail.com>
    VERSION SPAdes-v4.2.0-BayesHammer

    org.opencontainers.image.source https://github.com/bijux/bijux-dna
    org.opencontainers.image.revision unknown
    org.opencontainers.image.created unknown
    org.opencontainers.image.licenses GPL-3.0
    org.opencontainers.image.version unknown
%environment
    TZ=UTC
    DEBIAN_FRONTEND=noninteractive

%post
    export TZ=UTC
    export DEBIAN_FRONTEND=noninteractive

    BUILD_DEPS="build-essential cmake wget" && \
    RUNTIME_DEPS="libgomp1 libbz2-dev zlib1g-dev libboost-all-dev python3 python3-pip python3-yaml" && \

    apt-get update && \
    apt-get install -y --no-install-recommends \
        ${BUILD_DEPS} \
        ${RUNTIME_DEPS} && \

    wget -qO /tmp/spades.tar.gz \
        "https://github.com/ablab/spades/archive/refs/tags/v4.2.0.tar.gz" && \
    tar -xzf /tmp/spades.tar.gz -C /opt && \
    cd /opt/spades-4.2.0 && \
    ./spades_compile.sh && \
    cp -r bin/* /usr/local/bin/ && \
    cp -r share/spades /usr/local/share/ && \

    cd / && \
    rm -rf /opt/spades-4.2.0 /tmp/spades.tar.gz && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

    # Create a wrapper script for bayeshammer.
    printf '%s\n' \
      '#!/usr/bin/env bash' \
      'set -e' \
      'case "$1" in' \
      '  --version) echo "4.2.0"; exit 0 ;;' \
      '  --help|-h) exec spades.py --only-error-correction --help ;;' \
      'esac' \
      'exec spades.py --only-error-correction "$@"' \
      > /usr/local/bin/bayeshammer && \
    chmod +x /usr/local/bin/bayeshammer

%runscript
    if [ $# -eq 0 ]; then
        exec /usr/local/bin/bayeshammer --help
    else
        exec /usr/local/bin/bayeshammer "$@"
    fi

%help
    This Apptainer image provides BayesHammer (via SPAdes v4.2.0 error correction module).
    The default command is 'bayeshammer', which runs 'spades.py --only-error-correction'.
    Run without arguments to display help, or provide arguments to execute error correction.
