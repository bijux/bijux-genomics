Bootstrap: docker
From: ubuntu:24.04

%labels
    MAINTAINER Bijan Mousavi <mousavi.bijan@gmail.com>
    VERSION Cutadapt-v4.9

%environment
    DEBIAN_FRONTEND=noninteractive

%post
    export DEBIAN_FRONTEND=noninteractive

    apt-get update -qq && \
    apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        python3-dev \
        build-essential \
        ca-certificates && \

    python3 -m pip install --no-cache-dir --break-system-packages \
        "cutadapt==4.9" \
        numpy && \

    apt-get purge -y python3-dev build-essential && \
    apt-get autoremove -y && \
    rm -rf /var/lib/apt/lists/*

%runscript
    if [ $# -eq 0 ]; then
        exec cutadapt --help
    else
        exec cutadapt "$@"
    fi

%help
    This Apptainer image provides Cutadapt version 4.9.
    Run with arguments to execute cutadapt, or without arguments to display detailed help.