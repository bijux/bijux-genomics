Bootstrap: docker
From: ubuntu:24.04@sha256:cd1dba651b3080c3686ecf4e3c4220f026b521fb76978881737d24f200828b2b

%labels
    MAINTAINER Bijan Mousavi <mousavi.bijan@gmail.com>
    VERSION FastqValidator-v0.1.1
    org.opencontainers.image.source https://github.com/statgen/fastQValidator
    org.opencontainers.image.version v0.1.1
    org.opencontainers.image.tool fastqvalidator_official

    org.opencontainers.image.source https://github.com/bijux/bijux-dna
    org.opencontainers.image.revision unknown
    org.opencontainers.image.created unknown
    org.opencontainers.image.licenses GPL-3.0
    org.opencontainers.image.version unknown
%environment
    DEBIAN_FRONTEND=noninteractive

%post
    export DEBIAN_FRONTEND=noninteractive
    FASTQVALIDATOR_COMMIT=4cb293ca4153459b05ae7983f65a082d56b55c21

    apt-get update -qq && \
    apt-get install -y --no-install-recommends \
        git \
        build-essential \
        zlib1g-dev \
        libbz2-dev \
        zlib1g \
        libbz2-1.0 \
        ca-certificates && \

    git clone --depth 1 https://github.com/statgen/libStatGen.git /opt/libStatGen && cd /opt/libStatGen && git checkout fae4fca874b3b78bf9b61c0eae080c15edd976a4 && cd - && \
    git clone --branch v0.1.1 --depth 1 \
        https://github.com/statgen/fastQValidator.git /opt/fastQValidator && \
    cd /opt/fastQValidator && git checkout "$FASTQVALIDATOR_COMMIT" && cd - >/dev/null && \

    cd /opt/fastQValidator && \
    make -j$(nproc) LIB_PATH_FASTQ_VALIDATOR=/opt/libStatGen && \
    make install PREFIX=/usr/local && \

    mv /usr/local/bin/fastQValidator /usr/local/bin/fq-validator-bin && \

    # Create a wrapper script with version override and help handling.
    cat > /usr/local/bin/fastq-validator <<'EOF'
#!/bin/sh
case "$1" in
  --version) echo "0.1.1"; exit 0;;
  --help|-h|"") exec /usr/local/bin/fq-validator-bin --help;;
  *) exec /usr/local/bin/fq-validator-bin "$@";;
esac
EOF
    chmod +x /usr/local/bin/fastq-validator && \

    # Clean up source and build dependencies.
    rm -rf /opt/libStatGen /opt/fastQValidator && \
    rm -rf /var/lib/apt/lists/*

%runscript
    if [ $# -eq 0 ]; then
        exec /usr/local/bin/fastq-validator --help
    else
        exec /usr/local/bin/fastq-validator "$@"
    fi

%help
    This Apptainer image provides the official FastqValidator version 0.1.1 (compiled from source).
    The default command is 'fastq-validator'; run without arguments to display help.
