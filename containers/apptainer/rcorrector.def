Bootstrap: docker
From: ubuntu:24.04@sha256:cd1dba651b3080c3686ecf4e3c4220f026b521fb76978881737d24f200828b2b

%labels
    MAINTAINER Bijan Mousavi <mousavi.bijan@gmail.com>
    VERSION Rcorrector-v1.0.7
    COMMIT_SHA f8915b79363e896409bd9ca56819f56c3f77a47e
    JELLYFISH_VERSION 2.3.0
    org.opencontainers.image.source https://github.com/mourisl/Rcorrector
    org.opencontainers.image.licenses GPL-3.0

    org.opencontainers.image.source https://github.com/bijux/bijux-dna
    org.opencontainers.image.revision unknown
    org.opencontainers.image.created unknown
    org.opencontainers.image.licenses GPL-3.0
    org.opencontainers.image.version unknown
    org.opencontainers.image.tool rcorrector
%environment
    DEBIAN_FRONTEND=noninteractive
    TZ=UTC
    VERSION_RCORRECTOR=1.0.7
    JELLYFISH_VERSION=2.3.0
    PATH=/opt/jellyfish/bin:/usr/local/bin:/usr/bin:/bin

%post
    set -eux
    export DEBIAN_FRONTEND=noninteractive

    apt-get update
    apt-get install -y --no-install-recommends \
        build-essential \
        git \
        perl \
        ca-certificates \
        wget \
        curl \
        zlib1g-dev \
        libbz2-dev

    # Section: Build Jellyfish v2.3.0 deterministically to avoid apt version drift.
    mkdir -p /opt/src
    cd /opt/src
    wget -O jellyfish.tar.gz \
      https://github.com/gmarcais/Jellyfish/releases/download/v2.3.0/jellyfish-2.3.0.tar.gz \
      || curl -L -o jellyfish.tar.gz \
      https://github.com/gmarcais/Jellyfish/releases/download/v2.3.0/jellyfish-2.3.0.tar.gz
    tar -xzf jellyfish.tar.gz
    cd jellyfish-2.3.0
    ./configure --prefix=/opt/jellyfish
    make -j"$(nproc)"
    make install

    # Section: Fetch and pin Rcorrector.
    mkdir -p /opt/rcorrector
    for i in 1 2 3; do \
        git clone --depth 1 https://github.com/mourisl/Rcorrector.git /opt/rcorrector && break || \
        echo "Git clone attempt $i failed, retrying..." && sleep 5; \
    done || { echo "Failed to clone Rcorrector after 3 attempts"; exit 1; }

    cd /opt/rcorrector
    git checkout f8915b79363e896409bd9ca56819f56c3f77a47e

    # Point the Perl wrapper to the compiled binary installed as rcorrector-bin.
    sed -i 's|\$WD/rcorrector|\$WD/rcorrector-bin|g' run_rcorrector.pl

    # Apply the toolchain compatibility patch as in the Dockerfile.
    sed -i 's/-1/(char)-1/g' ./*.cpp

    # Build while ensuring the local Jellyfish is used and no extra downloads happen.
    export PATH="/opt/jellyfish/bin:${PATH}"
    make -j"$(nproc)"

    install -m 0755 ./rcorrector /usr/local/bin/rcorrector-bin
    install -m 0755 ./run_rcorrector.pl /usr/local/bin/run_rcorrector.pl

    # Create a wrapper with the same behavior as the Docker entrypoint.
    cat > /usr/local/bin/rcorrector <<'EOF'
#!/usr/bin/env bash
set -euo pipefail

case "${1:-}" in
  --version)
    echo "1.0.7"
    exit 0
    ;;
  --help|-h|"")
    exec perl /usr/local/bin/run_rcorrector.pl --help
    ;;
esac

exec perl /usr/local/bin/run_rcorrector.pl "$@"
EOF
    chmod 0755 /usr/local/bin/rcorrector

    # Section: Clean up.
    cd /
    rm -rf /opt/src/jellyfish-2.3.0 /opt/src/jellyfish.tar.gz /opt/rcorrector

    # Do not remove sed or grep (essential on Ubuntu). Purge only real build dependencies.
        build-essential \
        git \
        wget \
        curl \
        zlib1g-dev \
        libbz2-dev

    rm -rf /var/lib/apt/lists/*

%runscript
    if [ $# -eq 0 ]; then
        exec rcorrector --help
    else
        exec rcorrector "$@"
    fi

%help
    Rcorrector v1.0.7 (commit f8915b7) built from source on Ubuntu 24.04.
    Ships Jellyfish v2.3.0 under /opt/jellyfish to ensure deterministic behavior.
    Entry point: rcorrector (Perl wrapper).
    Underlying binary: rcorrector-bin.
