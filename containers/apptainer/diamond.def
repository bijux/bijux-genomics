Bootstrap: docker
From: ubuntu:24.04@sha256:cd1dba651b3080c3686ecf4e3c4220f026b521fb76978881737d24f200828b2b

%labels
    org.opencontainers.image.source https://github.com/bijux/bijux-dna
    org.opencontainers.image.revision unknown
    org.opencontainers.image.created unknown
    org.opencontainers.image.licenses GPL-3.0
    org.opencontainers.image.version 2.1.11

%post
    export DEBIAN_FRONTEND=noninteractive
    apt-get update -qq && apt-get install -y --no-install-recommends \
        git build-essential cmake zlib1g-dev libbz2-dev liblzma-dev \
        ca-certificates && \
        rm -rf /var/lib/apt/lists/*

    git clone --depth 1 https://github.com/bbuchfink/diamond.git /opt/diamond
    cd /opt/diamond
    git checkout add7f3bcb120704b8162b99d996fe9f5c110cec6
    cmake -S . -B build -DCMAKE_BUILD_TYPE=Release
    cmake --build build -j"$(nproc)"
    cp /opt/diamond/build/diamond /usr/local/bin/diamond

%runscript
    exec /usr/local/bin/diamond "$@"

%help
    Apptainer image for DIAMOND.
    Default runscript forwards arguments to diamond.
