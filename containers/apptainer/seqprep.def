Bootstrap: docker
From: ubuntu:24.04@sha256:cd1dba651b3080c3686ecf4e3c4220f026b521fb76978881737d24f200828b2b

%labels
    org.opencontainers.image.source https://github.com/bijux/bijux-dna
    org.opencontainers.image.revision unknown
    org.opencontainers.image.created unknown
    org.opencontainers.image.licenses GPL-3.0
    org.opencontainers.image.version 1.3
    org.opencontainers.image.tool seqprep

%environment
    DEBIAN_FRONTEND=noninteractive

%post
    export DEBIAN_FRONTEND=noninteractive
    apt-get update -qq && apt-get install -y --no-install-recommends \
        git build-essential zlib1g-dev ca-certificates && \
        rm -rf /var/lib/apt/lists/*

    git clone --depth 1 https://github.com/jstjohn/SeqPrep.git /opt/SeqPrep
    cd /opt/SeqPrep
    git checkout 575507b0b9c94701bdf67bb592da8ba91ba9639c
    make
    cp /opt/SeqPrep/SeqPrep /usr/local/bin/seqprep

%runscript
    exec /usr/local/bin/seqprep "$@"

%help
    Apptainer image for SeqPrep.
    Default runscript forwards arguments to seqprep.
