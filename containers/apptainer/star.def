Bootstrap: docker
From: ubuntu:24.04@sha256:cd1dba651b3080c3686ecf4e3c4220f026b521fb76978881737d24f200828b2b

%labels
    MAINTAINER Bijan Mousavi <mousavi.bijan@gmail.com>
    VERSION STAR-2.7.11b
    org.opencontainers.image.source https://github.com/alexdobin/STAR
    org.opencontainers.image.title STAR
    org.opencontainers.image.licenses Apache-2.0

    org.opencontainers.image.source https://github.com/bijux/bijux-dna
    org.opencontainers.image.revision unknown
    org.opencontainers.image.created unknown
    org.opencontainers.image.licenses GPL-3.0
    org.opencontainers.image.version unknown
    org.opencontainers.image.tool star
%environment
    DEBIAN_FRONTEND=noninteractive
    TZ=UTC
    VERSION_STAR=2.7.11b

%post
    set -eux
    export DEBIAN_FRONTEND=noninteractive

    apt-get update
    apt-get install -y --no-install-recommends \
        wget \
        ca-certificates \
        build-essential \
        zlib1g-dev \
        libbz2-dev \
        xxd

    # Fetch source
    cd /tmp
    wget -q -O star.tar.gz \
      "https://github.com/alexdobin/STAR/archive/2.7.11b.tar.gz"

    mkdir -p /opt
    tar -xzf star.tar.gz -C /opt
    cd /opt/STAR-2.7.11b/source

    # Remove x86 SIMD flags from Makefiles (safe on all arches)
    find . -name Makefile -exec \
        sed -Ei 's/-mavx2|-msse[0-9.]*|-mfpmath=sse//g' {} \;

    # APPTAINER_CPU_FLAG_JUSTIFIED: STAR requires explicit ARM tuning to avoid
    # build/runtime breakage on aarch64; this is constrained to arm64 hosts only.
    # Add ARM flags ONLY when actually compiling on ARM64
    arch="$(uname -m)"
    if [ "$arch" = "aarch64" ] || [ "$arch" = "arm64" ]; then
        echo 'CFLAGS  += -march=armv8-a' >> Makefile
        echo 'CXXFLAGS+= -march=armv8-a' >> Makefile
    fi

    # Build
    make -j"$(nproc)" STAR

    install -m 0755 ./STAR /usr/local/bin/star-bin

    # Wrapper: unified execution + stable --version / --help behavior
    cat > /usr/local/bin/star <<'EOF'
#!/usr/bin/env sh
set -eu

case "${1:-}" in
  --version)
    echo "${VERSION_STAR}"
    exit 0
    ;;
  --help|-h|"")
    exec /usr/local/bin/star-bin --help 2>&1
    ;;
esac

exec /usr/local/bin/star-bin "$@"
EOF
    chmod 0755 /usr/local/bin/star

    # Clean up.
    cd /
    rm -rf /opt/STAR-2.7.11b /tmp/star.tar.gz

    # Purge build deps only (keep ca-certificates)
        wget \
        build-essential \
        xxd \
        zlib1g-dev \
        libbz2-dev

    rm -rf /var/lib/apt/lists/*

%runscript
    if [ $# -eq 0 ]; then
        exec star --help
    else
        exec star "$@"
    fi

%help
    STAR v2.7.11b built from source on Ubuntu 24.04.
    Wrapper: 'star' -> /usr/local/bin/star-bin
