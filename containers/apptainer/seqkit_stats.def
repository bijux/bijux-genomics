Bootstrap: docker
From: ubuntu:24.04@sha256:cd1dba651b3080c3686ecf4e3c4220f026b521fb76978881737d24f200828b2b

%labels
    org.opencontainers.image.source https://github.com/bijux/bijux-dna
    org.opencontainers.image.revision unknown
    org.opencontainers.image.created unknown
    org.opencontainers.image.licenses GPL-3.0
    org.opencontainers.image.version 2.8.2
    org.opencontainers.image.tool seqkit_stats

%environment
    DEBIAN_FRONTEND=noninteractive

%post
    export DEBIAN_FRONTEND=noninteractive
    apt-get update -qq && \
    apt-get install -y --no-install-recommends ca-certificates seqkit && \
    rm -rf /var/lib/apt/lists/*

    cat > /usr/local/bin/seqkit_stats <<'EOS'
#!/usr/bin/env sh
if [ "${1:-}" = "--version" ]; then
  seqkit version | awk '{print $2}'
  exit 0
fi
if [ "${1:-}" = "--help" ] || [ $# -eq 0 ]; then
  exec seqkit stats --help
fi
exec seqkit stats "$@"
EOS
    chmod +x /usr/local/bin/seqkit_stats

%runscript
    exec /usr/local/bin/seqkit_stats "$@"

%help
    Apptainer image for seqkit_stats.
    Default runscript forwards arguments to the seqkit stats wrapper.
