Bootstrap: docker
From: ubuntu:24.04@sha256:cd1dba651b3080c3686ecf4e3c4220f026b521fb76978881737d24f200828b2b

%labels
    MAINTAINER Bijan Mousavi <mousavi.bijan@gmail.com>
    VERSION samtools-1.21
    org.opencontainers.image.source https://www.htslib.org/
    org.opencontainers.image.title samtools
    org.opencontainers.image.licenses Apache-2.0

    org.opencontainers.image.source https://github.com/bijux/bijux-dna
    org.opencontainers.image.revision unknown
    org.opencontainers.image.created unknown
    org.opencontainers.image.licenses GPL-3.0
    org.opencontainers.image.version unknown
%environment
    DEBIAN_FRONTEND=noninteractive
    TZ=UTC
    VERSION_SAMTOOLS=1.21

%post
    set -eux
    export DEBIAN_FRONTEND=noninteractive

    apt-get update
    apt-get install -y --no-install-recommends \
        samtools \
        ca-certificates

    # Keep the distro binary as samtools-bin (like your Dockerfile)
    install -m 0755 /usr/bin/samtools /usr/local/bin/samtools-bin
    rm -f /usr/bin/samtools

    # Wrapper script: unified execution + stable --version / --help behavior
    cat > /usr/local/bin/samtools <<'EOF'
#!/usr/bin/env sh
set -eu

case "${1:-}" in
  --version)
    # Keep your desired pinned value (note: may differ from apt-installed version)
    echo "${VERSION_SAMTOOLS}"
    exit 0
    ;;
  --help|-h|"")
    exec /usr/local/bin/samtools-bin --help
    ;;
esac

exec /usr/local/bin/samtools-bin "$@"
EOF
    chmod 0755 /usr/local/bin/samtools

    # Clean up apt lists. (don’t try to remove essential packages)
    rm -rf /var/lib/apt/lists/*

%runscript
    if [ $# -eq 0 ]; then
        exec samtools --help
    else
        exec samtools "$@"
    fi

%help
    This Apptainer image provides Samtools (installed from Ubuntu 24.04 packages).
    Wrapper: 'samtools' (stable --version and --help behavior)
    Underlying binary: 'samtools-bin'
