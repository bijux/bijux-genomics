Bootstrap: docker
From: ubuntu:24.04

%labels
    MAINTAINER Bijan Mousavi <mousavi.bijan@gmail.com>
    VERSION vsearch-2.28.1
    org.opencontainers.image.source https://github.com/torognes/vsearch
    org.opencontainers.image.title vsearch
    org.opencontainers.image.licenses Apache-2.0

%environment
    DEBIAN_FRONTEND=noninteractive
    TZ=UTC
    VERSION_VSEARCH=2.28.1

%post
    set -eux
    export DEBIAN_FRONTEND=noninteractive

    apt-get update
    apt-get install -y --no-install-recommends \
        wget \
        ca-certificates \
        build-essential \
        git \
        autoconf \
        automake \
        libtool \
        pkg-config \
        zlib1g-dev \
        libbz2-dev \
        liblzma-dev

    # Fetch source at the requested tag (with retries)
    for i in 1 2 3; do \
        git clone --depth 1 --branch "v2.28.1" https://github.com/torognes/vsearch.git /tmp/vsearch-src && break || \
        echo "Git clone attempt $i failed, retrying..." && sleep 5; \
    done || { echo "Failed to clone vsearch after 3 attempts"; exit 1; }

    cd /tmp/vsearch-src
    ./autogen.sh
    ./configure --quiet CFLAGS="-O3"
    make -j"$(nproc)"

    # Install binary
    install -m 0755 ./bin/vsearch /usr/local/bin/vsearch-bin
    strip /usr/local/bin/vsearch-bin || true

    # Wrapper: unified execution + stable --version / --help behavior
    cat > /usr/local/bin/vsearch <<'EOF'
#!/usr/bin/env sh
set -eu

case "${1:-}" in
  --version)
    echo "${VERSION_VSEARCH}"
    exit 0
    ;;
  --help|-h|"")
    exec /usr/local/bin/vsearch-bin --help
    ;;
esac

exec /usr/local/bin/vsearch-bin "$@"
EOF
    chmod 0755 /usr/local/bin/vsearch

    # Clean up the build tree. (avoid Docker-style aggressive purges that break Apptainer)
    cd /
    rm -rf /tmp/vsearch-src
    rm -rf /var/lib/apt/lists/*

%runscript
    if [ $# -eq 0 ]; then
        exec vsearch --help
    else
        exec vsearch "$@"
    fi

%help
    This Apptainer image provides VSEARCH v2.28.1 built from source on Ubuntu 24.04.
    Wrapper: 'vsearch' (stable --version and --help behavior)
    Underlying binary: 'vsearch-bin'
