Bootstrap: docker
From: ubuntu:24.04

%labels
    MAINTAINER Bijan Mousavi <mousavi.bijan@gmail.com>
    VERSION MetaPhlAn-v4.1.1
    org.opencontainers.image.source https://github.com/biobakery/MetaPhlAn

%environment
    DEBIAN_FRONTEND=noninteractive

%post
    export DEBIAN_FRONTEND=noninteractive

    apt-get update && \
    apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        python3-dev \
        build-essential \
        pkg-config \
        libbz2-dev \
        liblzma-dev \
        libcurl4-gnutls-dev \
        libssl-dev \
        zlib1g-dev \
        libhdf5-dev && \

    pip3 install --no-cache-dir --break-system-packages \
        metaphlan==4.1.1 && \

    mv /usr/local/bin/metaphlan /usr/local/bin/metaphlan-bin && \

    # Create a wrapper script with version override.
    cat > /usr/local/bin/metaphlan <<'EOF'
#!/bin/sh
case "$1" in
  --version) echo "4.1.1"; exit 0;;
  --help)    exec /usr/local/bin/metaphlan-bin --help;;
  *)         exec /usr/local/bin/metaphlan-bin "$@";;
esac
EOF
    chmod +x /usr/local/bin/metaphlan && \

    apt-get purge -y python3-dev build-essential pkg-config \
        libbz2-dev liblzma-dev libcurl4-gnutls-dev libssl-dev \
        zlib1g-dev libhdf5-dev && \
    apt-get autoremove -y && \
    rm -rf /var/lib/apt/lists/*

%runscript
    if [ $# -eq 0 ]; then
        exec /usr/local/bin/metaphlan --help
    else
        exec /usr/local/bin/metaphlan "$@"
    fi

%help
    This Apptainer image provides MetaPhlAn version 4.1.1, installed via pip.
    The default command is 'metaphlan' (with wrapper for consistent --version output).
    Run without arguments to display help.