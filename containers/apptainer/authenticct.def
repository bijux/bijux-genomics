Bootstrap: docker
From: ubuntu:24.04@sha256:cd1dba651b3080c3686ecf4e3c4220f026b521fb76978881737d24f200828b2b

%labels
    org.opencontainers.image.source https://github.com/bijux/bijux-dna
    org.opencontainers.image.revision unknown
    org.opencontainers.image.created unknown
    org.opencontainers.image.licenses GPL-3.0
    org.opencontainers.image.version 1.0.0
    org.opencontainers.image.tool authenticct

%environment
    DEBIAN_FRONTEND=noninteractive

%post
    export DEBIAN_FRONTEND=noninteractive
    apt-get update -qq && apt-get install -y --no-install-recommends \
        python3 python3-dev python3-pip python3-venv git build-essential ca-certificates && \
        rm -rf /var/lib/apt/lists/*

    git clone --depth 1 https://github.com/StephanePeyregne/AuthentiCT.git /opt/authenticct
    cd /opt/authenticct
    git checkout f58b25c448c8d9afebcdddd351cbae84fd5f6bab
    python3 -m pip install --break-system-packages --no-cache-dir .

    cat > /usr/local/bin/authenticct <<'EOS'
#!/usr/bin/env sh
AUTHENTICT_SCRIPT="${AUTHENTICT_SCRIPT:-/opt/authenticct/AuthentiCT.py}"
if [ ! -f "${AUTHENTICT_SCRIPT}" ]; then
  AUTHENTICT_SCRIPT="$(find /opt/authenticct -type f -name "AuthentiCT.py" -print -quit 2>/dev/null || true)"
fi
run_authenticct() {
  if [ -n "${AUTHENTICT_SCRIPT}" ] && [ -f "${AUTHENTICT_SCRIPT}" ]; then
    python3 "${AUTHENTICT_SCRIPT}" "$@"
    return 0
  fi
  if command -v AuthentiCT.py >/dev/null 2>&1; then
    AuthentiCT.py "$@"
    return 0
  fi
  echo "AuthentiCT.py not found under /opt/authenticct and not on PATH" >&2
  return 127
}
case "${1:-}" in
  --version) run_authenticct --version; exit 0 ;;
  --help|-h|"") run_authenticct --help; exit 0 ;;
esac
run_authenticct "$@"
EOS
    chmod +x /usr/local/bin/authenticct

%runscript
    exec /usr/local/bin/authenticct "$@"

%help
    Apptainer image for authenticct.
    Default runscript forwards arguments to the tool entrypoint.
