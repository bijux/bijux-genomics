Bootstrap: docker
From: python:3.10-slim

%labels
    MAINTAINER Bijan Mousavi <mousavi.bijan@gmail.com>
    VERSION Atropos-v1.1.31
    org.opencontainers.image.source https://github.com/jdidion/atropos

%post
    export DEBIAN_FRONTEND=noninteractive

    apt-get update -qq && \
    apt-get install -y --no-install-recommends \
        build-essential \
        ca-certificates && \
    rm -rf /var/lib/apt/lists/*

    python3 -m venv /opt/atropos-venv && \
    /opt/atropos-venv/bin/pip install --no-cache-dir "Cython<3" wheel && \
    /opt/atropos-venv/bin/pip download --no-binary :all: --no-deps \
        atropos==1.1.31 -d /tmp/atropos-src && \
    tar -xzf /tmp/atropos-src/atropos-1.1.31.tar.gz -C /tmp/atropos-src && \

    # Apply import patches using sed
    find /tmp/atropos-src/atropos-1.1.31/atropos -name '*.py' -exec sed -i \
        -e 's/from collections import OrderedDict, Iterable, Sequence/from collections import OrderedDict\nfrom collections.abc import Iterable, Sequence/' \
        -e 's/from collections import Sequence, defaultdict/from collections import defaultdict\nfrom collections.abc import Sequence/' \
        -e 's/from collections import Iterable, Sequence/from collections.abc import Iterable, Sequence/' \
        -e 's/from collections import Sequence/from collections.abc import Sequence/' \
        -e 's/from collections import Iterable/from collections.abc import Iterable/' {} + && \

    cat > /tmp/pygensend.h <<'EOF'
#include <Python.h>
#ifndef __PYX_GEN_SEND_COMPAT
#define __PYX_GEN_SEND_COMPAT
static inline PyObject* __Pyx_PyGen_Send(PyGenObject* gen, PyObject* value) {
    PyObject* result = NULL;
    PySendResult res = PyIter_Send((PyObject*)gen, value, &result);
    if (res == PYGEN_RETURN) {
        if (result == NULL) {
            result = Py_None;
            Py_INCREF(result);
        }
        PyErr_SetObject(PyExc_StopIteration, result);
        Py_DECREF(result);
        return NULL;
    }
    if (res == PYGEN_ERROR) {
        return NULL;
    }
    return result;
}
#endif
#define _PyGen_Send __Pyx_PyGen_Send
#define PyGen_Send __Pyx_PyGen_Send
EOF

    CFLAGS="-include /tmp/pygensend.h" CPPFLAGS="-include /tmp/pygensend.h" \
    /opt/atropos-venv/bin/pip install --no-cache-dir --no-build-isolation \
        /tmp/atropos-src/atropos-1.1.31 && \
    ln -s /opt/atropos-venv/bin/atropos /usr/local/bin/atropos && \

    rm -rf /tmp/atropos-src /tmp/pygensend.h && \
    apt-get purge -y build-essential && \
    apt-get autoremove -y && \
    rm -rf /var/lib/apt/lists/*

%runscript
    if [ $# -eq 0 ]; then
        exec /usr/local/bin/atropos --version
    else
        exec /usr/local/bin/atropos "$@"
    fi

%help
    This Apptainer image provides Atropos version 1.1.31 with compatibility patches.
    Run with arguments to execute the tool, or without arguments to display the version.