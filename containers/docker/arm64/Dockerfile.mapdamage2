# VERSION_SOURCE: containers/versions/versions.toml
FROM ubuntu:24.04@sha256:cd1dba651b3080c3686ecf4e3c4220f026b521fb76978881737d24f200828b2b
ARG OCI_REVISION=unknown
ARG OCI_CREATED=unknown
ARG TOOL_VERSION=2.2.2
LABEL org.opencontainers.image.source="https://github.com/bijux/bijux-genomics"       org.opencontainers.image.revision="${OCI_REVISION}"       org.opencontainers.image.created="${OCI_CREATED}"       org.opencontainers.image.licenses="GPL-3.0"       org.opencontainers.image.version="${TOOL_VERSION}"
LABEL org.opencontainers.image.tool="mapdamage2"
LABEL org.opencontainers.image.title="mapdamage2"
LABEL org.opencontainers.image.base.name="ubuntu:24.04@sha256:cd1dba651b3080c3686ecf4e3c4220f026b521fb76978881737d24f200828b2b"
LABEL org.opencontainers.image.base.digest="sha256:cd1dba651b3080c3686ecf4e3c4220f026b521fb76978881737d24f200828b2b"
ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update -qq && apt-get install -y --no-install-recommends     python3=3.12.3-0ubuntu2.1 python3-pip=24.0+dfsg-1ubuntu1.3 python3-venv=3.12.3-0ubuntu2.1 python3-dev=3.12.3-0ubuntu2.1 build-essential=12.10ubuntu1 git=1:2.43.0-1ubuntu7.3 ca-certificates=20240203 &&     rm -rf /var/lib/apt/lists/*

RUN git clone --depth 1 https://github.com/ginolhac/mapDamage.git /opt/mapdamage2 &&     cd /opt/mapdamage2 && git checkout 484bb3094de69422c2308385aa2bfaf0ef12fa27 &&     python3 -m pip install --break-system-packages --no-cache-dir .

RUN printf '%s\n'   '#!/usr/bin/env sh'   'case "${1:-}" in'   '  --version) mapDamage --version; exit 0 ;;'   '  --help|-h|"") mapDamage --help; exit 0 ;;'   'esac'   'exec mapDamage "$@"' > /usr/local/bin/mapdamage2 && chmod +x /usr/local/bin/mapdamage2

ENTRYPOINT ["/usr/local/bin/mapdamage2"]
CMD ["--help"]
